# Public vars are exposed to client bundle in Astro.
# Do NOT put private provider API keys here.

# Chatbot gateway URL (example)
PUBLIC_CHATBOT_API_ENDPOINT=https://api.example.com

# Optional metrics sink for widget events (open/send/success/error)
# Example: https://your-worker.example.com/metrics/homebot
PUBLIC_CHATBOT_METRICS_ENDPOINT=

# Tools worker API base URL (without trailing slash)
# Example: https://tools-worker.your-subdomain.workers.dev
PUBLIC_TOOLS_API_BASE=
