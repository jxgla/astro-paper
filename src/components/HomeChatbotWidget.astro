---
interface Props {
  locale?: "zh" | "en";
}

const { locale = "zh" } = Astro.props as Props;
const chatbotApi = import.meta.env.PUBLIC_CHATBOT_API_ENDPOINT || "";
const chatbotMetricsEndpoint = import.meta.env.PUBLIC_CHATBOT_METRICS_ENDPOINT || "";

const copy = locale === "en"
  ? {
      title: "Claw Bot",
      status: "ONLINE",
      welcome: "Hi, I am your site bot. Ask me anything about this blog.",
      placeholder: "Type your message...",
      thinking: "Thinking",
      send: "Send",
      open: "Open chatbot",
      close: "Close chatbot",
      expand: "Expand chatbot",
      collapse: "Restore chatbot size",
      error: "Network error",
      empty: "(No response)",
      footer: "POWERED BY OPENCLAW",
    }
  : {
      title: "鼓掌 · 机器人",
      status: "在线",
      welcome: "嘿！我是鼓掌集气人，欢迎随便聊聊。",
      placeholder: "说点什么...",
      thinking: "正在思考",
      send: "发送",
      open: "打开聊天机器人",
      close: "关闭聊天机器人",
      expand: "放大聊天窗口",
      collapse: "还原聊天窗口",
      error: "通信故障",
      empty: "（机器人没有回复）",
      footer: "POWERED BY OPENCLAW",
    };
---

<div
  class="homebot"
  data-homebot
  data-api={chatbotApi}
  data-metrics-endpoint={chatbotMetricsEndpoint}
  data-locale={locale}
>
  <button type="button" class="homebot-fab" data-homebot-fab aria-label={copy.open} title={copy.open}>
    <span class="homebot-fab-open">💬</span>
    <span class="homebot-fab-close" aria-hidden="true">✕</span>
  </button>

  <section class="homebot-panel" data-homebot-panel aria-label={copy.title}>
    <header class="homebot-head">
      <div class="homebot-avatar">
        <img src="/avatar.png" alt={copy.title} loading="lazy" decoding="async" />
      </div>
      <div class="homebot-meta">
        <p class="homebot-title">{copy.title}</p>
        <p class="homebot-status">{copy.status}</p>
      </div>
      <button
        type="button"
        class="homebot-expand"
        data-homebot-expand
        aria-label={copy.expand}
        title={copy.expand}
      >
        ⛶
      </button>
      <button
        type="button"
        class="homebot-close"
        data-homebot-close
        aria-label={copy.close}
        title={copy.close}
      >
        ✕
      </button>
    </header>

    <div class="homebot-messages" data-homebot-messages>
      <article class="homebot-msg homebot-msg-assistant">
        <span class="homebot-msg-avatar" aria-hidden="true">
          <img src="/avatar.png" alt="" loading="lazy" decoding="async" />
        </span>
        <div class="homebot-bubble">{copy.welcome}</div>
      </article>
    </div>

    <form class="homebot-form" data-homebot-form>
      <input
        class="homebot-input"
        data-homebot-input
        type="text"
        placeholder={copy.placeholder}
        autocomplete="off"
      />
      <button class="homebot-send" data-homebot-send type="submit">{copy.send}</button>
    </form>

    <p class="homebot-footer">{copy.footer}</p>
  </section>
</div>

<style>
  .homebot {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .homebot-fab {
    pointer-events: auto;
    position: absolute;
    right: 0;
    bottom: 0;
    width: 3.25rem;
    height: 3.25rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    background: linear-gradient(135deg, #2563eb, #7c3aed);
    color: #fff;
    font-size: 1.1rem;
    cursor: pointer;
    box-shadow: 0 12px 30px rgba(37, 99, 235, 0.38);
    display: grid;
    place-items: center;
    z-index: 2;
  }

  .homebot-fab-close {
    display: none;
  }

  .homebot.is-open .homebot-fab-open {
    display: none;
  }

  .homebot.is-open .homebot-fab-close {
    display: inline;
  }

  .homebot-panel {
    pointer-events: auto;
    position: absolute;
    right: 0;
    bottom: 3.9rem;
    width: 100%;
    height: min(32rem, calc(100vh - 10rem));
    border-radius: 1rem;
    border: 1px solid color-mix(in oklab, var(--accent) 35%, transparent);
    background: color-mix(in oklab, var(--background) 86%, #030712 14%);
    box-shadow: 0 22px 60px rgba(15, 23, 42, 0.32);
    backdrop-filter: blur(10px);
    display: grid;
    grid-template-rows: auto 1fr auto auto;
    transform: translateY(12px) scale(0.96);
    transform-origin: bottom right;
    opacity: 0;
    visibility: hidden;
    transition: all 0.22s ease;
    overflow: hidden;
  }

  .homebot.is-open .homebot-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }

  .homebot.is-maximized .homebot-panel {
    right: 0;
    bottom: 0;
    width: min(56rem, calc(100vw - 2rem));
    height: calc(100vh - 1.2rem);
    max-height: none;
    border-radius: 1rem;
  }

  .homebot-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 0.8rem;
    border-bottom: 1px solid color-mix(in oklab, var(--foreground) 14%, transparent);
  }

  .homebot-avatar {
    width: 1.8rem;
    height: 1.8rem;
    border-radius: 999px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.22);
    box-shadow: 0 5px 12px rgba(37, 99, 235, 0.28);
  }

  .homebot-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .homebot-meta {
    min-width: 0;
    flex: 1;
  }

  .homebot-title {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--foreground);
    line-height: 1.2;
  }

  .homebot-status {
    margin: 0.1rem 0 0;
    font-size: 0.65rem;
    color: #22d3ee;
    letter-spacing: 0.06em;
  }

  .homebot-close {
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 0.45rem;
    border: 1px solid color-mix(in oklab, var(--foreground) 18%, transparent);
    background: transparent;
    color: var(--foreground);
    cursor: pointer;
  }

  .homebot-expand {
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 0.45rem;
    border: 1px solid color-mix(in oklab, var(--foreground) 18%, transparent);
    background: transparent;
    color: var(--foreground);
    cursor: pointer;
    font-size: 0.95rem;
    line-height: 1;
  }

  .homebot-messages {
    overflow-y: auto;
    padding: 0.8rem;
    display: grid;
    gap: 0.55rem;
    align-content: start;
  }

  :global(.homebot-msg) {
    display: flex;
    align-items: flex-end;
    gap: 0.45rem;
  }

  :global(.homebot-msg-user) {
    justify-content: flex-end;
  }

  :global(.homebot-msg-avatar) {
    width: 1.35rem;
    height: 1.35rem;
    border-radius: 999px;
    overflow: hidden;
    flex-shrink: 0;
    border: 1px solid color-mix(in oklab, var(--foreground) 18%, transparent);
    box-shadow: 0 3px 10px rgba(37, 99, 235, 0.2);
  }

  :global(.homebot-msg-avatar img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  :global(.homebot-msg-user .homebot-msg-avatar) {
    display: none;
  }

  :global(.homebot-bubble) {
    max-width: 85%;
    padding: 0.55rem 0.7rem;
    border-radius: 0.75rem;
    font-size: 0.8rem;
    line-height: 1.45;
    border: 1px solid color-mix(in oklab, var(--foreground) 14%, transparent);
    background: color-mix(in oklab, var(--background) 82%, transparent);
    color: var(--foreground);
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }

  :global(.homebot-bubble p) {
    margin: 0.38rem 0;
  }

  :global(.homebot-bubble p:first-child) {
    margin-top: 0;
  }

  :global(.homebot-bubble p:last-child) {
    margin-bottom: 0;
  }

  :global(.homebot-bubble ul),
  :global(.homebot-bubble ol) {
    margin: 0.32rem 0 0.32rem 1rem;
    padding: 0;
  }

  :global(.homebot-bubble li) {
    margin: 0.18rem 0;
  }

  :global(.homebot-bubble pre) {
    margin: 0.42rem 0;
    padding: 0.48rem 0.56rem;
    border-radius: 0.55rem;
    background: color-mix(in oklab, #0f172a 80%, var(--background) 20%);
    color: #e2e8f0;
    font-size: 0.74rem;
    overflow-x: auto;
    white-space: pre;
  }

  :global(.homebot-bubble code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 0.75rem;
  }

  :global(.homebot-bubble :not(pre) > code) {
    background: color-mix(in oklab, var(--foreground) 10%, transparent);
    border-radius: 0.34rem;
    padding: 0.08rem 0.3rem;
  }

  :global(.homebot-bubble table) {
    width: 100%;
    border-collapse: collapse;
    margin: 0.45rem 0;
    font-size: 0.74rem;
  }

  :global(.homebot-bubble th),
  :global(.homebot-bubble td) {
    border: 1px solid color-mix(in oklab, var(--foreground) 16%, transparent);
    padding: 0.28rem 0.36rem;
    text-align: left;
    vertical-align: top;
  }

  :global(.homebot-bubble h1),
  :global(.homebot-bubble h2),
  :global(.homebot-bubble h3) {
    margin: 0.45rem 0 0.2rem;
    line-height: 1.3;
    font-weight: 700;
  }

  :global(.homebot-bubble h1) {
    font-size: 0.9rem;
  }

  :global(.homebot-bubble h2) {
    font-size: 0.86rem;
  }

  :global(.homebot-bubble h3) {
    font-size: 0.82rem;
  }

  :global(.homebot-bubble a) {
    color: #60a5fa;
    text-decoration: underline;
  }

  :global(.homebot-msg-user .homebot-bubble) {
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
    border-color: transparent;
    color: #fff;
  }

  .homebot-form {
    display: flex;
    gap: 0.45rem;
    padding: 0.7rem;
    border-top: 1px solid color-mix(in oklab, var(--foreground) 14%, transparent);
  }

  .homebot-input {
    flex: 1;
    min-width: 0;
    border-radius: 0.62rem;
    border: 1px solid color-mix(in oklab, var(--foreground) 16%, transparent);
    background: color-mix(in oklab, var(--background) 80%, transparent);
    color: var(--foreground);
    padding: 0.5rem 0.65rem;
    font-size: 0.78rem;
  }

  .homebot-send {
    border: 0;
    border-radius: 0.62rem;
    padding: 0.48rem 0.74rem;
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
    color: #fff;
    font-size: 0.75rem;
    cursor: pointer;
  }

  .homebot-send:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .homebot-footer {
    margin: 0;
    padding: 0 0.75rem 0.62rem;
    text-align: center;
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    color: color-mix(in oklab, var(--foreground) 54%, transparent);
  }

  @media (max-width: 767px) {
    .homebot-panel {
      right: 0;
      bottom: 3.7rem;
      width: min(100vw - 1rem, 28rem);
      height: min(80vh, calc(100vh - 4.6rem));
    }

    .homebot.is-maximized .homebot-panel {
      right: -0.5rem;
      bottom: -0.5rem;
      width: calc(100vw - 0.2rem);
      height: calc(100vh - 0.2rem);
      border-radius: 0.8rem;
    }
  }
</style>

<script>
  // @ts-nocheck
  const WIDGET_SELECTOR = "[data-homebot]";

  function initHomeBot(root) {
    const host = root;
    if (host.dataset.inited === "1") return;
    host.dataset.inited = "1";

    const api = host.dataset.api || "";
    const metricsEndpoint = host.dataset.metricsEndpoint || "";
    const locale = host.dataset.locale || "zh";

    const fab = host.querySelector("[data-homebot-fab]");
    const panel = host.querySelector("[data-homebot-panel]");
    const expandBtn = host.querySelector("[data-homebot-expand]");
    const closeBtn = host.querySelector("[data-homebot-close]");
    const messagesEl = host.querySelector("[data-homebot-messages]");
    const form = host.querySelector("[data-homebot-form]");
    const input = host.querySelector("[data-homebot-input]");
    const send = host.querySelector("[data-homebot-send]");

    if (!fab || !panel || !expandBtn || !closeBtn || !messagesEl || !form || !input || !send) return;

    const textMap = locale === "en"
      ? {
          thinking: "Thinking",
          error: "Network error",
          empty: "(No response)",
          config: "Chatbot is temporarily unavailable (missing endpoint config).",
          expand: "Expand chatbot",
          collapse: "Restore chatbot size",
        }
      : {
          thinking: "正在思考",
          error: "通信故障",
          empty: "（机器人没有回复）",
          config: "机器人暂时不可用（缺少 endpoint 配置）。",
          expand: "放大聊天窗口",
          collapse: "还原聊天窗口",
        };

    let isOpen = false;
    let isMaximized = false;
    let isPending = false;

    const escapeHtml = inputText =>
      String(inputText)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");

    const renderInlineMarkdown = inlineText => {
      let html = escapeHtml(inlineText);
      html = html.replace(/`([^`]+)`/g, "<code>$1</code>");
      html = html.replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>");
      html = html.replace(/\*([^*]+)\*/g, "<em>$1</em>");
      html = html.replace(/\[([^\]]+)\]\((https?:\/\/[^\s)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>');
      return html;
    };

    const looksLikeSeparator = row => row.every(cell => /^:?-{3,}:?$/.test(cell.trim()));

    const renderMarkdown = markdownText => {
      const src = String(markdownText || "").replace(/\r\n/g, "\n");
      const lines = src.split("\n");
      const out = [];
      let i = 0;

      while (i < lines.length) {
        const line = lines[i];

        if (!line.trim()) {
          i++;
          continue;
        }

        if (line.startsWith("```")) {
          const codeLines = [];
          i++;
          while (i < lines.length && !lines[i].startsWith("```")) {
            codeLines.push(lines[i]);
            i++;
          }
          if (i < lines.length) i++;
          out.push(`<pre><code>${escapeHtml(codeLines.join("\n"))}</code></pre>`);
          continue;
        }

        const tableBuffer = [];
        while (i < lines.length && /\|/.test(lines[i]) && lines[i].trim()) {
          tableBuffer.push(lines[i]);
          i++;
        }
        if (tableBuffer.length >= 2) {
          const tableRows = tableBuffer.map(r => r.split("|").map(c => c.trim()).filter(Boolean));
          if (tableRows.length >= 2 && looksLikeSeparator(tableRows[1])) {
            const header = tableRows[0].map(c => `<th>${renderInlineMarkdown(c)}</th>`).join("");
            const bodyRows = tableRows
              .slice(2)
              .map(row => `<tr>${row.map(c => `<td>${renderInlineMarkdown(c)}</td>`).join("")}</tr>`)
              .join("");
            out.push(`<table><thead><tr>${header}</tr></thead><tbody>${bodyRows}</tbody></table>`);
            continue;
          }
          i -= tableBuffer.length;
        }

        const headingMatch = line.match(/^(#{1,3})\s+(.+)$/);
        if (headingMatch) {
          const level = headingMatch[1].length;
          out.push(`<h${level}>${renderInlineMarkdown(headingMatch[2])}</h${level}>`);
          i++;
          continue;
        }

        if (/^[-*+]\s+/.test(line)) {
          const items = [];
          while (i < lines.length && /^[-*+]\s+/.test(lines[i])) {
            items.push(lines[i].replace(/^[-*+]\s+/, ""));
            i++;
          }
          out.push(`<ul>${items.map(item => `<li>${renderInlineMarkdown(item)}</li>`).join("")}</ul>`);
          continue;
        }

        if (/^\d+\.\s+/.test(line)) {
          const items = [];
          while (i < lines.length && /^\d+\.\s+/.test(lines[i])) {
            items.push(lines[i].replace(/^\d+\.\s+/, ""));
            i++;
          }
          out.push(`<ol>${items.map(item => `<li>${renderInlineMarkdown(item)}</li>`).join("")}</ol>`);
          continue;
        }

        const paragraphLines = [];
        while (
          i < lines.length &&
          lines[i].trim() &&
          !lines[i].startsWith("```") &&
          !/^#{1,3}\s+/.test(lines[i]) &&
          !/^[-*+]\s+/.test(lines[i]) &&
          !/^\d+\.\s+/.test(lines[i])
        ) {
          paragraphLines.push(lines[i]);
          i++;
        }
        const paragraph = paragraphLines.join("<br />");
        out.push(`<p>${renderInlineMarkdown(paragraph)}</p>`);
      }

      return out.join("") || `<p>${textMap.empty}</p>`;
    };

    const emitMetric = (eventName, extra = {}) => {
      const payload = {
        event: eventName,
        locale,
        path: location.pathname,
        ts: Date.now(),
        ...extra,
      };

      try {
        window.dispatchEvent(new CustomEvent("homebot:metric", { detail: payload }));
      } catch {
        // noop
      }

      try {
        if (typeof window.gtag === "function") {
          window.gtag("event", eventName, payload);
        }
      } catch {
        // noop
      }

      try {
        if (typeof window.plausible === "function") {
          window.plausible(`homebot_${eventName}`, { props: payload });
        }
      } catch {
        // noop
      }

      if (!metricsEndpoint) return;

      try {
        const body = JSON.stringify(payload);
        if (navigator.sendBeacon) {
          navigator.sendBeacon(metricsEndpoint, body);
        } else {
          fetch(metricsEndpoint, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body,
            keepalive: true,
          }).catch(() => {
            // noop
          });
        }
      } catch {
        // noop
      }
    };

    const syncState = () => {
      host.classList.toggle("is-open", isOpen);
      host.classList.toggle("is-maximized", isMaximized);
      expandBtn.textContent = isMaximized ? "🗗" : "⛶";
      expandBtn.title = isMaximized ? textMap.collapse : textMap.expand;
      expandBtn.setAttribute("aria-label", isMaximized ? textMap.collapse : textMap.expand);
      input.disabled = isPending;
      send.disabled = isPending;
      if (isOpen) input.focus();
    };

    fab.addEventListener("click", () => {
      isOpen = !isOpen;
      syncState();
      emitMetric(isOpen ? "open" : "close", { source: "fab" });
    });

    closeBtn.addEventListener("click", () => {
      isOpen = false;
      syncState();
      emitMetric("close", { source: "panel_close" });
    });

    expandBtn.addEventListener("click", () => {
      isOpen = true;
      isMaximized = !isMaximized;
      syncState();
      emitMetric(isMaximized ? "expand" : "collapse", { source: "panel_expand" });
    });

    const addBubble = (text, isUser) => {
      const wrap = document.createElement("article");
      wrap.className = `homebot-msg ${isUser ? "homebot-msg-user" : "homebot-msg-assistant"}`;

      if (!isUser) {
        const avatar = document.createElement("span");
        avatar.className = "homebot-msg-avatar";
        avatar.setAttribute("aria-hidden", "true");

        const avatarImg = document.createElement("img");
        avatarImg.src = "/avatar.png";
        avatarImg.alt = "";
        avatarImg.loading = "lazy";
        avatarImg.decoding = "async";

        avatar.appendChild(avatarImg);
        wrap.appendChild(avatar);
      }

      const bubble = document.createElement("div");
      bubble.className = "homebot-bubble";
      if (isUser) {
        bubble.textContent = text;
      } else {
        bubble.innerHTML = renderMarkdown(text);
      }
      wrap.appendChild(bubble);
      messagesEl.appendChild(wrap);
      messagesEl.scrollTop = messagesEl.scrollHeight;
      return wrap;
    };

    form.addEventListener("submit", async e => {
      e.preventDefault();
      if (isPending) return;
      const text = input.value.trim();
      if (!text) return;

      if (!api) {
        addBubble(textMap.config, false);
        emitMetric("config_missing", { has_api: Boolean(api) });
        return;
      }

      input.value = "";
      isPending = true;
      syncState();
      addBubble(text, true);
      const thinkingEl = addBubble(textMap.thinking, false);
      const startedAt = Date.now();
      emitMetric("send", { text_length: text.length });

      try {
        const headers = {
          "Content-Type": "application/json",
        };

        const res = await fetch(api, {
          method: "POST",
          headers,
          body: JSON.stringify({ message: text }),
        });

        let data = null;
        try {
          data = await res.json();
        } catch {
          data = null;
        }

        thinkingEl.remove();

        if (!res.ok) {
          const err = (data && data.error) || `HTTP ${res.status}`;
          addBubble(String(err), false);
          emitMetric("error", {
            status: res.status,
            latency_ms: Date.now() - startedAt,
            kind: "http",
          });
          return;
        }

        const reply =
          (data && data.choices && data.choices[0] && data.choices[0].message && data.choices[0].message.content) ||
          (data && data.error) ||
          textMap.empty;
        addBubble(String(reply), false);
        emitMetric("success", {
          latency_ms: Date.now() - startedAt,
          reply_length: String(reply).length,
        });
      } catch (err) {
        thinkingEl.remove();
        addBubble(`${textMap.error}: ${(err && err.message) || "unknown"}`, false);
        emitMetric("error", {
          latency_ms: Date.now() - startedAt,
          kind: "network",
        });
      } finally {
        isPending = false;
        syncState();
      }
    });
  }

  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll(WIDGET_SELECTOR).forEach(initHomeBot);
  });
</script>
