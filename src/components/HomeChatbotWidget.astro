---
interface Props {
  locale?: "zh" | "en";
}

const { locale = "zh" } = Astro.props as Props;
const chatbotApi = import.meta.env.PUBLIC_CHATBOT_API_ENDPOINT || "";
const chatbotMetricsEndpoint = import.meta.env.PUBLIC_CHATBOT_METRICS_ENDPOINT || "";

const copy = locale === "en"
  ? {
      title: "Claw Bot",
      status: "ONLINE",
      welcome: "Hi, I am your site bot. Ask me anything about this blog.",
      placeholder: "Type your message...",
      thinking: "Thinking",
      send: "Send",
      open: "Open chatbot",
      close: "Close chatbot",
      error: "Network error",
      empty: "(No response)",
      footer: "POWERED BY OPENCLAW",
    }
  : {
      title: "鼓掌 · 机器人",
      status: "在线",
      welcome: "嘿！我是站点机器人，欢迎随便聊聊。",
      placeholder: "说点什么...",
      thinking: "正在思考",
      send: "发送",
      open: "打开聊天机器人",
      close: "关闭聊天机器人",
      error: "通信故障",
      empty: "（机器人没有回复）",
      footer: "POWERED BY OPENCLAW",
    };
---

<div
  class="homebot"
  data-homebot
  data-api={chatbotApi}
  data-metrics-endpoint={chatbotMetricsEndpoint}
  data-locale={locale}
>
  <button type="button" class="homebot-fab" data-homebot-fab aria-label={copy.open} title={copy.open}>
    <span class="homebot-fab-open">💬</span>
    <span class="homebot-fab-close" aria-hidden="true">✕</span>
  </button>

  <section class="homebot-panel" data-homebot-panel aria-label={copy.title}>
    <header class="homebot-head">
      <div class="homebot-avatar">
        <img src="/avatar.png" alt={copy.title} loading="lazy" decoding="async" />
      </div>
      <div class="homebot-meta">
        <p class="homebot-title">{copy.title}</p>
        <p class="homebot-status">{copy.status}</p>
      </div>
      <button
        type="button"
        class="homebot-close"
        data-homebot-close
        aria-label={copy.close}
        title={copy.close}
      >
        ✕
      </button>
    </header>

    <div class="homebot-messages" data-homebot-messages>
      <article class="homebot-msg homebot-msg-assistant">
        <span class="homebot-msg-avatar" aria-hidden="true">
          <img src="/avatar.png" alt="" loading="lazy" decoding="async" />
        </span>
        <div class="homebot-bubble">{copy.welcome}</div>
      </article>
    </div>

    <form class="homebot-form" data-homebot-form>
      <input
        class="homebot-input"
        data-homebot-input
        type="text"
        placeholder={copy.placeholder}
        autocomplete="off"
      />
      <button class="homebot-send" data-homebot-send type="submit">{copy.send}</button>
    </form>

    <p class="homebot-footer">{copy.footer}</p>
  </section>
</div>

<style>
  .homebot {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .homebot-fab {
    pointer-events: auto;
    position: absolute;
    right: 0;
    bottom: 0;
    width: 3.25rem;
    height: 3.25rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    background: linear-gradient(135deg, #2563eb, #7c3aed);
    color: #fff;
    font-size: 1.1rem;
    cursor: pointer;
    box-shadow: 0 12px 30px rgba(37, 99, 235, 0.38);
    display: grid;
    place-items: center;
    z-index: 2;
  }

  .homebot-fab-close {
    display: none;
  }

  .homebot.is-open .homebot-fab-open {
    display: none;
  }

  .homebot.is-open .homebot-fab-close {
    display: inline;
  }

  .homebot-panel {
    pointer-events: auto;
    position: absolute;
    right: 0;
    bottom: 3.9rem;
    width: 100%;
    height: min(32rem, calc(100vh - 10rem));
    border-radius: 1rem;
    border: 1px solid color-mix(in oklab, var(--accent) 35%, transparent);
    background: color-mix(in oklab, var(--background) 86%, #030712 14%);
    box-shadow: 0 22px 60px rgba(15, 23, 42, 0.32);
    backdrop-filter: blur(10px);
    display: grid;
    grid-template-rows: auto 1fr auto auto;
    transform: translateY(12px) scale(0.96);
    transform-origin: bottom right;
    opacity: 0;
    visibility: hidden;
    transition: all 0.22s ease;
    overflow: hidden;
  }

  .homebot.is-open .homebot-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }

  .homebot-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 0.8rem;
    border-bottom: 1px solid color-mix(in oklab, var(--foreground) 14%, transparent);
  }

  .homebot-avatar {
    width: 1.8rem;
    height: 1.8rem;
    border-radius: 999px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.22);
    box-shadow: 0 5px 12px rgba(37, 99, 235, 0.28);
  }

  .homebot-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .homebot-meta {
    min-width: 0;
    flex: 1;
  }

  .homebot-title {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--foreground);
    line-height: 1.2;
  }

  .homebot-status {
    margin: 0.1rem 0 0;
    font-size: 0.65rem;
    color: #22d3ee;
    letter-spacing: 0.06em;
  }

  .homebot-close {
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 0.45rem;
    border: 1px solid color-mix(in oklab, var(--foreground) 18%, transparent);
    background: transparent;
    color: var(--foreground);
    cursor: pointer;
  }

  .homebot-messages {
    overflow-y: auto;
    padding: 0.8rem;
    display: grid;
    gap: 0.55rem;
    align-content: start;
  }

  :global(.homebot-msg) {
    display: flex;
    align-items: flex-end;
    gap: 0.45rem;
  }

  :global(.homebot-msg-user) {
    justify-content: flex-end;
  }

  :global(.homebot-msg-avatar) {
    width: 1.35rem;
    height: 1.35rem;
    border-radius: 999px;
    overflow: hidden;
    flex-shrink: 0;
    border: 1px solid color-mix(in oklab, var(--foreground) 18%, transparent);
    box-shadow: 0 3px 10px rgba(37, 99, 235, 0.2);
  }

  :global(.homebot-msg-avatar img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  :global(.homebot-msg-user .homebot-msg-avatar) {
    display: none;
  }

  :global(.homebot-bubble) {
    max-width: 85%;
    padding: 0.55rem 0.7rem;
    border-radius: 0.75rem;
    font-size: 0.8rem;
    line-height: 1.45;
    border: 1px solid color-mix(in oklab, var(--foreground) 14%, transparent);
    background: color-mix(in oklab, var(--background) 82%, transparent);
    color: var(--foreground);
    white-space: pre-wrap;
  }

  :global(.homebot-msg-user .homebot-bubble) {
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
    border-color: transparent;
    color: #fff;
  }

  .homebot-form {
    display: flex;
    gap: 0.45rem;
    padding: 0.7rem;
    border-top: 1px solid color-mix(in oklab, var(--foreground) 14%, transparent);
  }

  .homebot-input {
    flex: 1;
    min-width: 0;
    border-radius: 0.62rem;
    border: 1px solid color-mix(in oklab, var(--foreground) 16%, transparent);
    background: color-mix(in oklab, var(--background) 80%, transparent);
    color: var(--foreground);
    padding: 0.5rem 0.65rem;
    font-size: 0.78rem;
  }

  .homebot-send {
    border: 0;
    border-radius: 0.62rem;
    padding: 0.48rem 0.74rem;
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
    color: #fff;
    font-size: 0.75rem;
    cursor: pointer;
  }

  .homebot-send:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .homebot-footer {
    margin: 0;
    padding: 0 0.75rem 0.62rem;
    text-align: center;
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    color: color-mix(in oklab, var(--foreground) 54%, transparent);
  }
</style>

<script>
  // @ts-nocheck
  const WIDGET_SELECTOR = "[data-homebot]";

  function initHomeBot(root) {
    const host = root;
    if (host.dataset.inited === "1") return;
    host.dataset.inited = "1";

    const api = host.dataset.api || "";
    const metricsEndpoint = host.dataset.metricsEndpoint || "";
    const locale = host.dataset.locale || "zh";

    const fab = host.querySelector("[data-homebot-fab]");
    const panel = host.querySelector("[data-homebot-panel]");
    const closeBtn = host.querySelector("[data-homebot-close]");
    const messagesEl = host.querySelector("[data-homebot-messages]");
    const form = host.querySelector("[data-homebot-form]");
    const input = host.querySelector("[data-homebot-input]");
    const send = host.querySelector("[data-homebot-send]");

    if (!fab || !panel || !closeBtn || !messagesEl || !form || !input || !send) return;

    const textMap = locale === "en"
      ? {
          thinking: "Thinking",
          error: "Network error",
          empty: "(No response)",
          config: "Chatbot is temporarily unavailable (missing endpoint config).",
        }
      : {
          thinking: "正在思考",
          error: "通信故障",
          empty: "（机器人没有回复）",
          config: "机器人暂时不可用（缺少 endpoint 配置）。",
        };

    let isOpen = false;

    const emitMetric = (eventName, extra = {}) => {
      const payload = {
        event: eventName,
        locale,
        path: location.pathname,
        ts: Date.now(),
        ...extra,
      };

      try {
        window.dispatchEvent(new CustomEvent("homebot:metric", { detail: payload }));
      } catch {
        // noop
      }

      try {
        if (typeof window.gtag === "function") {
          window.gtag("event", eventName, payload);
        }
      } catch {
        // noop
      }

      try {
        if (typeof window.plausible === "function") {
          window.plausible(`homebot_${eventName}`, { props: payload });
        }
      } catch {
        // noop
      }

      if (!metricsEndpoint) return;

      try {
        const body = JSON.stringify(payload);
        if (navigator.sendBeacon) {
          navigator.sendBeacon(metricsEndpoint, body);
        } else {
          fetch(metricsEndpoint, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body,
            keepalive: true,
          }).catch(() => {
            // noop
          });
        }
      } catch {
        // noop
      }
    };

    const syncState = () => {
      host.classList.toggle("is-open", isOpen);
      if (isOpen) input.focus();
    };

    fab.addEventListener("click", () => {
      isOpen = !isOpen;
      syncState();
      emitMetric(isOpen ? "open" : "close", { source: "fab" });
    });

    closeBtn.addEventListener("click", () => {
      isOpen = false;
      syncState();
      emitMetric("close", { source: "panel_close" });
    });

    const addBubble = (text, isUser) => {
      const wrap = document.createElement("article");
      wrap.className = `homebot-msg ${isUser ? "homebot-msg-user" : "homebot-msg-assistant"}`;

      if (!isUser) {
        const avatar = document.createElement("span");
        avatar.className = "homebot-msg-avatar";
        avatar.setAttribute("aria-hidden", "true");

        const avatarImg = document.createElement("img");
        avatarImg.src = "/avatar.png";
        avatarImg.alt = "";
        avatarImg.loading = "lazy";
        avatarImg.decoding = "async";

        avatar.appendChild(avatarImg);
        wrap.appendChild(avatar);
      }

      const bubble = document.createElement("div");
      bubble.className = "homebot-bubble";
      bubble.textContent = text;
      wrap.appendChild(bubble);
      messagesEl.appendChild(wrap);
      messagesEl.scrollTop = messagesEl.scrollHeight;
      return wrap;
    };

    form.addEventListener("submit", async e => {
      e.preventDefault();
      const text = input.value.trim();
      if (!text) return;

      if (!api) {
        addBubble(textMap.config, false);
        emitMetric("config_missing", { has_api: Boolean(api) });
        return;
      }

      input.value = "";
      send.disabled = true;
      addBubble(text, true);
      const thinkingEl = addBubble(textMap.thinking, false);
      const startedAt = Date.now();
      emitMetric("send", { text_length: text.length });

      try {
        const headers = {
          "Content-Type": "application/json",
        };

        const res = await fetch(api, {
          method: "POST",
          headers,
          body: JSON.stringify({ message: text }),
        });

        let data = null;
        try {
          data = await res.json();
        } catch {
          data = null;
        }

        thinkingEl.remove();

        if (!res.ok) {
          const err = (data && data.error) || `HTTP ${res.status}`;
          addBubble(String(err), false);
          emitMetric("error", {
            status: res.status,
            latency_ms: Date.now() - startedAt,
            kind: "http",
          });
          return;
        }

        const reply =
          (data && data.choices && data.choices[0] && data.choices[0].message && data.choices[0].message.content) ||
          (data && data.error) ||
          textMap.empty;
        addBubble(String(reply), false);
        emitMetric("success", {
          latency_ms: Date.now() - startedAt,
          reply_length: String(reply).length,
        });
      } catch (err) {
        thinkingEl.remove();
        addBubble(`${textMap.error}: ${(err && err.message) || "unknown"}`, false);
        emitMetric("error", {
          latency_ms: Date.now() - startedAt,
          kind: "network",
        });
      } finally {
        send.disabled = false;
      }
    });
  }

  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll(WIDGET_SELECTOR).forEach(initHomeBot);
  });
</script>
