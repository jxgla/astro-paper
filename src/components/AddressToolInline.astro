---
interface Props {
  locale?: "zh" | "en";
}

const { locale = "zh" } = Astro.props as Props;

const copy = locale === "en"
  ? {
      title: "Address / Mock Identity Generator",
      desc: "Client-side only. Reads bundled JSON from this Astro site and writes the generated profile directly into the output area below.",
      country: "Region",
      mode: "Profile style",
      count: "Count",
      format: "Output",
      button: "Generate",
      copy: "Copy",
      download: "Download JSON",
      card: "Cards",
      json: "JSON",
      balanced: "Balanced",
      asia: "Asia-leaning",
      western: "Western-leaning",
      idle: "Pick a region and generate. Data is loaded from `/data/*.json` shipped with the blog build.",
      loading: "Generating...",
      done: (count: number, country: string) => `Generated ${count} ${country} profile(s) locally in the browser.`,
      copied: (count: number) => `Copied ${count} generated profile(s).`,
      error: "Failed to load bundled JSON data. Make sure `public/data/` is deployed with the site.",
      name: "Name",
      address: "Address",
      email: "Email",
      phone: "Phone",
      birth: "Birth date",
    }
  : {
      title: "地址 / 虚拟身份生成器",
      desc: "纯前端运行。直接读取当前 Astro 站点打包出去的 JSON，并把生成结果写进下面输出框。",
      country: "地区",
      mode: "身份风格",
      count: "数量",
      format: "输出格式",
      button: "生成",
      copy: "复制",
      download: "下载 JSON",
      card: "卡片",
      json: "JSON",
      balanced: "均衡随机",
      asia: "偏亚洲",
      western: "偏欧美",
      idle: "选择地区后即可生成。数据来自站点构建时一起发布的 `/data/*.json`。",
      loading: "生成中...",
      done: (count: number, country: string) => `已在浏览器本地生成 ${count} 条 ${country} 数据。`,
      copied: (count: number) => `已复制 ${count} 条生成结果。`,
      error: "读取站点内置 JSON 失败，请确认 `public/data/` 已随站点一同部署。",
      name: "姓名",
      address: "地址",
      email: "邮箱",
      phone: "电话",
      birth: "生日",
    };
---

<div class="address-inline" data-address-inline data-locale={locale}>
  <div class="address-inline-head">
    <div>
      <h3>{copy.title}</h3>
      <p>{copy.desc}</p>
    </div>
  </div>

  <form class="address-inline-form" data-address-form>
    <label>
      <span>{copy.country}</span>
      <select class="tool-input" data-address-country>
        <option value="US">United States</option>
        <option value="CN">中国</option>
        <option value="JP">日本</option>
        <option value="HK">香港</option>
        <option value="TW">台湾</option>
        <option value="GB">United Kingdom</option>
        <option value="DE">Deutschland</option>
        <option value="CA">Canada</option>
        <option value="AU">Australia</option>
        <option value="SG">Singapore</option>
      </select>
    </label>

    <label>
      <span>{copy.mode}</span>
      <select class="tool-input" data-address-mode>
        <option value="balanced">{copy.balanced}</option>
        <option value="asia">{copy.asia}</option>
        <option value="western">{copy.western}</option>
      </select>
    </label>

    <label>
      <span>{copy.count}</span>
      <input class="tool-input" data-address-count type="number" min="1" max="8" step="1" value="1" />
    </label>

    <label>
      <span>{copy.format}</span>
      <select class="tool-input" data-address-format>
        <option value="card">{copy.card}</option>
        <option value="json">{copy.json}</option>
      </select>
    </label>

    <div class="tool-actions">
      <button type="submit" class="tool-btn-primary" data-address-generate>{copy.button}</button>
      <button type="button" class="tool-btn-secondary" data-address-copy disabled>{copy.copy}</button>
      <button type="button" class="tool-btn-secondary" data-address-download disabled>{copy.download}</button>
    </div>

    <p class="tool-status" data-address-status>{copy.idle}</p>
  </form>

  <div class="tool-result-wrap address-inline-result-wrap" data-address-result-wrap>
    <div class="address-inline-cards" data-address-cards></div>
    <pre class="tool-result address-inline-json" data-address-json hidden></pre>
  </div>
</div>

<style>
  .address-inline {
    display: grid;
    gap: 1rem;
  }

  .address-inline-head h3 {
    margin: 0;
    font-size: 1.05rem;
  }

  .address-inline-head p {
    margin: 0.35rem 0 0;
    color: color-mix(in oklab, var(--foreground) 72%, transparent);
    line-height: 1.65;
    font-size: 0.9rem;
  }

  .address-inline-form {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 0.9rem;
    align-items: end;
  }

  .address-inline-form > label {
    display: grid;
    gap: 0.38rem;
  }

  .address-inline-form > label > span {
    font-size: 0.82rem;
    font-weight: 600;
  }

  .address-inline-result-wrap {
    display: grid;
    gap: 0.8rem;
  }

  .address-inline-cards {
    display: grid;
    gap: 0.75rem;
  }

  .address-inline-card {
    border: 1px solid color-mix(in oklab, var(--foreground) 14%, transparent);
    border-radius: 0.95rem;
    padding: 0.9rem;
    background: color-mix(in oklab, var(--background) 95%, transparent);
  }

  .address-inline-card strong {
    display: block;
    margin-bottom: 0.55rem;
    font-size: 0.95rem;
  }

  .address-inline-line {
    margin: 0.35rem 0;
    white-space: pre-wrap;
    line-height: 1.65;
    color: color-mix(in oklab, var(--foreground) 82%, transparent);
  }

  .address-inline-json {
    margin: 0;
    max-height: 24rem;
    overflow: auto;
  }
</style>

<script>
  const DATA_FILES = {
    US: "/data/usData.json",
    CN: "/data/cnData.json",
    JP: "/data/jpData.json",
    HK: "/data/hkData.json",
    TW: "/data/twData.json",
    GB: "/data/gbData.json",
    DE: "/data/deData.json",
    CA: "/data/caData.json",
    AU: "/data/auData.json",
    SG: "/data/sgData.json",
  };

  const COUNTRY_META = {
    US: { locale: "en", dialing: "+1" },
    CN: { locale: "zh", dialing: "+86" },
    JP: { locale: "ja", dialing: "+81" },
    HK: { locale: "zh", dialing: "+852" },
    TW: { locale: "zh", dialing: "+886" },
    GB: { locale: "en", dialing: "+44" },
    DE: { locale: "en", dialing: "+49" },
    CA: { locale: "en", dialing: "+1" },
    AU: { locale: "en", dialing: "+61" },
    SG: { locale: "en", dialing: "+65" },
  };

  const cache = new Map();

  function randomItem(items) {
    if (!Array.isArray(items) || items.length === 0) return "";
    return items[Math.floor(Math.random() * items.length)];
  }

  function randomInt(min, max) {
    return Math.floor(Math.random() * (max - min + 1)) + min;
  }

  function pad(value, length = 2) {
    return String(value).padStart(length, "0");
  }

  async function loadJson(path) {
    if (cache.has(path)) return cache.get(path);
    const response = await fetch(path);
    if (!response.ok) throw new Error(`Failed to load ${path}`);
    const data = await response.json();
    cache.set(path, data);
    return data;
  }

  function normalizeRegions(rawData) {
    if (Array.isArray(rawData)) {
      return rawData.map((entry, index) => ({
        label: entry.state || entry.province || entry.region || entry.city || `Region ${index + 1}`,
        cities: entry.cities || entry.districts || entry.areas || [],
      }));
    }

    return Object.values(rawData).map(value => ({
      label: value.state || value.province || value.region || value.city || "Unknown",
      cities: value.cities || value.districts || value.areas || [],
    }));
  }

  function buildBirthDate() {
    return `${randomInt(1980, 2004)}-${pad(randomInt(1, 12))}-${pad(randomInt(1, 28))}`;
  }

  function buildEmail(name) {
    const base = name.toLowerCase().replace(/[^a-z0-9\u4e00-\u9fa5\u3040-\u30ff]+/gi, "").slice(0, 14) || "user";
    return `${base}${randomInt(11, 999)}@${randomItem(["gmail.com", "outlook.com", "proton.me", "icloud.com"])}`;
  }

  function buildPhone(country) {
    const prefix = COUNTRY_META[country]?.dialing || "+00";
    return `${prefix} ${randomInt(100, 999)} ${randomInt(1000, 9999)} ${randomInt(1000, 9999)}`;
  }

  function buildStreet(locale, streetTypesData) {
    const base = ["Oak", "Pine", "Maple", "River", "Cedar", "朝阳", "和平", "中山", "若葉", "桜", "青葉"];
    const suffixes = streetTypesData?.[locale] || streetTypesData?.en || ["Street"];
    return `${randomInt(11, 9879)} ${randomItem(base)}${locale === "zh" || locale === "ja" ? "" : " "}${randomItem(suffixes)}`;
  }

  function buildName(namesData, mode, locale) {
    const male = namesData.firstName_male || [];
    const female = namesData.firstName_female || [];
    const last = namesData.lastName || namesData.last_name || [];
    const firstPool = Math.random() > 0.48 ? male : female;
    const asiaHint = /[一-龥ぁ-んァ-ヶ]/;
    const westernHint = /[A-Za-z]/;
    const filterByMode = list => {
      if (mode === "asia") return list.filter(item => asiaHint.test(item));
      if (mode === "western") return list.filter(item => westernHint.test(item));
      return list;
    };
    const firstName = randomItem(filterByMode(firstPool).length ? filterByMode(firstPool) : firstPool) || "Alex";
    const lastName = randomItem(filterByMode(last).length ? filterByMode(last) : last) || "Taylor";
    return locale === "zh" || locale === "ja" ? `${lastName}${firstName}` : `${firstName} ${lastName}`;
  }

  function copyText(text) {
    return navigator.clipboard.writeText(text);
  }

  function downloadJson(payload) {
    const blob = new Blob([JSON.stringify(payload, null, 2)], { type: "application/json" });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.href = url;
    link.download = `address-inline-${Date.now()}.json`;
    link.click();
    URL.revokeObjectURL(url);
  }

  function initAddressInline(root) {
    if (!root || root.dataset.ready === "true") return;
    root.dataset.ready = "true";

    const locale = root.dataset.locale || "zh";
    const isEn = locale === "en";
    const labels = isEn
      ? { name: "Name", address: "Address", email: "Email", phone: "Phone", birth: "Birth date", loading: "Generating...", error: "Failed to load bundled JSON data. Make sure `public/data/` is deployed with the site.", copied: count => `Copied ${count} generated profile(s).`, done: (count, country) => `Generated ${count} ${country} profile(s) locally in the browser.` }
      : { name: "姓名", address: "地址", email: "邮箱", phone: "电话", birth: "生日", loading: "生成中...", error: "读取站点内置 JSON 失败，请确认 `public/data/` 已随站点一同部署。", copied: count => `已复制 ${count} 条生成结果。`, done: (count, country) => `已在浏览器本地生成 ${count} 条 ${country} 数据。` };

    const form = root.querySelector("[data-address-form]");
    const countryEl = root.querySelector("[data-address-country]");
    const modeEl = root.querySelector("[data-address-mode]");
    const countEl = root.querySelector("[data-address-count]");
    const formatEl = root.querySelector("[data-address-format]");
    const statusEl = root.querySelector("[data-address-status]");
    const cardsEl = root.querySelector("[data-address-cards]");
    const jsonEl = root.querySelector("[data-address-json]");
    const copyBtn = root.querySelector("[data-address-copy]");
    const downloadBtn = root.querySelector("[data-address-download]");
    let lastGenerated = [];

    form?.addEventListener("submit", async event => {
      event.preventDefault();
      statusEl.textContent = labels.loading;

      try {
        const [regionData, namesData, streetTypesData] = await Promise.all([
          loadJson(DATA_FILES[countryEl.value]),
          loadJson("/data/namesData.json"),
          loadJson("/data/streetTypesData.json"),
        ]);

        const localeKey = COUNTRY_META[countryEl.value]?.locale || "en";
        const regions = normalizeRegions(regionData);
        const count = Math.max(1, Math.min(8, Number(countEl.value) || 1));

        lastGenerated = Array.from({ length: count }, () => {
          const region = randomItem(regions);
          const city = randomItem(region?.cities || []) || region?.label || "Unknown";
          const name = buildName(namesData, modeEl.value, localeKey);
          const street = buildStreet(localeKey, streetTypesData);
          const postalCode = `${randomInt(10000, 999999)}`;
          return {
            country: countryEl.value,
            name,
            address: `${street}, ${city}, ${region?.label || "Unknown"}, ${countryEl.value} ${postalCode}`,
            email: buildEmail(name),
            phone: buildPhone(countryEl.value),
            birthDate: buildBirthDate(),
          };
        });

        if (formatEl.value === "json") {
          cardsEl.innerHTML = "";
          jsonEl.hidden = false;
          jsonEl.textContent = JSON.stringify(lastGenerated, null, 2);
        } else {
          jsonEl.hidden = true;
          cardsEl.innerHTML = lastGenerated.map(item => `
            <article class="address-inline-card">
              <strong>${item.name}</strong>
              <p class="address-inline-line"><b>${labels.address}:</b> ${item.address}</p>
              <p class="address-inline-line"><b>${labels.email}:</b> ${item.email}</p>
              <p class="address-inline-line"><b>${labels.phone}:</b> ${item.phone}</p>
              <p class="address-inline-line"><b>${labels.birth}:</b> ${item.birthDate}</p>
            </article>
          `).join("");
        }

        copyBtn.disabled = false;
        downloadBtn.disabled = false;
        statusEl.textContent = labels.done(lastGenerated.length, countryEl.value);
      } catch (error) {
        console.error(error);
        statusEl.textContent = labels.error;
      }
    });

    copyBtn?.addEventListener("click", async () => {
      if (!lastGenerated.length) return;
      const text = formatEl.value === "json"
        ? JSON.stringify(lastGenerated, null, 2)
        : lastGenerated.map(item => `${item.name}\n${item.address}\n${item.email}\n${item.phone}`).join("\n\n");
      await copyText(text);
      statusEl.textContent = labels.copied(lastGenerated.length);
    });

    downloadBtn?.addEventListener("click", () => {
      if (!lastGenerated.length) return;
      downloadJson(lastGenerated);
    });
  }

  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll("[data-address-inline]").forEach(initAddressInline);
  });

  document.querySelectorAll("[data-address-inline]").forEach(initAddressInline);
</script>