---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";
import { TOOL_NAV_SECTIONS } from "@/data/tools-nav";

const { pathname } = Astro.url;

// Remove trailing slash from current pathname if exists
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isEn = currentPath === "/en" || currentPath.startsWith("/en/");
const langSwitchHref = isEn
  ? (currentPath === "/en" ? "/" : currentPath.replace(/^\/en/, ""))
  : `/en${currentPath === "/" ? "" : currentPath}`;
const langSwitchLabel = isEn ? "CN" : "EN";
const chatNavLabel = isEn ? "🤖 Chat" : "🤖 AI Chat";

const EN_LOCALIZED_PATHS = new Set(["/", "/chat", "/posts", "/tools", "/fun"]);
const brandTitleDesktop = isEn ? "VibeWatcher" : SITE.title;
const brandTitleMobile = isEn ? "VibeWatcher" : "观者终端";

const withLocale = (path: string) => {
  if (!path.startsWith("/")) return path;
  if (!isEn) return path;
  if (!EN_LOCALIZED_PATHS.has(path)) return path;
  return path === "/" ? "/en" : `/en${path}`;
};

const isActive = (path: string) => {
  const localizedPath = withLocale(path);
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = localizedPath.split("/").filter(p => p.trim());

  return currentPath === localizedPath || currentPathArray[0] === pathArray[0];
};

const isToolsRoute = currentPath === withLocale("/tools");
const isFunRoute = currentPath === withLocale("/fun");
const isEnHome = currentPath === "/en";
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
>
  Skip to content
</a>

<!-- SEO-only header (visually hidden, indexable) -->
<header class="sr-only" aria-label={isEn ? "Site quick links" : "站点快捷入口"}>
  <h1>
    {isEn
      ? "Free AI Chat, Tools & Fun — Cloudflare edge gateway"
      : "免费 AI Chat / Tools / Fun — Cloudflare 边缘网关"}
  </h1>
  <p>
    {isEn
      ? "No login. Streaming chat. Internal tools and image fun pages."
      : "免登录 · 流式聊天 · 工具集合 · 趣味页面（含图片瀑布流）"}
  </p>
  <nav aria-label={isEn ? "Primary pages" : "主要页面"}>
    <ul>
      <li><a href={withLocale("/chat")}>{isEn ? "AI Chat" : "AI Chat"}</a></li>
      <li><a href={withLocale("/tools")}>{isEn ? "Tools" : "Tools"}</a></li>
      <li><a href={withLocale("/fun")}>{isEn ? "Fun" : "Fun"}</a></li>
    </ul>
  </nav>
</header>

<header
  class="app-layout flex flex-col items-center justify-between sm:flex-row"
>
  <div
    id="top-nav-wrap"
    class:list={[
      "py-4 sm:py-6",
      "border-b border-border",
      "relative w-full bg-background",
      "flex items-center justify-between",
    ]}
  >
    <a
      href={withLocale("/")}
      class="max-w-[74vw] truncate py-1 pe-2 text-xl leading-tight font-semibold whitespace-nowrap sm:max-w-none sm:pe-0 sm:text-2xl sm:leading-none"
    >
      <span class="sm:hidden">{brandTitleMobile}</span>
      <span class="hidden sm:inline">{brandTitleDesktop}</span>
    </a>
    <nav
      id="nav-menu"
      class="relative flex flex-col items-end sm:ms-2 sm:flex-row sm:items-center sm:justify-end sm:space-x-4 sm:py-0"
    >
      <button
        id="menu-btn"
        class="focus-outline self-end p-2 sm:hidden"
        aria-label="Open Menu"
        aria-expanded="false"
        aria-controls="menu-items"
      >
        <IconX id="close-icon" class="hidden" />
        <IconMenuDeep id="menu-icon" />
      </button>
      <ul
        id="menu-items"
        class:list={[
          "mt-4 flex w-[min(22rem,calc(100vw-2rem))] flex-col gap-2 self-stretch rounded-2xl border border-border bg-background/98 p-2 shadow-lg",
          "[&>li>a]:block [&>li>a]:rounded-xl [&>li>a]:px-4 [&>li>a]:py-3 [&>li>a]:text-center [&>li>a]:font-medium [&>li>a]:hover:text-accent [&>li>a]:whitespace-nowrap sm:[&>li>a]:px-2 sm:[&>li>a]:py-1",
          "hidden",
          "sm:mt-0 sm:flex sm:w-auto sm:flex-row sm:gap-x-5 sm:gap-y-0 sm:self-auto sm:rounded-none sm:border-0 sm:bg-transparent sm:p-0 sm:shadow-none",
        ]}
      >
        <li class="col-span-2">
          <a
            href={withLocale("/chat")}
            class:list={[{ "active-nav": isActive("/chat") }]}
            style="font-weight: 600;"
          >
            {chatNavLabel}
          </a>
        </li>
        <li class="col-span-2">
          <a href={withLocale("/posts")} class:list={{ "active-nav": isActive("/posts") }}>
            {isEn ? "Posts" : "Posts"}
          </a>
        </li>
        <li class="col-span-2">
          <a href={withLocale("/fun")} class:list={{ "active-nav": isFunRoute || isActive("/fun") }}>
            {isEn ? "Fun" : "Fun"}
          </a>
        </li>
        <li id="tools-nav-item" class="col-span-2 sm:relative">
          <button
            type="button"
            id="tools-menu-trigger"
            class:list={[
              "w-full cursor-pointer rounded-xl border border-border bg-background/90 px-4 py-3 text-center font-medium whitespace-nowrap hover:text-accent sm:border-0 sm:bg-transparent sm:px-2 sm:py-1",
              { "active-nav": isToolsRoute },
            ]}
            aria-haspopup="true"
            aria-expanded="false"
          >
            {isEn ? "Tools" : "Tools"}
          </button>

          <div
            id="tools-dropdown"
            class="tools-dropdown sm:absolute sm:top-full sm:left-1/2 sm:z-40 sm:mt-2 sm:w-[30rem] sm:-translate-x-1/2 sm:rounded-xl sm:border sm:border-border sm:bg-background sm:p-3 sm:shadow-lg"
          >
            <div class="grid gap-3 sm:grid-cols-3">
              {TOOL_NAV_SECTIONS.map(section => (
                <section class="rounded-lg border border-border/70 p-3">
                  <h3 class="mb-2 text-sm font-semibold">{isEn ? section.title.en : section.title.zh}</h3>
                  {section.items.map(item => (
                    <a class="tools-link" href={withLocale(item.href)}>{isEn ? item.label.en : item.label.zh}</a>
                  ))}
                </section>
              ))}
            </div>
          </div>
        </li>
        <li class="col-span-2">
          <a href={withLocale("/about")} class:list={{ "active-nav": isActive("/about") }}>
            {isEn ? "About" : "About"}
          </a>
        </li>
        {
          SITE.showArchives && (
            <li class="col-span-2">
              <LinkButton
                href={withLocale("/archives")}
                class:list={[
                  "focus-outline flex justify-center p-3 sm:p-1",
                  {
                    "active-nav [&>svg]:stroke-accent": isActive("/archives"),
                  },
                ]}
                title="Archives"
                aria-label="archives"
              >
                <IconArchive class="hidden sm:inline-block" />
                <span class="sm:sr-only">Archives</span>
              </LinkButton>
            </li>
          )
        }
        <li class="col-span-1 flex items-center justify-center">
          <a
            href={langSwitchHref}
            class="focus-outline rounded-full border border-border px-3 py-2 text-xs font-semibold tracking-wide transition hover:border-accent hover:text-accent"
            title={isEn ? "切换到中文" : "Switch to English"}
            aria-label={isEn ? "switch-to-chinese" : "switch-to-english"}
          >
            {langSwitchLabel}
          </a>
        </li>
        <li class="col-span-1 flex items-center justify-center">
          <LinkButton
            href={withLocale("/search")}
            class:list={[
              "focus-outline flex p-3 sm:p-1",
              { "[&>svg]:stroke-accent": isActive("/search") },
            ]}
            title="Search"
            aria-label="search"
          >
            <IconSearch />
            <span class="sr-only">Search</span>
          </LinkButton>
        </li>
        {
          SITE.lightAndDarkMode && (
            <li class="col-span-1 flex items-center justify-center gap-1.5">
              <button
                id="theme-btn"
                class="focus-outline relative size-12 p-4 sm:size-8 hover:[&>svg]:stroke-accent"
                title="Toggles light & dark"
                aria-label="auto"
                aria-live="polite"
              >
                <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
              </button>
              {
                isEnHome && (
                  <button
                    type="button"
                    id="secret-entry-trigger"
                    class="secret-entry-trigger"
                    aria-hidden="true"
                    tabindex="-1"
                    title=""
                  >
                    ·
                  </button>
                )
              }
            </li>
          )
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .tools-dropdown {
    display: none;
  }

  #tools-nav-item[data-open="true"] #tools-dropdown {
    display: block;
  }

  .tools-link {
    display: block;
    padding: 0.42rem 0;
    font-size: 0.86rem;
    line-height: 1.4;
    color: color-mix(in oklab, var(--foreground) 88%, transparent);
  }

  .tools-link:hover {
    color: var(--accent);
  }

  .secret-entry-trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 0.7rem;
    height: 0.7rem;
    border: none;
    background: transparent;
    color: color-mix(in oklab, var(--foreground) 16%, transparent);
    font-size: 0.72rem;
    line-height: 1;
    opacity: 0.35;
    cursor: default;
    user-select: none;
    pointer-events: none;
  }

  @media (max-width: 639px) {
    #tools-menu-trigger {
      min-height: 44px;
    }

    #tools-nav-item[data-open="true"] #tools-dropdown {
      display: block;
      margin-top: 0.45rem;
      border-radius: 1rem;
      border: 1px solid color-mix(in oklab, var(--foreground) 12%, transparent);
      background: color-mix(in oklab, var(--background) 96%, transparent);
      padding: 0.7rem;
    }

    #tools-dropdown .grid {
      display: grid;
      gap: 0.65rem;
    }

    #tools-dropdown section {
      border-radius: 0.8rem;
      border: 1px solid color-mix(in oklab, var(--foreground) 10%, transparent);
      padding: 0.7rem;
      text-align: left;
    }

    #tools-dropdown h3 {
      margin-bottom: 0.45rem;
      font-size: 0.84rem;
      font-weight: 700;
    }

    .tools-link {
      min-height: 44px;
      padding: 0.55rem 0;
      font-size: 0.84rem;
      display: flex;
      align-items: center;
    }
  }
</style>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn") as HTMLElement | null;
    const menuItems = document.querySelector("#menu-items") as HTMLElement | null;
    const menuIcon = document.querySelector("#menu-icon") as HTMLElement | null;
    const closeIcon = document.querySelector("#close-icon") as HTMLElement | null;
    const toolsNavItem = document.querySelector("#tools-nav-item") as HTMLElement | null;
    const toolsTrigger = document.querySelector("#tools-menu-trigger") as HTMLElement | null;
    const toolsDropdown = document.querySelector("#tools-dropdown") as HTMLElement | null;

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon || !toolsNavItem || !toolsTrigger || !toolsDropdown) return;
    if (menuBtn.dataset.bound === "1") return;
    menuBtn.dataset.bound = "1";

    const closeToolsMobileMenu = () => {
      toolsNavItem.setAttribute("data-open", "false");
      toolsTrigger.setAttribute("aria-expanded", "false");
    };

    const toggleToolsMenu = (forceOpen?: boolean) => {
      const isOpen = toolsNavItem.getAttribute("data-open") === "true";
      const next = typeof forceOpen === "boolean" ? forceOpen : !isOpen;
      toolsNavItem.setAttribute("data-open", next ? "true" : "false");
      toolsTrigger.setAttribute("aria-expanded", next ? "true" : "false");
    };

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "Open Menu" : "Close Menu");

      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");

      if (openMenu) {
        closeToolsMobileMenu();
      }
    });

    toolsTrigger.addEventListener("click", e => {
      e.preventDefault();
      e.stopPropagation();
      toggleToolsMenu();
    });

    toolsDropdown.querySelectorAll("a").forEach(link => {
      link.addEventListener("click", () => {
        closeToolsMobileMenu();
      });
    });

    document.addEventListener("click", e => {
      const target = e.target;
      if (!(target instanceof Node)) return;
      if (!toolsNavItem.contains(target)) {
        toggleToolsMenu(false);
      }
    });
  }

  function initSecretEntry() {
    const currentPath = window.location.pathname.endsWith("/") && window.location.pathname !== "/"
      ? window.location.pathname.slice(0, -1)
      : window.location.pathname;
    const isEnHome = currentPath === "/en";
    if (!isEnHome) return;

    const themeBtn = document.querySelector("#theme-btn") as HTMLButtonElement | null;
    if (!themeBtn) return;
    if (themeBtn.dataset.secretBound === "1") return;
    themeBtn.dataset.secretBound = "1";

    const recentClicks: number[] = [];
    const WINDOW_MS = 20_000;
    const REQUIRED_CLICKS = 10;

    themeBtn.addEventListener("click", () => {
      const now = Date.now();
      recentClicks.push(now);
      while (recentClicks.length && now - recentClicks[0] > WINDOW_MS) {
        recentClicks.shift();
      }

      if (recentClicks.length >= REQUIRED_CLICKS) {
        recentClicks.length = 0;
        window.dispatchEvent(new CustomEvent("secret-entry:open"));
      }
    });
  }

  toggleNav();
  initSecretEntry();

  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", toggleNav);
  document.addEventListener("astro:after-swap", initSecretEntry);
</script>
