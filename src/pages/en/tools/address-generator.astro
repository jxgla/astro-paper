---
import DocToolPage from "@/layouts/DocToolPage.astro";

const addressToolUrl = import.meta.env.PUBLIC_ADDRESS_TOOL_URL || "";
---

<DocToolPage
  title="Address / Mock Identity Generator"
  desc="Entry page for a standalone address and mock identity tool"
  heading="Address / Mock Identity Generator"
  subheading="The actual app should live on Cloudflare Workers or Pages, while the blog keeps only a lightweight and safe shell."
>
  <div class="tool-host-shell">
    <div class="tool-host-note">
      <div>
        <strong>Why this is safer</strong>
        <p>It removes heavy frontend logic and data handling from the blog's main page, tool card scripts, and chat flows, reducing the chance of breaking `/chat` or the home bot again.</p>
      </div>
      <div>
        <strong>Recommended setup</strong>
        <p>Deploy `E:\Antigravity\address` as its own Worker or Pages app, expose its own UI and API there, and let the blog reference it only through an environment variable.</p>
      </div>
    </div>

    {
      addressToolUrl ? (
        <>
          <div class="tool-host-actions">
            <a class="tool-open-btn" href={addressToolUrl} target="_blank" rel="noreferrer">Open standalone tool</a>
          </div>
          <iframe
            class="tool-host-frame"
            src={addressToolUrl}
            title="Address / Mock Identity Generator"
            loading="lazy"
            referrerpolicy="strict-origin-when-cross-origin"
            sandbox="allow-scripts allow-forms allow-downloads allow-modals allow-popups allow-same-origin"
          ></iframe>
        </>
      ) : (
        <div class="tool-host-empty">
          <strong>No standalone address tool configured yet</strong>
          <p>Set `PUBLIC_ADDRESS_TOOL_URL` in `astro-paper/.env` and point it to the independently deployed Worker or Pages app.</p>
          <p>Example: `PUBLIC_ADDRESS_TOOL_URL=https://address-tool.your-domain.pages.dev`</p>
        </div>
      )
    }
  </div>
</DocToolPage>

<style>
  .tool-host-shell {
    display: grid;
    gap: 1rem;
  }

  .tool-host-note {
    display: grid;
    gap: 0.8rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .tool-host-note > div,
  .tool-host-empty {
    border: 1px solid color-mix(in oklab, var(--foreground) 14%, transparent);
    border-radius: 0.9rem;
    padding: 0.95rem;
    background: color-mix(in oklab, var(--background) 96%, transparent);
  }

  .tool-host-note p,
  .tool-host-empty p {
    margin: 0.35rem 0 0;
    line-height: 1.7;
    font-size: 0.92rem;
  }

  .tool-host-actions {
    display: flex;
    justify-content: flex-end;
  }

  .tool-open-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: 0.75rem 1rem;
    border-radius: 0.8rem;
    text-decoration: none;
    color: white;
    font-weight: 600;
    background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 58%, #1e3a8a 100%);
    box-shadow: 0 14px 30px rgba(37, 99, 235, 0.22);
  }

  .tool-host-frame {
    width: 100%;
    min-height: 78vh;
    border: 1px solid color-mix(in oklab, var(--foreground) 14%, transparent);
    border-radius: 1rem;
    background: color-mix(in oklab, var(--background) 98%, transparent);
  }
</style>