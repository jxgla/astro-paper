---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/layouts/Main.astro";
import { SITE } from "@/config";

const noIndex = true;
---

<Layout title={`Restricted | ${SITE.title}`} noIndex={noIndex}>
  <Header />
  <Main pageTitle="Restricted" pageDesc="Private access only.">
    <section class="vault-shell" data-secret-vault>
      <div class="vault-card" data-secret-vault-card>
        <p class="vault-kicker">Restricted</p>
        <h1>Private workspace</h1>
        <p class="vault-copy">Token verification required. This page stays locked unless a fresh signed token is present.</p>
        <div class="vault-status" data-secret-vault-status>Checking access…</div>
        <div class="vault-content" data-secret-vault-content hidden>
          <div class="vault-grid">
            <article>
              <strong>Session</strong>
              <p>Short-lived access granted.</p>
            </article>
            <article>
              <strong>Reminder</strong>
              <p>When the token expires, this page becomes inaccessible again.</p>
            </article>
          </div>
        </div>
      </div>
    </section>
  </Main>
  <Footer />
</Layout>

<style>
  .vault-shell {
    display: grid;
    place-items: center;
    min-height: 60vh;
  }

  .vault-card {
    width: min(100%, 56rem);
    border-radius: 1.2rem;
    border: 1px solid color-mix(in oklab, var(--foreground) 13%, transparent);
    background: linear-gradient(135deg, color-mix(in oklab, var(--background) 96%, transparent), color-mix(in oklab, #0f172a 16%, var(--background) 84%));
    padding: 1.4rem;
    box-shadow: 0 28px 80px rgba(15, 23, 42, 0.22);
  }

  .vault-kicker {
    margin: 0;
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--accent) 85%, white 15%);
  }

  .vault-card h1 {
    margin: 0.45rem 0 0;
    font-size: clamp(1.9rem, 4vw, 3rem);
  }

  .vault-copy,
  .vault-status,
  .vault-grid p {
    color: color-mix(in oklab, var(--foreground) 78%, transparent);
    line-height: 1.7;
  }

  .vault-content {
    margin-top: 1rem;
  }

  .vault-grid {
    display: grid;
    gap: 0.9rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .vault-grid article {
    border-radius: 1rem;
    border: 1px solid color-mix(in oklab, var(--foreground) 12%, transparent);
    background: color-mix(in oklab, var(--background) 98%, transparent);
    padding: 1rem;
  }

  .vault-grid strong {
    display: block;
    margin-bottom: 0.35rem;
  }
</style>

<script>
  document.addEventListener("astro:page-load", async () => {
    const status = document.querySelector("[data-secret-vault-status]") as HTMLElement | null;
    const content = document.querySelector("[data-secret-vault-content]") as HTMLElement | null;
    if (!status || !content) return;

    const params = new URLSearchParams(window.location.search);
    const token = params.get("token") || sessionStorage.getItem("secretEntryToken") || "";
    const path = sessionStorage.getItem("secretEntryPath") || "";
    const expectedPath = "/en/x9qv-2mra-k7p1-vault-c4e8n";

    if (!token || (path && path !== expectedPath)) {
      status.textContent = "Access denied.";
      return;
    }

    const [expiresAtRaw] = token.split(".");
    const expiresAt = Number(expiresAtRaw || 0);
    if (!Number.isFinite(expiresAt) || Date.now() > expiresAt) {
      sessionStorage.removeItem("secretEntryToken");
      status.textContent = "Token expired.";
      return;
    }

    status.textContent = "Access granted.";
    content.hidden = false;
  });
</script>
