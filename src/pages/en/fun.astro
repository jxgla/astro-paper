---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/layouts/Main.astro";
import { SITE } from "@/config";

// Prefer a configured env var, but default to the production custom domain.
const funApiBase = import.meta.env.PUBLIC_FUN_API_BASE || "https://fun.410666.xyz";
---

<Layout title={`Fun | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Fun" pageDesc="Grok2API-powered fun capabilities (phase 1: image waterfall)">
    <section class="fun-section">
      <article class="fun-card">
        <h2>Image Waterfall</h2>
        <p>Generate images continuously from prompts. Maximum 50 images per IP per day.</p>

        <form class="fun-form" data-fun-imagine data-api-base={funApiBase}>
          <label>
            <span class="fun-label">Prompt</span>
            <textarea class="fun-input" data-prompt placeholder="e.g. neon cyberpunk alley, rainy night, cinematic light"></textarea>
          </label>

          <label>
            <span class="fun-label">Aspect Ratio</span>
            <select class="fun-select" data-ratio>
              <option value="2:3">2:3</option>
              <option value="3:2">3:2</option>
              <option value="1:1">1:1</option>
              <option value="16:9">16:9</option>
              <option value="9:16">9:16</option>
            </select>
          </label>

          <div class="fun-actions">
            <button type="submit" class="fun-btn-primary" data-start>Start</button>
            <button type="button" class="fun-btn-secondary" data-stop>Stop</button>
            <button type="button" class="fun-btn-secondary" data-clear>Clear Images</button>
            <button type="button" class="fun-btn-secondary" data-batch>Batch Save</button>
          </div>

          <div class="fun-save-row">
            <label class="fun-toggle">
              <input type="checkbox" data-auto-save />
              <span>Auto-save</span>
            </label>
            <button type="button" class="fun-btn-secondary" data-pick-folder disabled>Select folder</button>
            <span class="fun-folder" data-folder>Not selected</span>
          </div>

          <p class="fun-status" data-status>Ready</p>
          <p class="fun-quota" data-quota>Daily quota: -- / 50</p>
        </form>
      </article>

      <article class="fun-waterfall-card">
        <div class="fun-selection" data-selection hidden>
          <button type="button" class="fun-btn-secondary" data-select-all>Select all / Deselect</button>
          <button type="button" class="fun-btn-primary" data-download-selected disabled>Download selected (<span data-selected-count>0</span>)</button>
          <button type="button" class="fun-btn-secondary" data-exit-selection>Exit</button>
        </div>
        <div class="fun-waterfall" data-waterfall></div>
      </article>
    </section>
  </Main>
  <Footer />
</Layout>

<style>
  .fun-section {
    display: grid;
    gap: 0.9rem;
  }

  .fun-card,
  .fun-waterfall-card {
    border: 1px solid color-mix(in oklab, var(--foreground) 15%, transparent);
    border-radius: 0.9rem;
    padding: 0.9rem;
    background: color-mix(in oklab, var(--background) 95%, transparent);
  }

  .fun-card h2 {
    margin: 0 0 0.4rem;
    font-size: 1rem;
    font-weight: 700;
  }

  .fun-card p {
    margin: 0;
    font-size: 0.82rem;
    color: color-mix(in oklab, var(--foreground) 78%, transparent);
  }

  .fun-form {
    margin-top: 0.7rem;
    display: grid;
    gap: 0.55rem;
  }

  .fun-label {
    display: inline-block;
    margin-bottom: 0.25rem;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .fun-input,
  .fun-select {
    width: 100%;
    border-radius: 0.6rem;
    border: 1px solid color-mix(in oklab, var(--foreground) 18%, transparent);
    background: color-mix(in oklab, var(--background) 96%, transparent);
    color: var(--foreground);
    padding: 0.55rem 0.58rem;
    font-size: 0.78rem;
  }

  .fun-input {
    min-height: 5.8rem;
    resize: vertical;
    line-height: 1.45;
  }

  .fun-actions {
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .fun-btn-primary,
  .fun-btn-secondary {
    border: 1px solid color-mix(in oklab, var(--foreground) 18%, transparent);
    background: color-mix(in oklab, var(--background) 95%, transparent);
    color: var(--foreground);
    border-radius: 0.52rem;
    padding: 0.38rem 0.72rem;
    font-size: 0.74rem;
    cursor: pointer;
  }

  .fun-btn-primary {
    border-color: transparent;
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
    color: #fff;
  }

  .fun-status,
  .fun-quota {
    margin: 0;
    font-size: 0.72rem;
    color: color-mix(in oklab, var(--foreground) 70%, transparent);
  }

  .fun-save-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .fun-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.74rem;
    user-select: none;
  }

  .fun-folder {
    font-size: 0.72rem;
    color: color-mix(in oklab, var(--foreground) 70%, transparent);
  }

  .fun-selection {
    position: sticky;
    top: 0.6rem;
    z-index: 5;
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
    padding: 0.55rem;
    border-radius: 0.7rem;
    margin-bottom: 0.7rem;
    border: 1px solid color-mix(in oklab, var(--foreground) 15%, transparent);
    background: color-mix(in oklab, var(--background) 92%, transparent);
    backdrop-filter: blur(10px);
  }

  .fun-waterfall {
    columns: 4 220px;
    column-gap: 0.7rem;
  }

  .fun-item {
    break-inside: avoid;
    margin-bottom: 0.7rem;
    border-radius: 0.72rem;
    overflow: hidden;
    border: 1px solid color-mix(in oklab, var(--foreground) 14%, transparent);
    background: color-mix(in oklab, var(--background) 97%, transparent);
    position: relative;
  }

  .fun-item.selection-mode {
    cursor: pointer;
  }

  .fun-item.selection-mode::after {
    content: "";
    position: absolute;
    inset: 0;
    background: transparent;
    pointer-events: none;
    transition: background 120ms ease;
  }

  .fun-item.selection-mode.selected::after {
    background: color-mix(in oklab, #2563eb 20%, transparent);
  }

  .fun-item img {
    width: 100%;
    display: block;
  }

  .fun-item-meta {
    padding: 0.4rem 0.5rem;
    font-size: 0.68rem;
    color: color-mix(in oklab, var(--foreground) 72%, transparent);
  }
</style>

<script>
  // @ts-nocheck
  function initFunImagePage() {
    const root = document.querySelector("[data-fun-imagine]");
    if (!(root instanceof HTMLFormElement) || root.dataset.bound === "1") return;
    root.dataset.bound = "1";

    const apiBase = (root.getAttribute("data-api-base") || "").replace(/\/$/, "");
    const promptEl = root.querySelector("[data-prompt]");
    const ratioEl = root.querySelector("[data-ratio]");
    const statusEl = root.querySelector("[data-status]");
    const quotaEl = root.querySelector("[data-quota]");
    const stopBtn = root.querySelector("[data-stop]");
    const clearBtn = root.querySelector("[data-clear]");
    const batchBtn = root.querySelector("[data-batch]");
    const autoSaveToggle = root.querySelector("[data-auto-save]");
    const pickFolderBtn = root.querySelector("[data-pick-folder]");
    const folderEl = root.querySelector("[data-folder]");
    const waterfall = document.querySelector("[data-waterfall]");
    const selectionBar = document.querySelector("[data-selection]");
    const selectAllBtn = document.querySelector("[data-select-all]");
    const downloadSelectedBtn = document.querySelector("[data-download-selected]");
    const exitSelectionBtn = document.querySelector("[data-exit-selection]");
    const selectedCountEl = document.querySelector("[data-selected-count]");

    if (!(promptEl instanceof HTMLTextAreaElement)) return;
    if (!(ratioEl instanceof HTMLSelectElement)) return;
    if (!(statusEl instanceof HTMLElement)) return;
    if (!(quotaEl instanceof HTMLElement)) return;
    if (!(stopBtn instanceof HTMLButtonElement)) return;
    if (!(clearBtn instanceof HTMLButtonElement)) return;
    if (!(batchBtn instanceof HTMLButtonElement)) return;
    if (!(autoSaveToggle instanceof HTMLInputElement)) return;
    if (!(pickFolderBtn instanceof HTMLButtonElement)) return;
    if (!(folderEl instanceof HTMLElement)) return;
    if (!(waterfall instanceof HTMLElement)) return;
    if (!(selectionBar instanceof HTMLElement)) return;
    if (!(selectAllBtn instanceof HTMLButtonElement)) return;
    if (!(downloadSelectedBtn instanceof HTMLButtonElement)) return;
    if (!(exitSelectionBtn instanceof HTMLButtonElement)) return;
    if (!(selectedCountEl instanceof HTMLElement)) return;

    let taskId = "";
    /** @type {EventSource | null} */
    let eventSource = null;
    let generated = 0;
    /** @type {Map<string, HTMLElement>} */
    const streamImageMap = new Map();

    // Save / batch-save state
    /** @type {any} */
    let directoryHandle = null;
    let useFileSystemAPI = false;
    const savedImageIds = new Set();
    let isSelectionMode = false;
    const selectedItems = new Set();

    /** @type {string | null} */
    let statusHold = null;

    /** @param {string} text */
    function setStatus(text) {
      statusHold = null;
      statusEl.textContent = text;
    }

    /** @param {string} text */
    function holdStatus(text) {
      statusHold = text;
      statusEl.textContent = text;
    }

    setStatus("Initialized");

    const refreshQuota = async () => {
      try {
        if (!statusHold) holdStatus("Loading quota...");
        const res = await fetch(`${apiBase}/api/fun/imagine/quota`, { cache: "no-store" });
        const data = await res.json();
        if (data?.ok) {
          quotaEl.textContent = `Daily quota: ${data.used} / ${data.limit} (remaining ${data.remaining})`;
          if (statusHold === "Loading quota...") setStatus("Ready");
        } else {
          if (!statusHold) holdStatus("Quota API returned unexpected response");
        }
      } catch {
        quotaEl.textContent = "Daily quota: fetch failed";
        if (!statusHold) holdStatus("Quota fetch failed (check domain/CORS/network)");
      }
    };

    function inferMimeFromBase64(b64) {
      if (!b64) return "image/jpeg";
      if (b64.startsWith("iVBOR")) return "image/png";
      if (b64.startsWith("/9j/")) return "image/jpeg";
      if (b64.startsWith("R0lGOD")) return "image/gif";
      return "image/jpeg";
    }

    /** @param {string} payload */
    function payloadToSrc(payload) {
      if (!payload) return "";
      if (payload.startsWith("http://") || payload.startsWith("https://")) return payload;
      if (payload.startsWith("data:")) return payload;
      const mime = inferMimeFromBase64(payload);
      return `data:${mime};base64,${payload}`;
    }

    /** @param {string} payload */
    function addImage(payload) {
      if (!payload) return;
      const item = document.createElement("figure");
      item.className = "fun-item";

      const img = document.createElement("img");
      img.loading = "lazy";
      img.decoding = "async";
      img.src = payloadToSrc(payload);
      img.alt = "generated image";

      const meta = document.createElement("figcaption");
      meta.className = "fun-item-meta";
      generated += 1;
      meta.textContent = `#${generated}`;

      item.appendChild(img);
      item.appendChild(meta);
      waterfall.prepend(item);
    }

    function dataUrlToBlob(dataUrl) {
      const parts = (dataUrl || "").split(",");
      if (parts.length < 2) return null;
      const header = parts[0];
      const b64 = parts.slice(1).join(",");
      const match = header.match(/data:(.*?);base64/);
      const mime = match ? match[1] : "application/octet-stream";
      try {
        const byteString = atob(b64);
        const ab = new ArrayBuffer(byteString.length);
        const ia = new Uint8Array(ab);
        for (let i = 0; i < byteString.length; i++) {
          ia[i] = byteString.charCodeAt(i);
        }
        return new Blob([ab], { type: mime });
      } catch {
        return null;
      }
    }

    function sanitizeFilename(raw) {
      const s = String(raw || "image").trim() || "image";
      return s
        .slice(0, 40)
        .replace(/\s+/g, "_")
        .replace(/[^a-zA-Z0-9\u4e00-\u9fa5_\-]/g, "_");
    }

    async function saveToFileSystem(dataUrlOrBase64, filenameBase) {
      if (!directoryHandle) return false;
      try {
        let dataUrl = dataUrlOrBase64;
        if (dataUrlOrBase64 && !String(dataUrlOrBase64).startsWith("data:")) {
          dataUrl = payloadToSrc(String(dataUrlOrBase64));
        }
        const blob = dataUrlToBlob(String(dataUrl));
        if (!blob) return false;
        const ext = blob.type === "image/png" ? "png" : "jpg";
        const filename = `${sanitizeFilename(filenameBase)}.${ext}`;
        const fileHandle = await directoryHandle.getFileHandle(filename, { create: true });
        const writable = await fileHandle.createWritable();
        await writable.write(blob);
        await writable.close();
        return true;
      } catch {
        return false;
      }
    }

    function downloadImage(dataUrlOrBase64, filenameBase) {
      const payload = String(dataUrlOrBase64 || "");
      const dataUrl = payload.startsWith("data:") ? payload : payloadToSrc(payload);
      const ext = dataUrl.includes("image/png") ? "png" : "jpg";
      const link = document.createElement("a");
      link.href = dataUrl;
      link.download = `${sanitizeFilename(filenameBase)}.${ext}`;
      link.style.display = "none";
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    }

    async function maybeAutoSave(item, meta, imageId, payload, isFinal) {
      if (!autoSaveToggle.checked) return;
      if (!isFinal) return;
      if (!payload) return;

      const key = imageId ? String(imageId) : (item && item.dataset && item.dataset.key) || "";
      if (key && savedImageIds.has(key)) return;

      const prompt = (item && item.dataset && item.dataset.prompt) ? item.dataset.prompt : (meta && meta.prompt) ? String(meta.prompt) : (promptEl.value || "").trim();
      const ts = Date.now();
      const baseName = `imagine_${ts}_${prompt ? sanitizeFilename(prompt) : "image"}`;

      if ("showDirectoryPicker" in window && directoryHandle) {
        const ok = await saveToFileSystem(payload, baseName);
        if (!ok) {
          downloadImage(payload, baseName);
        }
      } else {
        downloadImage(payload, baseName);
      }

      if (key) savedImageIds.add(key);
    }

    /**
     * Upsert a stream image by imageId so partial images can be replaced by final images.
     * @param {string} payload
     * @param {any} meta
     * @param {string} imageId
     * @param {boolean} isFinal
     */
    function upsertStreamImage(payload, meta, imageId, isFinal) {
      if (!payload || !imageId) return;
      const existing = streamImageMap.get(imageId);
      if (!existing) {
        const item = document.createElement("figure");
        item.className = "fun-item";
        item.dataset.imageId = imageId;

        const img = document.createElement("img");
        img.loading = "lazy";
        img.decoding = "async";
        img.src = payloadToSrc(payload);
        img.alt = "generated image";

        const metaEl = document.createElement("figcaption");
        metaEl.className = "fun-item-meta";
        generated += 1;
        const ms = meta && meta.elapsed_ms ? ` • ${meta.elapsed_ms}ms` : "";
        metaEl.textContent = `#${generated}${isFinal ? "" : " (generating)"}${ms}`;

        item.dataset.imageUrl = payloadToSrc(payload);
        item.dataset.prompt = (meta && meta.prompt) ? String(meta.prompt) : (promptEl.value || "").trim();
        item.dataset.key = imageId;

        item.appendChild(img);
        item.appendChild(metaEl);
        waterfall.prepend(item);
        streamImageMap.set(imageId, item);

        maybeAutoSave(item, meta, imageId, payload, isFinal);
        return;
      }

      const img = existing.querySelector("img");
      if (img instanceof HTMLImageElement) {
        img.src = payloadToSrc(payload);
      }
      existing.dataset.imageUrl = payloadToSrc(payload);
      const metaEl = existing.querySelector(".fun-item-meta");
      if (metaEl instanceof HTMLElement) {
        const ms = meta && meta.elapsed_ms ? ` • ${meta.elapsed_ms}ms` : "";
        metaEl.textContent = `${metaEl.textContent?.replace(/\(generating\)/g, "") || ""}${isFinal ? "" : " (generating)"}${ms}`.trim();
      }

      maybeAutoSave(existing, meta, imageId, payload, isFinal);
    }

    function updateSelectedCount() {
      selectedCountEl.textContent = String(selectedItems.size);
      downloadSelectedBtn.disabled = selectedItems.size === 0;

      const items = Array.from(waterfall.querySelectorAll(".fun-item"));
      const allSelected = items.length > 0 && selectedItems.size === items.length;
      selectAllBtn.textContent = allSelected ? "Deselect all" : "Select all";
    }

    function enterSelectionMode() {
      isSelectionMode = true;
      selectedItems.clear();
      selectionBar.hidden = false;
      Array.from(waterfall.querySelectorAll(".fun-item")).forEach(item => item.classList.add("selection-mode"));
      updateSelectedCount();
      setStatus("Selection mode");
    }

    function exitSelectionMode() {
      isSelectionMode = false;
      selectedItems.clear();
      selectionBar.hidden = true;
      Array.from(waterfall.querySelectorAll(".fun-item")).forEach(item => item.classList.remove("selection-mode", "selected"));
      updateSelectedCount();
      setStatus("Ready");
    }

    function toggleItemSelection(item) {
      if (!isSelectionMode) return;
      if (!(item instanceof HTMLElement)) return;
      if (item.classList.contains("selected")) {
        item.classList.remove("selected");
        selectedItems.delete(item);
      } else {
        item.classList.add("selected");
        selectedItems.add(item);
      }
      updateSelectedCount();
    }

    function toggleSelectAll() {
      const items = Array.from(waterfall.querySelectorAll(".fun-item"));
      const allSelected = items.length > 0 && selectedItems.size === items.length;
      if (allSelected) {
        items.forEach(item => item.classList.remove("selected"));
        selectedItems.clear();
      } else {
        items.forEach(item => {
          item.classList.add("selected");
          selectedItems.add(item);
        });
      }
      updateSelectedCount();
    }

    async function downloadSelectedAsZip() {
      if (selectedItems.size === 0) return;
      if (typeof window.JSZip === "undefined") {
        setStatus("JSZip not loaded");
        return;
      }

      setStatus(`Packing ${selectedItems.size} images...`);
      downloadSelectedBtn.disabled = true;

      const zip = new window.JSZip();
      const folder = zip.folder("images");
      let idx = 0;

      for (const item of selectedItems) {
        const url = item.dataset.imageUrl || "";
        const prompt = item.dataset.prompt || "image";
        let blob = null;
        try {
          if (url.startsWith("data:")) {
            blob = dataUrlToBlob(url);
          } else if (url) {
            const res = await fetch(url);
            blob = await res.blob();
          }
        } catch {
          blob = null;
        }
        if (!blob) continue;
        idx += 1;
        const ext = blob.type === "image/png" ? "png" : "jpg";
        const filename = `${sanitizeFilename(prompt)}_${idx}.${ext}`;
        folder.file(filename, blob);
      }

      if (idx === 0) {
        setStatus("No downloadable images");
        downloadSelectedBtn.disabled = false;
        return;
      }

      const content = await zip.generateAsync({ type: "blob" });
      const link = document.createElement("a");
      link.href = URL.createObjectURL(content);
      link.download = `imagine_${new Date().toISOString().slice(0, 10)}_${Date.now()}.zip`;
      link.click();
      URL.revokeObjectURL(link.href);
      setStatus(`Downloaded ${idx} images`);
      downloadSelectedBtn.disabled = false;
      exitSelectionMode();
    }

    const stopStream = async (silent = false) => {
      if (eventSource) {
        eventSource.close();
        eventSource = null;
      }

      if (taskId) {
        try {
          await fetch(`${apiBase}/api/fun/imagine/stop`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ task_ids: [taskId] }),
          });
        } catch {
          // ignore
        }
      }

      taskId = "";
      if (!silent) setStatus("Stopped");
      await refreshQuota();
    };

    root.addEventListener("submit", async event => {
      event.preventDefault();

      const prompt = (promptEl.value || "").trim();
      const aspect_ratio = ratioEl.value || "2:3";
      if (!prompt) {
        setStatus("Please enter a prompt");
        return;
      }

      await stopStream(true);

      setStatus("Creating task...");
      let startData;
      try {
        const res = await fetch(`${apiBase}/api/fun/imagine/start`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ prompt, aspect_ratio }),
        });
        const rawText = await res.text();
        try {
          startData = rawText ? JSON.parse(rawText) : null;
        } catch {
          startData = null;
        }
        if (!res.ok || !startData?.task_id) {
          const apiMsg = startData?.error || startData?.detail || rawText;
          throw new Error(`HTTP ${res.status}: ${String(apiMsg || "start failed").slice(0, 200)}`);
        }
      } catch (err) {
        const message = err instanceof Error ? err.message : String(err);
        setStatus(`Start failed: ${message}`);
        // Don't overwrite the error status with "Ready" immediately.
        refreshQuota();
        return;
      }

      taskId = startData.task_id;
      setStatus("Generating...");

      eventSource = new EventSource(`${apiBase}/api/fun/imagine/sse?task_id=${encodeURIComponent(taskId)}`);
      eventSource.onmessage = async e => {
        if (!e?.data) return;
        if (e.data === "[DONE]") {
          await stopStream(true);
          setStatus("Completed");
          return;
        }

        let payload;
        try {
          payload = JSON.parse(e.data);
        } catch {
          return;
        }

        // Grok2API streaming event types
        if (payload?.type === "image_generation.partial_image" || payload?.type === "image_generation.completed") {
          const imageId = payload.image_id || payload.imageId;
          const p = payload.b64_json || payload.url || payload.image;
          const isFinal = payload.type === "image_generation.completed" || payload.stage === "final";
          if (p && imageId) {
            upsertStreamImage(p, payload, String(imageId), Boolean(isFinal));
          }
          return;
        }

        if (payload?.type === "image" && payload?.b64_json) {
          addImage(payload.b64_json);
          return;
        }

        if (payload?.type === "status") {
          if (payload.status === "running") {
            setStatus("Generating...");
          }
          if (payload.status === "stopped") {
            await stopStream(true);
            setStatus("Completed");
          }
          return;
        }

        if (payload?.type === "quota" && payload?.status === "limit_reached") {
          setStatus("Daily quota reached (50)");
          await stopStream(true);
          return;
        }

        if (payload?.type === "error" || payload?.error) {
          const msg = payload?.message || payload?.error?.message || "unknown";
          setStatus(`Error: ${msg}`);
          await stopStream(true);
          return;
        }
      };

      eventSource.onerror = async () => {
        setStatus("Connection dropped and stopped");
        await stopStream(true);
      };
    });

    stopBtn.addEventListener("click", () => stopStream());

    clearBtn.addEventListener("click", () => {
      waterfall.innerHTML = "";
      generated = 0;
      streamImageMap.clear();
      savedImageIds.clear();
      selectedItems.clear();
      exitSelectionMode();
      setStatus("Images cleared");
    });

    // Auto-save: folder picking
    if ("showDirectoryPicker" in window) {
      pickFolderBtn.disabled = false;
      pickFolderBtn.addEventListener("click", async () => {
        try {
          directoryHandle = await window.showDirectoryPicker({ mode: "readwrite" });
          useFileSystemAPI = true;
          folderEl.textContent = directoryHandle?.name || "Selected";
          setStatus("Folder selected");
        } catch (e) {
          if (e && e.name !== "AbortError") {
            setStatus("Folder selection failed");
          }
        }
      });
    } else {
      pickFolderBtn.disabled = true;
      folderEl.textContent = "Folder save unsupported (will download)";
    }

    autoSaveToggle.addEventListener("change", () => {
      if (autoSaveToggle.checked) {
        if ("showDirectoryPicker" in window) {
          pickFolderBtn.disabled = false;
          if (!directoryHandle) {
            holdStatus("Auto-save enabled: please select a folder");
          }
        } else {
          holdStatus("Auto-save enabled: will use downloads");
        }
      } else {
        setStatus("Auto-save disabled");
      }
    });

    // Batch save
    batchBtn.addEventListener("click", () => {
      if (isSelectionMode) {
        exitSelectionMode();
      } else {
        enterSelectionMode();
      }
    });
    exitSelectionBtn.addEventListener("click", exitSelectionMode);
    selectAllBtn.addEventListener("click", toggleSelectAll);
    downloadSelectedBtn.addEventListener("click", downloadSelectedAsZip);

    waterfall.addEventListener("click", e => {
      if (!isSelectionMode) return;
      const item = e.target && e.target.closest ? e.target.closest(".fun-item") : null;
      if (item) toggleItemSelection(item);
    });

    window.addEventListener("beforeunload", () => {
      if (eventSource) eventSource.close();
    });

    refreshQuota();
  }

  // Ensure the page works whether or not Astro's client router/view-transitions are enabled.
  // - Initial load: DOMContentLoaded (or immediate if DOM already ready)
  // - Client-side navigation (if enabled): astro:page-load / astro:after-swap
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initFunImagePage, { once: true });
  } else {
    initFunImagePage();
  }
  document.addEventListener("astro:page-load", initFunImagePage);
  document.addEventListener("astro:after-swap", initFunImagePage);
</script>

