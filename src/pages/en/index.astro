---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";
import HomeChatbotWidget from "@/components/HomeChatbotWidget.astro";

const posts = await getCollection("blog");

// EN home: prioritize localized EN posts first (filename suffix -en)
const enPostsOnly = posts.filter(p => p.id.endsWith("-en"));
const sortedPosts = getSortedPosts(enPostsOnly);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const toolsApiBase = import.meta.env.PUBLIC_TOOLS_API_BASE || "https://tools-worker.mehjx.workers.dev";
---

<Layout title={`AI Terminal | English | ${SITE.title}`}>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout relative pb-24 md:pb-40">
    <div aria-hidden="true" class="ambient-shell pointer-events-none">
      <div class="ambient-orb ambient-orb-left"></div>
      <div class="ambient-orb ambient-orb-right"></div>
      <div class="ambient-grid"></div>
    </div>
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        AI Terminal
      </h1>
      <a
        target="_blank"
        href="/rss.xml"
        class="inline-block"
        aria-label="rss feed"
        title="RSS Feed"
      >
        <IconRss
          width={20}
          height={20}
          class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSS Feed</span>
      </a>

      <p class="mt-2 text-skin-base/80">
        Security-first AI gateway notes · Cloudflare edge deployment · practical engineering logs
      </p>
      <p class="mt-1 text-skin-base/60 text-sm">
        This site runs a Cloudflare Worker based <strong>multi-model AI gateway</strong> with Grok / GPT / Codex switching, SSE streaming, and layered abuse protection.
      </p>

      {
        SOCIALS.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">Social Links:</div>
            <Socials />
          </div>
        )
      }

      <div class="mt-8">
        <p class="mb-3 text-xs text-skin-base/55">English access · secure edge gateway · instant model switching</p>
        <a
          href="/en/chat"
          class="group relative inline-flex items-center gap-3 overflow-hidden rounded-xl border border-white/20 px-8 py-3.5 text-base font-semibold text-white shadow-lg transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl"
          style="background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 58%, #1e3a8a 100%);"
        >
          <span>Launch AI Terminal</span>
          <span class="text-white/65 text-sm font-normal">grok-4.1-fast / gpt-5.3-codex ›</span>
        </a>
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Recent Posts</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/en/posts/">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>

    <div
      id="chatbot-reserved-slot"
      aria-hidden="true"
      class="chatbot-slot-placeholder"
    >
      <HomeChatbotWidget locale="en" />
    </div>

    <div class="secret-entry-modal" data-secret-entry-modal hidden>
      <div class="secret-entry-backdrop" data-secret-entry-close></div>
      <div class="secret-entry-panel" role="dialog" aria-modal="true" aria-label="Restricted access">
        <div class="secret-entry-head">
          <strong>Restricted access</strong>
          <button type="button" class="secret-entry-close" data-secret-entry-close aria-label="Close">✕</button>
        </div>
        <p class="secret-entry-copy">Enter the PIN to continue.</p>
        <form class="secret-entry-form" data-secret-entry-form data-tools-api-base={toolsApiBase}>
          <input class="secret-entry-input" data-secret-entry-input type="password" inputmode="numeric" autocomplete="one-time-code" placeholder="PIN code" />
          <button type="submit" class="secret-entry-submit">Enter</button>
        </form>
        <p class="secret-entry-status" data-secret-entry-status hidden></p>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .ambient-shell {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    isolation: isolate;
  }

  .ambient-orb {
    position: absolute;
    width: clamp(20rem, 28vw, 32rem);
    height: clamp(20rem, 28vw, 32rem);
    border-radius: 999px;
    filter: blur(24px);
    opacity: 0.6;
    animation: ambientDrift 16s ease-in-out infinite;
  }

  .ambient-orb-left {
    left: clamp(-12rem, -8vw, -6rem);
    top: 18vh;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.38) 0%, rgba(59, 130, 246, 0) 72%);
  }

  .ambient-orb-right {
    right: clamp(-12rem, -8vw, -6rem);
    top: 32vh;
    background: radial-gradient(circle, rgba(56, 189, 248, 0.32) 0%, rgba(56, 189, 248, 0) 72%);
    animation-delay: -8s;
  }

  .ambient-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(59, 130, 246, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(59, 130, 246, 0.04) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(circle at 50% 40%, rgba(0, 0, 0, 0.42) 0%, transparent 78%);
  }

  .chatbot-slot-placeholder {
    position: fixed;
    right: 1.35rem;
    bottom: 1.35rem;
    width: min(22rem, calc(100vw - 2.4rem));
    height: 22rem;
    border-radius: 1rem;
    height: min(36rem, calc(100vh - 2.4rem));
    background: transparent;
    box-shadow: none;
    backdrop-filter: none;
    pointer-events: auto;
    z-index: 35;
  }

  @media (max-width: 767px) {
    .chatbot-slot-placeholder {
      right: 0.7rem;
      bottom: 0.7rem;
      width: min(22rem, calc(100vw - 1.1rem));
      height: min(34rem, calc(100vh - 1.1rem));
    }
  }

  .chatbot-slot-border,
  .chatbot-slot-label {
    display: none;
  }

  @keyframes ambientDrift {
    0%,
    100% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    50% {
      transform: translate3d(0, -14px, 0) scale(1.035);
    }
  }

  @media (max-width: 1023px) {
    .ambient-shell {
      opacity: 0.72;
    }
  }

  :global(html[data-theme="light"]) .ambient-orb-left {
    background: radial-gradient(circle, rgba(37, 99, 235, 0.24) 0%, rgba(37, 99, 235, 0) 72%);
  }

  :global(html[data-theme="light"]) .ambient-orb-right {
    background: radial-gradient(circle, rgba(14, 165, 233, 0.18) 0%, rgba(14, 165, 233, 0) 72%);
  }

  :global(html[data-theme="light"]) .chatbot-slot-placeholder {
    background: transparent;
  }

  .secret-entry-modal[hidden] {
    display: none;
  }

  .secret-entry-modal {
    position: fixed;
    inset: 0;
    z-index: 90;
  }

  .secret-entry-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(2, 6, 23, 0.55);
    backdrop-filter: blur(8px);
  }

  .secret-entry-panel {
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(92vw, 24rem);
    transform: translate(-50%, -50%);
    border-radius: 1rem;
    border: 1px solid color-mix(in oklab, var(--foreground) 14%, transparent);
    background: color-mix(in oklab, var(--background) 94%, #020617 6%);
    padding: 1rem;
    box-shadow: 0 24px 64px rgba(15, 23, 42, 0.38);
  }

  .secret-entry-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .secret-entry-copy,
  .secret-entry-status {
    margin: 0.8rem 0 0;
    font-size: 0.88rem;
    line-height: 1.6;
    color: color-mix(in oklab, var(--foreground) 78%, transparent);
  }

  .secret-entry-form {
    display: grid;
    gap: 0.75rem;
    margin-top: 0.9rem;
  }

  .secret-entry-input {
    width: 100%;
    border-radius: 0.8rem;
    border: 1px solid color-mix(in oklab, var(--foreground) 15%, transparent);
    background: color-mix(in oklab, var(--background) 98%, transparent);
    color: var(--foreground);
    padding: 0.78rem 0.85rem;
    font-size: 0.92rem;
  }

  .secret-entry-submit,
  .secret-entry-close {
    border-radius: 0.75rem;
    border: 1px solid color-mix(in oklab, var(--foreground) 14%, transparent);
    background: color-mix(in oklab, var(--background) 98%, transparent);
    color: var(--foreground);
    cursor: pointer;
  }

  .secret-entry-submit {
    padding: 0.72rem 0.95rem;
    font-size: 0.88rem;
    font-weight: 700;
  }

  .secret-entry-close {
    width: 2rem;
    height: 2rem;
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/en");
    }
  });

  document.addEventListener("astro:page-load", () => {
    const modal = document.querySelector("[data-secret-entry-modal]") as HTMLElement | null;
    const form = document.querySelector("[data-secret-entry-form]") as HTMLFormElement | null;
    const input = document.querySelector("[data-secret-entry-input]") as HTMLInputElement | null;
    const status = document.querySelector("[data-secret-entry-status]") as HTMLElement | null;
    const closeButtons = document.querySelectorAll("[data-secret-entry-close]");
    if (!modal || !form || !input || !status) return;
    if (form.dataset.bound === "1") return;
    form.dataset.bound = "1";

    const closeModal = () => {
      modal.hidden = true;
      input.value = "";
      status.hidden = true;
      status.textContent = "";
    };

    const openModal = () => {
      modal.hidden = false;
      status.hidden = true;
      status.textContent = "";
      setTimeout(() => input.focus(), 20);
    };

    closeButtons.forEach(button => {
      button.addEventListener("click", closeModal);
    });

    window.addEventListener("secret-entry:open", openModal);

    form.addEventListener("submit", async event => {
      event.preventDefault();
      const toolsApiBase = form.dataset.toolsApiBase || "";
      if (!toolsApiBase) {
        status.hidden = false;
        status.textContent = "Secret entry is unavailable.";
        return;
      }

      const pin = input.value.trim();
      if (!pin) {
        status.hidden = false;
        status.textContent = "Enter the PIN first.";
        return;
      }

      status.hidden = false;
      status.textContent = "Checking…";

      try {
        const response = await fetch(`${toolsApiBase}/api/tools/secret-entry-auth`, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ pin }),
        });

        const payload = await response.json();
        if (!response.ok || !payload?.ok || !payload?.token || !payload?.targetUrl) {
          throw new Error(payload?.error || "Access denied");
        }

        sessionStorage.setItem("secretEntryToken", payload.token);
        window.location.href = `${payload.targetUrl}${payload.targetUrl.includes("?") ? "&" : "?"}token=${encodeURIComponent(payload.token)}`;
      } catch (error) {
        status.textContent = error instanceof Error ? error.message : "Access denied";
      }
    });
  });
</script>