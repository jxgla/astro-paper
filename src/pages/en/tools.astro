---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/layouts/Main.astro";
import { SITE } from "@/config";

const toolsApiBase = import.meta.env.PUBLIC_TOOLS_API_BASE || "https://tools-worker.mehjx.workers.dev";
---

<Layout title={`Tools | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Tools" pageDesc="A curated toolbox for practical workflows." wide>
    <section id="fun" class="tools-section">
      <h2>Fun Utilities</h2>
      <div class="tools-grid">
        <article id="mbti-match" data-tool-expandable>
          <h3>MBTI Match Test</h3>
          <p>See whether you two are instant spark, slow-burn gold, or that classic high-chemistry high-friction pairing.</p>
          <span class="tool-badge">New</span>

          <form class="tool-form" data-mbti-form data-tools-api-base={toolsApiBase}>
            <div class="mbti-grid">
              <label>
                <span class="tool-label">MBTI A</span>
                <select class="tool-input" data-mbti-type-a>
                  <option value="">Select</option>
                </select>
              </label>
              <label>
                <span class="tool-label">MBTI B</span>
                <select class="tool-input" data-mbti-type-b>
                  <option value="">Select</option>
                </select>
              </label>
            </div>

            <div class="tool-actions">
              <button type="submit" class="tool-btn-primary" data-mbti-submit>Analyze</button>
              <button type="button" class="tool-btn-secondary" data-mbti-deep>AI Deep Read</button>
              <button type="button" class="tool-btn-secondary" data-mbti-swap>Swap</button>
              <button type="button" class="tool-btn-secondary" data-mbti-copy>Copy</button>
              <button type="button" class="tool-btn-secondary" data-mbti-poster>Share Card</button>
            </div>

            <p class="tool-status" data-mbti-status>Pick two MBTI types and instantly see whether this is sweet, slow-burn, or chaos with chemistry.</p>

            <div class="tool-result-wrap" data-mbti-result-wrap hidden>
              <div class="mbti-score-card">
                <div>
                  <div class="mbti-score-label">Overall Match</div>
                  <div class="mbti-score-value" data-mbti-overall>--</div>
                </div>
                <div>
                  <div class="mbti-pair" data-mbti-pair>-- × --</div>
                  <div class="mbti-tier" data-mbti-tier hidden></div>
                </div>
              </div>

              <div class="mbti-dimension-grid" data-mbti-dimensions></div>
              <div class="mbti-share-title" data-mbti-share-title hidden></div>

              <div class="tool-result mbti-result-block" data-mbti-result></div>
              <div class="tool-result mbti-result-block" data-mbti-deep-result hidden></div>
            </div>

            <div class="temp-mail-modal" data-mbti-poster-modal hidden>
              <div class="temp-mail-modal-backdrop" data-mbti-poster-close></div>
              <div class="temp-mail-modal-panel temp-mail-modal-panel-poster" role="dialog" aria-modal="true" aria-label="Share card">
                <div class="temp-mail-modal-head">
                  <strong>Share Card</strong>
                  <button type="button" class="tool-btn-secondary" data-mbti-poster-close>Close</button>
                </div>
                <div class="mbti-poster-preview" data-mbti-poster-preview></div>
                <div class="tool-actions">
                  <button type="button" class="tool-btn-primary" data-mbti-poster-download>Download PNG</button>
                  <button type="button" class="tool-btn-secondary" data-mbti-poster-copy>Copy caption</button>
                </div>
              </div>
            </div>
          </form>
        </article>

        <article id="emoji-dna" data-tool-expandable>
          <h3>Emoji DNA</h3>
          <p>Paste a chat snippet and see your emoji vibe. Local-only.</p>
          <span class="tool-badge">New</span>

          <div class="tool-form" data-emoji-dna data-locale="en">
            <label>
              <span class="tool-label">Chat snippet</span>
              <textarea class="tool-textarea" data-emoji-dna-input placeholder="Paste text..." style="min-height: 7rem"></textarea>
            </label>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-emoji-dna-analyze>Analyze</button>
              <button type="button" class="tool-btn-secondary" data-emoji-dna-copy disabled>Copy</button>
              <button type="button" class="tool-btn-secondary" data-emoji-dna-share disabled>Share</button>
            </div>
            <p class="tool-status" data-emoji-dna-status aria-live="polite">Tip: runs locally in your browser — nothing is uploaded.</p>
            <div class="tool-result emoji-dna-top" data-emoji-dna-top></div>
            <div class="emoji-dna-bars">
              <div class="emoji-dna-row"><span>Sweetness</span><div class="emoji-dna-bar" data-emoji-dna-sweet></div></div>
              <div class="emoji-dna-row"><span>Spiciness</span><div class="emoji-dna-bar" data-emoji-dna-spicy></div></div>
              <div class="emoji-dna-row"><span>Chaos</span><div class="emoji-dna-bar" data-emoji-dna-chaos></div></div>
              <div class="emoji-dna-row"><span>Energy</span><div class="emoji-dna-bar" data-emoji-dna-energy></div></div>
            </div>
            <div class="tool-status">Vibe: <strong data-emoji-dna-vibe>--</strong></div>
            <pre class="tool-result" data-emoji-dna-summary></pre>
          </div>
        </article>

        <article id="nickname-gen" data-tool-expandable>
          <h3>Nickname Generator</h3>
          <p>Generate meme-ready nicknames with a style knob.</p>
          <span class="tool-badge">New</span>

          <div class="tool-form" data-nickname-gen data-locale="en">
            <label>
              <span class="tool-label">Keyword (optional)</span>
              <input class="tool-input" data-nickname-key type="text" placeholder="e.g. vibe" />
            </label>
            <label>
              <span class="tool-label">Style</span>
              <select class="tool-input" data-nickname-style>
                <option value="cyber">Cyber</option>
                <option value="xianxia">Xianxia</option>
                <option value="minimal">Minimal</option>
                <option value="japan">J-Style</option>
                <option value="abstract">Abstract</option>
                <option value="emo">Emo</option>
                <option value="biz">Business</option>
              </select>
            </label>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-nickname-generate>Generate</button>
              <button type="button" class="tool-btn-secondary" data-nickname-more>More</button>
              <button type="button" class="tool-btn-secondary" data-nickname-copyall disabled>Copy all</button>
            </div>
            <p class="tool-status" data-nickname-status aria-live="polite">Generate names locally. No network.</p>
            <div class="nickname-tiles" data-nickname-list></div>
          </div>
        </article>

        <article id="astro-roast" data-tool-expandable>
          <h3>Astro Roast</h3>
          <p>Mystic mode vs skeptic mode — both will call you out.</p>
          <span class="tool-badge">New</span>

          <div class="tool-form" data-astro-roast data-locale="en">
            <label>
              <span class="tool-label">Birthday (optional)</span>
              <input class="tool-input" data-astro-date type="date" />
            </label>
            <label>
              <span class="tool-label">Zodiac (optional)</span>
              <select class="tool-input" data-astro-sign>
                <option value="">Select</option>
              </select>
            </label>
            <label>
              <span class="tool-label">Mode</span>
              <select class="tool-input" data-astro-mode>
                <option value="mystic">Mystic</option>
                <option value="skeptic">Skeptic</option>
              </select>
            </label>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-astro-generate>Generate</button>
              <button type="button" class="tool-btn-secondary" data-astro-copy disabled>Copy</button>
            </div>
            <p class="tool-status" data-astro-status aria-live="polite">Entertainment only. Runs locally.</p>
            <pre class="tool-result" data-astro-output></pre>
          </div>
        </article>

        <article id="poem-generator" data-tool-expandable>
          <h3>Chinese Hidden Poem</h3>
          <p>Generate a Chinese acrostic or telestich poem from 2-8 Chinese chars. Odd counts are padded only at the edge.</p>
          <span class="tool-badge">AI</span>

          <div class="tool-form" data-poem-gen data-locale="en">
            <label>
              <span class="tool-label">Keyword</span>
              <input class="tool-input" data-poem-keyword type="text" inputmode="text" maxlength="8" placeholder="Chinese only, e.g. 春江花月" />
            </label>
            <label>
              <span class="tool-label">Theme (optional)</span>
              <input class="tool-input" data-poem-theme type="text" inputmode="text" maxlength="10" placeholder="Chinese only, e.g. 夜雨" />
            </label>
            <div class="tool-actions">
              <select class="tool-input" data-poem-mode style="width:auto">
                <option value="head">Acrostic</option>
                <option value="tail">Telestich</option>
              </select>
              <select class="tool-input" data-poem-line-length style="width:auto">
                <option value="5">5-char lines</option>
                <option value="7" selected>7-char lines</option>
              </select>
            </div>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-poem-generate>Generate</button>
              <button type="button" class="tool-btn-secondary" data-poem-copy disabled>Copy</button>
            </div>
            <p class="tool-status" data-poem-status aria-live="polite">Chinese only. The request uses grok-4.1-thinking.</p>
            <div class="poem-meta" data-poem-meta></div>
            <pre class="tool-result poem-output" data-poem-output></pre>
          </div>
        </article>

        <article id="pixel-avatar" data-tool-expandable>
          <h3>Pixel Avatar</h3>
          <p>Upload an image and turn it into a 32×32 pixel avatar locally. Download PNG/SVG.</p>
          <span class="tool-badge">New</span>

          <div class="tool-form" data-pixel-avatar data-locale="en">
            <label class="tool-file-btn">
              Upload image
              <input type="file" accept="image/*" data-pixel-file />
            </label>
            <div class="tool-actions">
              <label class="tool-label" style="margin-right:0.25rem">Grid</label>
              <select class="tool-input" data-pixel-grid style="width:auto">
                <option value="16">16</option>
                <option value="24">24</option>
                <option value="32" selected>32</option>
                <option value="48">48</option>
              </select>
            </div>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-pixel-random>Randomize</button>
              <button type="button" class="tool-btn-secondary" data-pixel-png>Download PNG</button>
              <button type="button" class="tool-btn-secondary" data-pixel-svg>Download SVG</button>
            </div>
            <p class="tool-status" data-pixel-status aria-live="polite">Generate a tiny avatar locally.</p>
            <div class="pixel-avatar-preview">
              <canvas data-pixel-canvas width="192" height="192"></canvas>
            </div>
          </div>
        </article>

        <article id="image-to-svg" data-tool-expandable>
          <h3>Image to SVG</h3>
          <p>Vectorize a PNG/JPG into SVG locally in your browser. Best for logos and simple illustrations.</p>
          <span class="tool-badge">New</span>

          <div class="tool-form" data-image-to-svg data-locale="en">
            <label class="tool-file-btn">
              <span data-image-to-svg-file-label>Choose image</span>
              <input type="file" accept="image/*" data-image-to-svg-file />
            </label>

            <label>
              <span class="tool-label">Preset</span>
              <select class="tool-input" data-image-to-svg-preset>
                <option value="default">default</option>
                <option value="posterized1">posterized1</option>
                <option value="posterized2" selected>posterized2</option>
                <option value="detailed">detailed</option>
                <option value="smoothed">smoothed</option>
                <option value="grayscale">grayscale</option>
              </select>
            </label>

            <label>
              <span class="tool-label">Max side (px)</span>
              <input class="tool-input" data-image-to-svg-max type="number" min="256" max="4096" step="64" value="2048" />
            </label>

            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-image-to-svg-convert>Convert</button>
              <button type="button" class="tool-btn-secondary" data-image-to-svg-copy disabled>Copy SVG</button>
              <button type="button" class="tool-btn-secondary" data-image-to-svg-download disabled>Download SVG</button>
            </div>

            <p class="tool-status" data-image-to-svg-status aria-live="polite">Tip: logos/illustrations work best. Photos may look messy.</p>

            <div class="tool-result-wrap" data-image-to-svg-wrap>
              <div class="tool-result image-to-svg-preview" data-image-to-svg-preview></div>
              <pre class="tool-result" data-image-to-svg-code></pre>
            </div>
          </div>
        </article>

      </div>
    </section>

    <section id="quick-links" class="tools-section">
      <h2>Quick Links</h2>
      <div class="tools-grid">
        <article id="doc-converter" class="tool-card">
          <h3>Document Converter</h3>
          <p>Standalone subpage version for basic md, tex, html, and docx conversions.</p>
          <span class="tool-badge">Experimental</span>
          <div class="tool-form">
            <a class="tool-btn-primary" href="/en/tools/doc-converter">Open converter</a>
            <p class="tool-status">This first release validates the subpage workflow. Complex formatting is not guaranteed yet.</p>
          </div>
        </article>

        <article id="pixelpunk-image-host" class="tool-card">
          <h3>Image Hosting / Upload</h3>
          <p>Open the PixelPunk image host to upload files fast, grab direct links, and reuse them in Markdown or webpages.</p>
          <span class="tool-badge">Hot</span>
          <div class="tool-form">
            <a class="tool-btn-primary" href="https://pic.410666.xyz" target="_blank" rel="noreferrer">Open image host</a>
            <p class="tool-status">This tool currently uses a direct external link for a cleaner and more reliable upload workflow.</p>
          </div>
        </article>

        <article id="address-generator" class="tool-card">
          <h3>Address Generator</h3>
          <p>Standalone static page for quickly generating test address profiles.</p>
          <span class="tool-badge">Experimental</span>
          <div class="tool-form">
            <a class="tool-btn-primary" href="https://address.410666.xyz" target="_blank" rel="noreferrer">Open tool</a>
            <p class="tool-status">This now opens the standalone address generator directly.</p>
          </div>
        </article>

      </div>
    </section>

    <section id="efficiency" class="tools-section">
      <h2>Productivity Tools</h2>
      <div class="tools-grid">
        <article id="timestamp-converter" data-tool-expandable>
          <h3>Timestamp Converter</h3>
          <p>Convert Unix seconds, Unix milliseconds, and ISO strings into local time, UTC, and common timezone outputs.</p>
          <span class="tool-badge">New</span>
          <div class="tool-form" data-timestamp-tool data-locale="en">
            <label>
              <span class="tool-label">Input</span>
              <textarea class="tool-textarea" data-timestamp-input placeholder="Enter Unix seconds / milliseconds / ISO time"></textarea>
            </label>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-timestamp-convert>Convert</button>
              <button type="button" class="tool-btn-secondary" data-timestamp-now>Now</button>
              <button type="button" class="tool-btn-secondary" data-timestamp-copy disabled>Copy</button>
              <button type="button" class="tool-btn-secondary" data-timestamp-clear>Clear</button>
            </div>
            <p class="tool-status" data-timestamp-status>Supports Unix seconds, milliseconds, and ISO-8601.</p>
            <label>
              <span class="tool-label">Output</span>
              <textarea class="tool-textarea" data-timestamp-output readonly></textarea>
            </label>
          </div>
        </article>

        <article id="text-processor" data-tool-expandable>
          <h3>Batch Text Processor</h3>
          <p>Clean lines, dedupe items, add prefixes or suffixes, batch replace text, and normalize case in one place.</p>
          <span class="tool-badge">New</span>
          <div class="tool-form" data-text-processor data-locale="en">
            <label>
              <span class="tool-label">Input text</span>
              <textarea class="tool-textarea" data-text-processor-input placeholder="One item per line, or paste a full block of text"></textarea>
            </label>
            <div class="tool-grid-2">
              <label><input type="checkbox" data-text-dedupe /> Remove duplicate lines</label>
              <label><input type="checkbox" data-text-remove-blank /> Remove blank lines</label>
              <label><input type="checkbox" data-text-trim /> Trim each line</label>
              <label><input type="checkbox" data-text-line-numbers /> Add line numbers</label>
            </div>
            <div class="tool-grid-2">
              <label><span class="tool-label">Prefix</span><input class="tool-input" data-text-prefix type="text" /></label>
              <label><span class="tool-label">Suffix</span><input class="tool-input" data-text-suffix type="text" /></label>
              <label><span class="tool-label">Find</span><input class="tool-input" data-text-find type="text" /></label>
              <label><span class="tool-label">Replace with</span><input class="tool-input" data-text-replace type="text" /></label>
            </div>
            <label>
              <span class="tool-label">Case</span>
              <select class="tool-input" data-text-case>
                <option value="none">No change</option>
                <option value="upper">UPPERCASE</option>
                <option value="lower">lowercase</option>
                <option value="title">Title Case</option>
              </select>
            </label>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-text-run>Process</button>
              <button type="button" class="tool-btn-secondary" data-text-copy disabled>Copy</button>
              <button type="button" class="tool-btn-secondary" data-text-clear>Clear</button>
            </div>
            <p class="tool-status" data-text-processor-status>Useful for cleaning lists, line-based text, and quick copy editing.</p>
            <label>
              <span class="tool-label">Output</span>
              <textarea class="tool-textarea" data-text-processor-output readonly></textarea>
            </label>
          </div>
        </article>

        <article id="json-toolbox" data-tool-expandable>
          <h3>JSON / YAML / TOML Toolbox</h3>
          <p>Format, validate, minify JSON, and do lightweight JSON / YAML / TOML conversions.</p>
          <span class="tool-badge">New</span>
          <div class="tool-form" data-json-toolbox data-locale="en">
            <div class="tool-grid-2">
              <label>
                <span class="tool-label">Input format</span>
                <select class="tool-input" data-json-format>
                  <option value="json">JSON</option>
                  <option value="yaml">YAML</option>
                  <option value="toml">TOML</option>
                </select>
              </label>
              <label>
                <span class="tool-label">Convert target</span>
                <select class="tool-input" data-json-convert-target>
                  <option value="json">JSON</option>
                  <option value="yaml">YAML</option>
                  <option value="toml">TOML</option>
                </select>
              </label>
            </div>
            <label>
              <span class="tool-label">Input</span>
              <textarea class="tool-textarea" data-json-input placeholder="Paste JSON / YAML / TOML here"></textarea>
            </label>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-json-format-btn>Format</button>
              <button type="button" class="tool-btn-secondary" data-json-minify-btn>Minify JSON</button>
              <button type="button" class="tool-btn-secondary" data-json-validate-btn>Validate</button>
              <button type="button" class="tool-btn-secondary" data-json-convert-btn>Convert</button>
            </div>
            <div class="tool-actions">
              <button type="button" class="tool-btn-secondary" data-json-copy disabled>Copy</button>
              <button type="button" class="tool-btn-secondary" data-json-clear>Clear</button>
            </div>
            <p class="tool-status" data-json-status>Useful for config snippets and API payload inspection.</p>
            <label>
              <span class="tool-label">Output</span>
              <textarea class="tool-textarea" data-json-output readonly></textarea>
            </label>
          </div>
        </article>

        <article id="url-toolbox" data-tool-expandable>
          <h3>URL Toolbox</h3>
          <p>Handle URL encode/decode, query parsing, Base64 decoding, JWT decoding, and URL breakdowns.</p>
          <span class="tool-badge">New</span>
          <div class="tool-form" data-url-toolbox data-locale="en">
            <label>
              <span class="tool-label">Action</span>
              <select class="tool-input" data-url-action>
                <option value="encode">URL Encode</option>
                <option value="decode">URL Decode</option>
                <option value="query">Parse Query</option>
                <option value="breakdown">Break down URL</option>
                <option value="base64">Base64 Decode</option>
                <option value="jwt">JWT Decode</option>
              </select>
            </label>
            <label>
              <span class="tool-label">Input</span>
              <textarea class="tool-textarea" data-url-input placeholder="Enter a URL, query string, Base64 value, or JWT"></textarea>
            </label>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-url-run>Run</button>
              <button type="button" class="tool-btn-secondary" data-url-copy disabled>Copy</button>
              <button type="button" class="tool-btn-secondary" data-url-clear>Clear</button>
            </div>
            <p class="tool-status" data-url-status>Useful for debugging links, params, and token payloads.</p>
            <label>
              <span class="tool-label">Output</span>
              <textarea class="tool-textarea" data-url-output readonly></textarea>
            </label>
          </div>
        </article>

        <article id="regex-tester" data-tool-expandable>
          <h3>Regex Tester</h3>
          <p>Enter a pattern, flags, and sample text to inspect matches, capture groups, and a highlighted preview.</p>
          <span class="tool-badge">New</span>
          <div class="tool-form" data-regex-tester data-locale="en">
            <div class="tool-grid-2">
              <label><span class="tool-label">Pattern</span><input class="tool-input" data-regex-pattern type="text" placeholder="e.g. \\b\\w+@\\w+\\.\\w+\\b" /></label>
              <label><span class="tool-label">Flags</span><input class="tool-input" data-regex-flags type="text" value="g" /></label>
            </div>
            <label>
              <span class="tool-label">Sample text</span>
              <textarea class="tool-textarea" data-regex-input placeholder="Enter text to test against"></textarea>
            </label>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-regex-run>Test</button>
              <button type="button" class="tool-btn-secondary" data-regex-copy disabled>Copy</button>
              <button type="button" class="tool-btn-secondary" data-regex-clear>Clear</button>
            </div>
            <p class="tool-status" data-regex-status>Quickly validate patterns and inspect groups.</p>
            <label>
              <span class="tool-label">Matches</span>
              <textarea class="tool-textarea" data-regex-output readonly></textarea>
            </label>
            <div class="tool-result tool-highlight" data-regex-highlight></div>
          </div>
        </article>

        <article id="text-redactor" data-tool-expandable>
          <h3>Sensitive Data Redactor</h3>
          <p>Mask email addresses, phone numbers, tokens, cookies, and long IDs before sharing logs or support text.</p>
          <span class="tool-badge">New</span>
          <div class="tool-form" data-text-redactor data-locale="en">
            <label>
              <span class="tool-label">Input text</span>
              <textarea class="tool-textarea" data-redactor-input placeholder="Paste raw text to redact locally"></textarea>
            </label>
            <div class="tool-grid-2">
              <label><input type="checkbox" data-redactor-email checked /> Email</label>
              <label><input type="checkbox" data-redactor-phone checked /> Phone</label>
              <label><input type="checkbox" data-redactor-token checked /> Token / key</label>
              <label><input type="checkbox" data-redactor-cookie checked /> Cookie</label>
              <label><input type="checkbox" data-redactor-ids checked /> Long IDs</label>
            </div>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-redactor-run>Redact</button>
              <button type="button" class="tool-btn-secondary" data-redactor-copy disabled>Copy</button>
              <button type="button" class="tool-btn-secondary" data-redactor-clear>Clear</button>
            </div>
            <p class="tool-status" data-redactor-status>Runs locally in the browser. Nothing is uploaded.</p>
            <label>
              <span class="tool-label">Redacted output</span>
              <textarea class="tool-textarea" data-redactor-output readonly></textarea>
            </label>
          </div>
        </article>

        <article id="random-string" data-tool-expandable>
          <h3>Random String Generator</h3>
          <p>Pick a length and generate a random string for passwords. Client-side only — nothing is uploaded.</p>
          <span class="tool-badge">New</span>

          <form class="tool-form" data-passgen-form>
            <label>
              <span class="tool-label">Length</span>
              <input class="tool-input" data-passgen-length type="number" min="4" max="128" step="1" value="16" />
            </label>

            <label>
              <span class="tool-label">Result</span>
              <input class="tool-input" data-passgen-output type="text" readonly placeholder="Click generate" />
            </label>

            <div class="tool-actions">
              <button type="submit" class="tool-btn-primary" data-passgen-generate>Generate</button>
              <button type="button" class="tool-btn-secondary" data-passgen-copy disabled>Copy</button>
            </div>

            <p class="tool-status" data-passgen-status aria-live="polite">Tip: use 16+ characters and a password manager for important accounts.</p>
          </form>
        </article>

        <article id="language-detector" data-tool-expandable>
          <h3>Language Detector</h3>
          <p>Estimate the dominant language, script distribution, and likely translation direction before translating.</p>
          <span class="tool-badge">New</span>
          <div class="tool-form" data-language-detector data-locale="en">
            <label>
              <span class="tool-label">Input text</span>
              <textarea class="tool-textarea" data-language-input placeholder="Enter any multilingual text..."></textarea>
            </label>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-language-run>Detect</button>
              <button type="button" class="tool-btn-secondary" data-language-copy disabled>Copy</button>
              <button type="button" class="tool-btn-secondary" data-language-clear>Clear</button>
            </div>
            <p class="tool-status" data-language-status>Runs locally and only analyzes character/script distribution.</p>
            <label>
              <span class="tool-label">Result</span>
              <textarea class="tool-textarea" data-language-output readonly></textarea>
            </label>
          </div>
        </article>

        <article id="text-translator" data-tool-expandable>
          <h3>Multilingual Translator</h3>
          <p>Auto-detect the source language, translate into multiple targets, and generate bilingual output for easier review.</p>
          <span class="tool-badge">New</span>

          <form class="tool-form" data-translate-form data-locale="en" data-tools-api-base={toolsApiBase}>
            <label>
              <span class="tool-label">Source text</span>
              <textarea class="tool-textarea" data-translate-input placeholder="Enter text to translate..." data-translate-preserve></textarea>
            </label>

            <div class="tool-actions">
              <label style="flex:1;min-width:120px;display:grid;gap:0.25rem;">
                <span class="tool-label">Source language</span>
                <select class="tool-input" data-translate-source></select>
              </label>
              <label style="flex:1;min-width:120px;display:grid;gap:0.25rem;">
                <span class="tool-label">Target language</span>
                <select class="tool-input" data-translate-target></select>
              </label>
            </div>

            <div class="tool-actions">
              <button type="submit" class="tool-btn-primary" data-translate-submit>Translate</button>
              <button type="button" class="tool-btn-secondary" data-translate-swap>Swap</button>
              <button type="button" class="tool-btn-secondary" data-translate-copy disabled>Copy translation</button>
              <button type="button" class="tool-btn-secondary" data-translate-copy-bilingual disabled>Copy bilingual</button>
              <button type="button" class="tool-btn-secondary" data-translate-clear>Clear</button>
            </div>

            <p class="tool-status" data-translate-status aria-live="polite">Calls translator service through a secure tools-worker proxy.</p>
            <div class="tool-status" data-translate-detected></div>

            <label>
              <span class="tool-label">Translated text</span>
              <textarea class="tool-textarea" data-translate-output readonly placeholder="Translation will appear here"></textarea>
            </label>
            <label>
              <span class="tool-label">Bilingual output</span>
              <textarea class="tool-textarea" data-translate-bilingual readonly placeholder="Source + translation will appear here"></textarea>
            </label>
          </form>
        </article>

        <!-- Image-to-SVG is a fun tool and is listed under Fun Utilities above. -->
      </div>
    </section>

    <section id="experimental" class="tools-section">
      <h2>Experimental</h2>
      <div class="tools-grid">
        <article id="clash-yaml" data-tool-expandable>
          <h3>Clash YAML Subscription Convert</h3>
          <p>Convert node/subscription content into Clash YAML. Supports vless/vmess/trojan/ss and Base64 generic subscriptions.</p>
          <span class="tool-badge">Beta</span>

          <form class="tool-form" data-clash-form data-tools-api-base={toolsApiBase}>
            <div class="tool-source-tabs" role="tablist" aria-label="Input mode">
              <button type="button" class="tool-tab is-active" data-source-tab="text">Text Input</button>
              <button type="button" class="tool-tab" data-source-tab="url">Subscription URL</button>
            </div>

            <label class="tool-label" for="clash-input-en">Paste node text or subscription content</label>
            <textarea
              id="clash-input-en"
              class="tool-textarea"
              data-clash-input
              placeholder="One vless/vmess/trojan/ss:// link per line, or paste Base64 subscription"
            ></textarea>

            <div class="tool-url-wrap" data-url-wrap hidden>
              <label class="tool-label" for="clash-source-url-en">Subscription URL</label>
              <input
                id="clash-source-url-en"
                class="tool-input"
                data-clash-source-url
                type="url"
                placeholder="https://example.com/subscription.txt"
              />
            </div>

            <div class="tool-actions">
              <label class="tool-file-btn" data-file-btn>
                Import .txt
                <input type="file" accept=".txt,text/plain" data-clash-file />
              </label>
              <button type="submit" class="tool-btn-primary" data-clash-convert>Convert</button>
              <button type="button" class="tool-btn-secondary" data-clash-clear-input>Clear input</button>
            </div>

            <p class="tool-status" data-clash-status>Supports paste, txt upload, and subscription URL. Base64 subscriptions are auto-detected and decoded.</p>

            <div class="tool-result-wrap" data-clash-result-wrap hidden>
              <pre class="tool-result" data-clash-result></pre>
              <div class="tool-actions">
                <button type="button" class="tool-btn-secondary" data-clash-copy>Copy YAML</button>
                <button type="button" class="tool-btn-secondary" data-clash-download>Download sub.yml</button>
                <button type="button" class="tool-btn-secondary" data-clash-clear-output>Clear output</button>
              </div>
            </div>
          </form>
        </article>

        <article id="ctf-desensitizer" data-tool-expandable>
          <h3>CTF Desensitizer</h3>
          <p>By default it only auto-detects allowlisted sensitive company names and replaces them with example1, example2, etc. You can also provide custom targets and reverse from mapping.</p>
          <span class="tool-badge">New</span>

          <div class="tool-form" data-ctf-desensitizer data-locale="en">
            <label>
              <span class="tool-label">Input code / text (max 5000 lines)</span>
              <textarea class="tool-textarea" data-ctf-input placeholder="Paste script or code snippet, or import a .py file"></textarea>
            </label>
            <div class="tool-actions">
              <button type="button" class="tool-btn-secondary" data-ctf-input-paste>Paste input</button>
            </div>

            <div class="tool-actions">
              <label class="tool-file-btn">
                Import .py
                <input type="file" accept=".py,.txt,text/plain" data-ctf-file />
              </label>
              <button type="button" class="tool-btn-primary" data-ctf-sanitize>Sanitize</button>
              <button type="button" class="tool-btn-secondary" data-ctf-clear>Clear</button>
              <button type="button" class="tool-btn-secondary" data-ctf-lock-toggle>Unlock</button>
            </div>

            <p class="tool-status" data-ctf-status>Runs fully in browser. No upload, no server dependency. Auto-detect defaults to an allowlist of sensitive company names.</p>

            <label>
              <span class="tool-label">Only replace these terms (one per line, optional)</span>
              <textarea class="tool-textarea" data-ctf-targets placeholder="For example:
amazon
google
openai"></textarea>
            </label>

            <label>
              <span class="tool-label">Mapping JSON (paste, edit, upload, or download)</span>
              <textarea class="tool-textarea" data-ctf-mapping-json placeholder='{
  "amazon": "example1"
}'></textarea>
            </label>

            <div class="tool-actions">
              <label class="tool-file-btn">
                Upload JSON
                <input type="file" accept=".json,application/json" data-ctf-mapping-file />
              </label>
              <button type="button" class="tool-btn-secondary" data-ctf-mapping-export>Export JSON</button>
              <button type="button" class="tool-btn-secondary" data-ctf-mapping-apply>Use JSON</button>
            </div>

            <label>
              <span class="tool-label">Output</span>
              <textarea class="tool-textarea" data-ctf-output placeholder="Transformed output appears here. You can edit it before restoring from the mapping."></textarea>
            </label>
            <div class="tool-actions">
              <button type="button" class="tool-btn-secondary" data-ctf-output-paste>Paste output</button>
              <button type="button" class="tool-btn-secondary" data-ctf-copy disabled>Copy output</button>
              <button type="button" class="tool-btn-secondary" data-ctf-download disabled>Download output</button>
              <button type="button" class="tool-btn-secondary" data-ctf-reverse>Reverse</button>
              <button type="button" class="tool-btn-secondary" data-ctf-mapping-download disabled>Download JSON</button>
            </div>
          </div>
        </article>


        <article id="temp-mail" data-tool-expandable>
          <h3>Temporary Mailbox</h3>
          <p>Create disposable inboxes quickly for one-time verification and short-lived usage.</p>
          <span class="tool-badge">Beta</span>

          <div class="tool-form" data-temp-mail data-tools-api-base={toolsApiBase}>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-temp-mail-create>Create mailbox</button>
              <button type="button" class="tool-btn-secondary" data-temp-mail-refresh>Refresh inbox</button>
              <button type="button" class="tool-btn-secondary" data-temp-mail-auto>Auto refresh: OFF</button>
            </div>

            <p class="tool-status" data-temp-mail-status>Generate a mailbox first, then refresh the inbox.</p>
            <div class="tool-mailbox-row">
              <div class="tool-mailbox" data-temp-mail-address>No mailbox yet</div>
              <button type="button" class="tool-btn-secondary" data-temp-mail-copy>Copy</button>
            </div>
            <div class="tool-result" data-temp-mail-list>No email yet</div>

            <div class="temp-mail-modal" data-temp-mail-modal hidden>
              <div class="temp-mail-modal-backdrop" data-temp-mail-close></div>
              <div class="temp-mail-modal-panel" role="dialog" aria-modal="true" aria-label="Email detail">
                <div class="temp-mail-modal-head">
                  <strong data-temp-mail-detail-subject>Email detail</strong>
                  <button type="button" class="tool-btn-secondary" data-temp-mail-close>Close</button>
                </div>
                <p class="tool-status" data-temp-mail-detail-meta></p>
                <div class="temp-mail-otp" data-temp-mail-otp-wrap hidden>
                  <span data-temp-mail-otp-text></span>
                  <button type="button" class="tool-btn-secondary" data-temp-mail-copy-otp>Copy OTP</button>
                </div>
                <div class="tool-result temp-mail-detail-content" data-temp-mail-detail-content>Loading...</div>
              </div>
            </div>
          </div>
        </article>

        <article id="vps-residual-value" data-tool-expandable>
          <h3>VPS Residual Cycle Value</h3>
          <p>Calculated only from paid amount, total cycle, and expiry date. No market or scarcity factors.</p>
          <span class="tool-badge">New</span>

          <form class="tool-form" data-vps-value-form>
            <label>
              <span class="tool-label">Paid Amount</span>
              <input class="tool-input" data-vps-paid type="number" min="0" step="0.01" placeholder="e.g. 360" />
            </label>

            <label>
              <span class="tool-label">Currency</span>
              <select class="tool-input" data-vps-currency>
                <option value="CNY">CNY (RMB)</option>
                <option value="USD">USD</option>
                <option value="GBP">GBP</option>
                <option value="EUR">EUR</option>
                <option value="HKD">HKD</option>
              </select>
            </label>

            <label>
              <span class="tool-label">Total Cycle (months)</span>
              <input class="tool-input" data-vps-total-months type="number" min="1" step="1" placeholder="e.g. 12" />
            </label>

            <label>
              <span class="tool-label">Expiry Date</span>
              <input class="tool-input" data-vps-expiry type="date" />
            </label>

            <div class="tool-actions">
              <button type="submit" class="tool-btn-primary">Calculate</button>
              <button type="button" class="tool-btn-secondary" data-vps-clear>Clear</button>
            </div>

            <p class="tool-status" data-vps-status>Formula: paid amount × (remaining cycle / total cycle)</p>

            <div class="vps-value-panel" data-vps-result hidden>
              <div class="vps-value-main" data-vps-value>--</div>
              <div class="vps-value-meta">
                <span data-vps-fx-date>FX date: --</span>
                <span data-vps-fx-rate>FX rate: --</span>
                <span data-vps-remaining>Remaining days: --</span>
                <span data-vps-ratio>Remaining ratio: --</span>
                <span data-vps-original-value>Residual in source currency: --</span>
              </div>
            </div>
          </form>
        </article>

      </div>
    </section>
  </Main>
  <div class="temp-mail-modal tool-expand-modal" data-tool-expand-modal hidden>
    <div class="temp-mail-modal-backdrop" data-tool-expand-close></div>
    <div class="temp-mail-modal-panel tool-expand-panel" role="dialog" aria-modal="true" aria-label="Tool detail">
      <div class="temp-mail-modal-head tool-expand-head">
        <strong data-tool-expand-title>Tool detail</strong>
        <button type="button" class="tool-btn-secondary" data-tool-expand-close>Close</button>
      </div>
      <div class="tool-expand-slot" data-tool-expand-slot></div>
    </div>
  </div>
  <Footer />
</Layout>

<style>
  .tools-section {
    margin-top: 1.1rem;
  }

  .tools-section h2 {
    margin-bottom: 0.7rem;
    font-size: 1.05rem;
    font-weight: 700;
  }

  .tools-grid {
    display: grid;
    gap: 0.8rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .tools-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  /* Desktop: 4 cards per row */
  @media (min-width: 900px) {
    .tools-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .tool-card {
    border: 1px solid color-mix(in oklab, var(--foreground) 15%, transparent);
    border-radius: 0.9rem;
    padding: 0.9rem;
    background: color-mix(in oklab, var(--background) 95%, transparent);
  }

  .tool-card[data-tool-expandable] {
    cursor: pointer;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .tool-card[data-tool-expandable]:hover {
    transform: translateY(-1px);
    box-shadow: 0 12px 26px rgba(15, 23, 42, 0.08);
    border-color: color-mix(in oklab, var(--accent) 25%, var(--foreground) 10%);
  }

  .tool-card[data-tool-expandable] > :not(h3):not(p):not(.tool-badge) {
    display: none;
  }

  .tool-card[data-tool-expanded="true"] {
    cursor: default;
  }

  .tool-card[data-tool-expanded="true"] > :not(h3):not(p):not(.tool-badge) {
    display: revert;
  }

  .tool-card[data-tool-expanded="true"] .tool-form,
  .tool-card[data-tool-expanded="true"] form,
  .tool-card[data-tool-expanded="true"] .vps-value-panel,
  .tool-card[data-tool-expanded="true"] .tool-result,
  .tool-card[data-tool-expanded="true"] .tool-result-wrap,
  .tool-card[data-tool-expanded="true"] .tool-mailbox-row,
  .tool-card[data-tool-expanded="true"] .tool-mailbox,
  .tool-card[data-tool-expanded="true"] .mbti-grid,
  .tool-card[data-tool-expanded="true"] .mbti-score-card,
  .tool-card[data-tool-expanded="true"] .mbti-share-title,
  .tool-card[data-tool-expanded="true"] .mbti-dimension-grid,
  .tool-card[data-tool-expanded="true"] .mbti-poster-preview,
  .tool-card[data-tool-expanded="true"] .temp-mail-modal,
  .tool-card[data-tool-expanded="true"] .temp-mail-otp,
  .tool-card[data-tool-expanded="true"] .tool-grid-2,
  .tool-card[data-tool-expanded="true"] .tool-actions,
  .tool-card[data-tool-expanded="true"] label {
    display: revert;
  }

  .tool-card[data-tool-expanded="true"] {
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  .tool-card[data-tool-expanded="true"] h3,
  .tool-card[data-tool-expanded="true"] > p,
  .tool-card[data-tool-expanded="true"] > .tool-badge {
    display: none;
  }

  .tool-card p {
    margin: 0 0 0.35rem;
    font-size: 0.95rem;
    font-weight: 700;
  }

  .tool-card p {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.45;
    color: color-mix(in oklab, var(--foreground) 80%, transparent);
  }

  .tool-form {
    margin-top: 0.65rem;
    display: grid;
    gap: 0.55rem;
  }


  .tool-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: color-mix(in oklab, var(--foreground) 78%, transparent);
  }

  .tool-source-tabs {
    display: inline-flex;
    gap: 0.35rem;
    padding: 0.2rem;
    border-radius: 0.6rem;
    border: 1px solid color-mix(in oklab, var(--foreground) 14%, transparent);
    width: fit-content;
  }

  .tool-tab {
    border: 0;
    background: transparent;
    color: color-mix(in oklab, var(--foreground) 76%, transparent);
    border-radius: 0.45rem;
    padding: 0.28rem 0.52rem;
    font-size: 0.72rem;
    cursor: pointer;
  }

  .tool-tab.is-active {
    background: color-mix(in oklab, var(--accent) 20%, transparent);
    color: var(--accent);
    font-weight: 700;
  }

  .tool-input {
    width: 100%;
    min-height: 2.75rem;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in oklab, var(--foreground) 18%, transparent);
    background: color-mix(in oklab, var(--background) 96%, transparent);
    color: var(--foreground);
    padding: 0.72rem 0.75rem;
    font-size: 0.92rem;
  }

  .tool-textarea {
    width: 100%;
    min-height: 8.5rem;
    resize: vertical;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in oklab, var(--foreground) 18%, transparent);
    background: color-mix(in oklab, var(--background) 96%, transparent);
    color: var(--foreground);
    padding: 0.78rem;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .tool-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
  }

  .tool-file-btn,
  .tool-btn-primary,
  .tool-btn-secondary {
    min-height: 2.75rem;
    border: 1px solid color-mix(in oklab, var(--foreground) 18%, transparent);
    background: color-mix(in oklab, var(--background) 95%, transparent);
    color: var(--foreground);
    border-radius: 0.72rem;
    padding: 0.65rem 0.95rem;
    font-size: 0.84rem;
    cursor: pointer;
    touch-action: manipulation;
  }

  .tool-btn-primary {
    border-color: transparent;
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
    color: #fff;
  }

  .tool-file-btn input {
    display: none;
  }

  .tool-btn-primary:disabled,
  .tool-btn-secondary:disabled,
  .tool-input:disabled,
  .tool-textarea:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .tool-status {
    margin: 0;
    font-size: 0.72rem;
    color: color-mix(in oklab, var(--foreground) 70%, transparent);
  }

  .vps-value-panel {
    border-radius: 0.75rem;
    border: 1px solid color-mix(in oklab, var(--accent) 24%, transparent);
    background: linear-gradient(135deg, color-mix(in oklab, var(--accent) 18%, var(--background) 82%), color-mix(in oklab, var(--background) 96%, transparent));
    padding: 0.72rem 0.8rem;
    display: grid;
    gap: 0.4rem;
  }

  .vps-value-main {
    font-size: 1.4rem;
    font-weight: 800;
    line-height: 1.1;
    color: var(--foreground);
  }

  .vps-value-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.9rem;
    font-size: 0.74rem;
    color: color-mix(in oklab, var(--foreground) 76%, transparent);
  }

  .tool-result-wrap {
    display: grid;
    gap: 0.45rem;
  }

  .tool-result {
    margin: 0;
    max-height: 14rem;
    overflow: auto;
    border-radius: 0.62rem;
    border: 1px solid color-mix(in oklab, var(--foreground) 14%, transparent);
    background: color-mix(in oklab, #0f172a 82%, var(--background) 18%);
    color: #e2e8f0;
    padding: 0.6rem;
    font-size: 0.71rem;
    line-height: 1.38;
  }

  .tool-mailbox {
    border-radius: 0.62rem;
    border: 1px dashed color-mix(in oklab, var(--foreground) 18%, transparent);
    padding: 0.55rem 0.6rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--foreground);
    background: color-mix(in oklab, var(--background) 97%, transparent);
  }

  .tool-mailbox-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.45rem;
    align-items: center;
  }

  .mbti-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .mbti-score-card {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: flex-start;
    flex-wrap: wrap;
    border-radius: 0.75rem;
    padding: 0.75rem 0.8rem;
    border: 1px solid color-mix(in oklab, var(--accent) 24%, transparent);
    background: linear-gradient(135deg, color-mix(in oklab, var(--accent) 18%, var(--background) 82%), color-mix(in oklab, var(--background) 96%, transparent));
  }

  .mbti-score-label {
    font-size: 0.72rem;
    color: color-mix(in oklab, var(--foreground) 70%, transparent);
  }

  .mbti-score-value {
    font-size: 1.5rem;
    font-weight: 800;
    line-height: 1;
