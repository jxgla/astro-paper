---
import DocToolPage from "@/layouts/DocToolPage.astro";

const addressToolUrl = import.meta.env.PUBLIC_ADDRESS_TOOL_URL || "";
---

<DocToolPage
  title="地址 / 虚拟身份生成器"
  desc="独立部署的地址与 mock identity 工具入口页"
  heading="地址 / 虚拟身份生成器"
  subheading="真实工具建议独立部署在 Cloudflare Worker 或 Pages，博客只保留轻量入口与安全壳层。"
>
  <div class="tool-host-shell">
    <div class="tool-host-note">
      <div>
        <strong>为什么这样更安全</strong>
        <p>把复杂前端和数据逻辑从博客主页面、工具卡片脚本和聊天链路里剥离出去，避免再次污染 `/chat` 与首页机器人运行环境。</p>
      </div>
      <div>
        <strong>推荐部署方式</strong>
        <p>将 `E:\Antigravity\address` 做成独立 Worker / Pages 应用，对外暴露自己的页面与 API；博客仅通过环境变量引用。</p>
      </div>
    </div>

    {
      addressToolUrl ? (
        <>
          <div class="tool-host-actions">
            <a class="tool-open-btn" href={addressToolUrl} target="_blank" rel="noreferrer">新窗口打开独立工具</a>
          </div>
          <iframe
            class="tool-host-frame"
            src={addressToolUrl}
            title="地址 / 虚拟身份生成器"
            loading="lazy"
            referrerpolicy="strict-origin-when-cross-origin"
            sandbox="allow-scripts allow-forms allow-downloads allow-modals allow-popups allow-same-origin"
          ></iframe>
        </>
      ) : (
        <div class="tool-host-empty">
          <strong>尚未配置独立地址工具</strong>
          <p>请在 `astro-paper/.env` 中设置 `PUBLIC_ADDRESS_TOOL_URL`，指向你部署在 Cloudflare Worker 或 Pages 的独立地址工具域名。</p>
          <p>示例：`PUBLIC_ADDRESS_TOOL_URL=https://address-tool.your-domain.pages.dev`</p>
        </div>
      )
    }
  </div>
</DocToolPage>

<style>
  .tool-host-shell {
    display: grid;
    gap: 1rem;
  }

  .tool-host-note {
    display: grid;
    gap: 0.8rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .tool-host-note > div,
  .tool-host-empty {
    border: 1px solid color-mix(in oklab, var(--foreground) 14%, transparent);
    border-radius: 0.9rem;
    padding: 0.95rem;
    background: color-mix(in oklab, var(--background) 96%, transparent);
  }

  .tool-host-note p,
  .tool-host-empty p {
    margin: 0.35rem 0 0;
    line-height: 1.7;
    font-size: 0.92rem;
  }

  .tool-host-actions {
    display: flex;
    justify-content: flex-end;
  }

  .tool-open-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: 0.75rem 1rem;
    border-radius: 0.8rem;
    text-decoration: none;
    color: white;
    font-weight: 600;
    background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 58%, #1e3a8a 100%);
    box-shadow: 0 14px 30px rgba(37, 99, 235, 0.22);
  }

  .tool-host-frame {
    width: 100%;
    min-height: 78vh;
    border: 1px solid color-mix(in oklab, var(--foreground) 14%, transparent);
    border-radius: 1rem;
    background: color-mix(in oklab, var(--background) 98%, transparent);
  }
</style>