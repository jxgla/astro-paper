---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/layouts/Main.astro";
import { SITE } from "@/config";

const toolsApiBase = import.meta.env.PUBLIC_TOOLS_API_BASE || "https://tools-worker.mehjx.workers.dev";
const addressToolUrl = import.meta.env.PUBLIC_ADDRESS_TOOL_URL || "";
---

<Layout title={`Tools | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Tools" pageDesc="实用工具集合（持续更新）" wide>
    <section id="fun" class="tools-section">
      <h2>趣味小工具</h2>
      <div class="tools-grid">
        <article id="mbti-match" class="tool-card">
          <h3>MBTI 匹配测试</h3>
          <p>看看你和 TA 是一见来电、慢热变香，还是典型的高甜高拉扯组合。</p>
          <span class="tool-badge">New</span>

          <form class="tool-form" data-mbti-form data-tools-api-base={toolsApiBase}>
            <div class="mbti-grid">
              <label>
                <span class="tool-label">你的 MBTI</span>
                <select class="tool-input" data-mbti-type-a>
                  <option value="">请选择</option>
                </select>
              </label>
              <label>
                <span class="tool-label">TA 的 MBTI</span>
                <select class="tool-input" data-mbti-type-b>
                  <option value="">请选择</option>
                </select>
              </label>
            </div>

            <div class="tool-actions">
              <button type="submit" class="tool-btn-primary" data-mbti-submit>开始分析</button>
              <button type="button" class="tool-btn-secondary" data-mbti-deep>AI 深度解读</button>
              <button type="button" class="tool-btn-secondary" data-mbti-swap>交换顺序</button>
              <button type="button" class="tool-btn-secondary" data-mbti-copy>复制结果</button>
              <button type="button" class="tool-btn-secondary" data-mbti-poster>分享卡片</button>
            </div>

            <p class="tool-status" data-mbti-status>先选两个 MBTI，马上看你们是高甜、慢热，还是越爱越容易互相气到。</p>

            <div class="tool-result-wrap" data-mbti-result-wrap hidden>
              <div class="mbti-score-card">
                <div>
                  <div class="mbti-score-label">综合匹配度</div>
                  <div class="mbti-score-value" data-mbti-overall>--</div>
                </div>
                <div>
                  <div class="mbti-pair" data-mbti-pair>-- × --</div>
                  <div class="mbti-tier" data-mbti-tier hidden></div>
                </div>
              </div>

              <div class="mbti-dimension-grid" data-mbti-dimensions></div>
              <div class="mbti-share-title" data-mbti-share-title hidden></div>

              <div class="tool-result mbti-result-block" data-mbti-result></div>
              <div class="tool-result mbti-result-block" data-mbti-deep-result hidden></div>
            </div>

            <div class="temp-mail-modal" data-mbti-poster-modal hidden>
              <div class="temp-mail-modal-backdrop" data-mbti-poster-close></div>
              <div class="temp-mail-modal-panel temp-mail-modal-panel-poster" role="dialog" aria-modal="true" aria-label="分享卡片">
                <div class="temp-mail-modal-head">
                  <strong>分享卡片</strong>
                  <button type="button" class="tool-btn-secondary" data-mbti-poster-close>关闭</button>
                </div>
                <div class="mbti-poster-preview" data-mbti-poster-preview></div>
                <div class="tool-actions">
                  <button type="button" class="tool-btn-primary" data-mbti-poster-download>下载 PNG</button>
                  <button type="button" class="tool-btn-secondary" data-mbti-poster-copy>复制文案</button>
                </div>
              </div>
            </div>
          </form>
        </article>

        <article id="emoji-dna" class="tool-card">
          <h3>Emoji DNA</h3>
          <p>粘贴聊天片段，看看你的表情气质与四维“浓度”。纯本地分析。</p>
          <span class="tool-badge">New</span>

          <div class="tool-form" data-emoji-dna data-locale="zh">
            <label>
              <span class="tool-label">聊天片段</span>
              <textarea class="tool-textarea" data-emoji-dna-input placeholder="把文本粘贴到这里…" style="min-height: 7rem"></textarea>
            </label>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-emoji-dna-analyze>开始分析</button>
              <button type="button" class="tool-btn-secondary" data-emoji-dna-copy disabled>复制结果</button>
              <button type="button" class="tool-btn-secondary" data-emoji-dna-share disabled>分享</button>
            </div>
            <p class="tool-status" data-emoji-dna-status aria-live="polite">提示：纯本地分析，不上传任何内容。</p>
            <div class="tool-result emoji-dna-top" data-emoji-dna-top></div>
            <div class="emoji-dna-bars">
              <div class="emoji-dna-row"><span>甜度</span><div class="emoji-dna-bar" data-emoji-dna-sweet></div></div>
              <div class="emoji-dna-row"><span>攻击性</span><div class="emoji-dna-bar" data-emoji-dna-spicy></div></div>
              <div class="emoji-dna-row"><span>抽象度</span><div class="emoji-dna-bar" data-emoji-dna-chaos></div></div>
              <div class="emoji-dna-row"><span>社交能量</span><div class="emoji-dna-bar" data-emoji-dna-energy></div></div>
            </div>
            <div class="tool-status">气质：<strong data-emoji-dna-vibe>--</strong></div>
            <pre class="tool-result" data-emoji-dna-summary></pre>
          </div>
        </article>

        <article id="nickname-gen" class="tool-card">
          <h3>网名生成器</h3>
          <p>选择风格，一键生成一批可用又有梗的网名。</p>
          <span class="tool-badge">New</span>

          <div class="tool-form" data-nickname-gen data-locale="zh">
            <label>
              <span class="tool-label">关键词（可选）</span>
              <input class="tool-input" data-nickname-key type="text" placeholder="例如：观者 / vibe" />
            </label>
            <label>
              <span class="tool-label">风格</span>
              <select class="tool-input" data-nickname-style>
                <option value="cyber">赛博</option>
                <option value="xianxia">仙侠</option>
                <option value="minimal">极简</option>
                <option value="japan">日系</option>
                <option value="abstract">抽象</option>
                <option value="emo">emo</option>
                <option value="biz">商务</option>
              </select>
            </label>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-nickname-generate>生成</button>
              <button type="button" class="tool-btn-secondary" data-nickname-more>再来一批</button>
              <button type="button" class="tool-btn-secondary" data-nickname-copyall disabled>复制全部</button>
            </div>
            <p class="tool-status" data-nickname-status aria-live="polite">纯本地生成，不联网。</p>
            <div class="nickname-tiles" data-nickname-list></div>
          </div>
        </article>

        <article id="astro-roast" class="tool-card">
          <h3>星座嘴替</h3>
          <p>玄学嘴替 vs 理工嘴硬：都很欠，但你会觉得很准。</p>
          <span class="tool-badge">New</span>

          <div class="tool-form" data-astro-roast data-locale="zh">
            <label>
              <span class="tool-label">生日（可选）</span>
              <input class="tool-input" data-astro-date type="date" />
            </label>
            <label>
              <span class="tool-label">星座（可选）</span>
              <select class="tool-input" data-astro-sign>
                <option value="">请选择</option>
              </select>
            </label>
            <label>
              <span class="tool-label">模式</span>
              <select class="tool-input" data-astro-mode>
                <option value="mystic">玄学嘴替</option>
                <option value="skeptic">理工嘴硬</option>
              </select>
            </label>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-astro-generate>生成</button>
              <button type="button" class="tool-btn-secondary" data-astro-copy disabled>复制</button>
            </div>
            <p class="tool-status" data-astro-status aria-live="polite">仅供娱乐，纯本地生成。</p>
            <pre class="tool-result" data-astro-output></pre>
          </div>
        </article>

        <article id="poem-generator" class="tool-card">
          <h3>藏头 / 藏尾诗</h3>
          <p>输入 2-8 个中文关键词，生成一首可直接分享的藏头或藏尾诗。奇数字数只会在首尾补成双数句。</p>
          <span class="tool-badge">AI</span>

          <div class="tool-form" data-poem-gen data-locale="zh">
            <label>
              <span class="tool-label">关键词</span>
              <input class="tool-input" data-poem-keyword type="text" inputmode="text" maxlength="8" placeholder="仅支持中文，例如：春江花月" />
            </label>
            <label>
              <span class="tool-label">意境（可选）</span>
              <input class="tool-input" data-poem-theme type="text" inputmode="text" maxlength="10" placeholder="仅支持中文，例如：夜雨" />
            </label>
            <div class="tool-actions">
              <select class="tool-input" data-poem-mode style="width:auto">
                <option value="head">藏头</option>
                <option value="tail">藏尾</option>
              </select>
              <select class="tool-input" data-poem-line-length style="width:auto">
                <option value="5">五言</option>
                <option value="7" selected>七言</option>
              </select>
            </div>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-poem-generate>生成</button>
              <button type="button" class="tool-btn-secondary" data-poem-copy disabled>复制</button>
            </div>
            <p class="tool-status" data-poem-status aria-live="polite">只支持纯中文输入，调用 grok-4.1-thinking 生成。</p>
            <div class="poem-meta" data-poem-meta></div>
            <pre class="tool-result poem-output" data-poem-output></pre>
          </div>
        </article>

        <article id="pixel-avatar" class="tool-card">
          <h3>像素头像</h3>
          <p>本地上传图片，一键转成 32×32 像素头像，支持下载 PNG / SVG。</p>
          <span class="tool-badge">New</span>

          <div class="tool-form" data-pixel-avatar data-locale="zh">
            <label class="tool-file-btn">
              上传图片
              <input type="file" accept="image/*" data-pixel-file />
            </label>
            <div class="tool-actions">
              <label class="tool-label" style="margin-right:0.25rem">网格</label>
              <select class="tool-input" data-pixel-grid style="width:auto">
                <option value="16">16</option>
                <option value="24">24</option>
                <option value="32" selected>32</option>
                <option value="48">48</option>
              </select>
            </div>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-pixel-random>随机生成</button>
              <button type="button" class="tool-btn-secondary" data-pixel-png>下载 PNG</button>
              <button type="button" class="tool-btn-secondary" data-pixel-svg>下载 SVG</button>
            </div>
            <p class="tool-status" data-pixel-status aria-live="polite">纯本地生成像素头像。</p>
            <div class="pixel-avatar-preview">
              <canvas data-pixel-canvas width="192" height="192"></canvas>
            </div>
          </div>
        </article>

        <article id="image-to-svg" class="tool-card">
          <h3>图片转 SVG</h3>
          <p>在浏览器本地把 PNG/JPG 矢量化为 SVG。更适合 Logo / 插画，照片类可能会更“碎”。</p>
          <span class="tool-badge">New</span>

          <div class="tool-form" data-image-to-svg data-locale="zh">
            <label class="tool-file-btn">
              <span data-image-to-svg-file-label>选择图片</span>
              <input type="file" accept="image/*" data-image-to-svg-file />
            </label>

            <label>
              <span class="tool-label">预设</span>
              <select class="tool-input" data-image-to-svg-preset>
                <option value="default">default</option>
                <option value="posterized1">posterized1</option>
                <option value="posterized2" selected>posterized2</option>
                <option value="detailed">detailed</option>
                <option value="smoothed">smoothed</option>
                <option value="grayscale">grayscale</option>
              </select>
            </label>

            <label>
              <span class="tool-label">最长边（px）</span>
              <input class="tool-input" data-image-to-svg-max type="number" min="256" max="4096" step="64" value="2048" />
            </label>

            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-image-to-svg-convert>转换</button>
              <button type="button" class="tool-btn-secondary" data-image-to-svg-copy disabled>复制 SVG</button>
              <button type="button" class="tool-btn-secondary" data-image-to-svg-download disabled>下载 SVG</button>
            </div>

            <p class="tool-status" data-image-to-svg-status aria-live="polite">提示：Logo/插画效果最好；照片类可能会比较“碎”。</p>

            <div class="tool-result-wrap" data-image-to-svg-wrap>
              <div class="tool-result image-to-svg-preview" data-image-to-svg-preview></div>
              <pre class="tool-result" data-image-to-svg-code></pre>
            </div>
          </div>
        </article>

      </div>
    </section>

    <section id="efficiency" class="tools-section">
      <h2>效率工具</h2>
      <div class="tools-grid">
        <div class="tool-link-stack">
          <article id="doc-converter" class="tool-card tool-card-compact">
            <h3>文档格式转换</h3>
            <p>独立子页面版本，支持 md、tex、html、docx 的基础互转。</p>
            <div class="tool-link-meta">
              <span class="tool-badge">Experimental</span>
              <a class="tool-btn-primary tool-btn-compact" href="/tools/doc-converter">打开转换器</a>
            </div>
            <p class="tool-status">当前优先验证独立子页面链路，复杂格式暂不保证完全保真。</p>
          </article>

          <article id="pixelpunk-image-host" class="tool-card tool-card-compact">
            <h3>图床 / 图片上传</h3>
            <p>直达 PixelPunk 图床，适合快速上传图片、获取外链并用于 Markdown 或网页引用。</p>
            <div class="tool-link-meta">
              <span class="tool-badge">Hot</span>
              <a class="tool-btn-primary tool-btn-compact" href="https://pic.410666.xyz" target="_blank" rel="noreferrer">打开图床</a>
            </div>
            <p class="tool-status">当前采用独立站直链接入，上传、管理与外链复制体验更稳定。</p>
          </article>
        </div>

        <article id="timestamp-converter" class="tool-card">
          <h3>时间戳转换器</h3>
          <p>支持 Unix 秒、毫秒和 ISO 时间互转，并输出本地时间、UTC 与常用时区结果。</p>
          <span class="tool-badge">New</span>
          <div class="tool-form" data-timestamp-tool data-locale="zh">
            <label>
              <span class="tool-label">输入</span>
              <textarea class="tool-textarea" data-timestamp-input placeholder="输入 Unix 秒 / Unix 毫秒 / ISO 时间"></textarea>
            </label>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-timestamp-convert>转换</button>
              <button type="button" class="tool-btn-secondary" data-timestamp-now>现在</button>
              <button type="button" class="tool-btn-secondary" data-timestamp-copy disabled>复制结果</button>
              <button type="button" class="tool-btn-secondary" data-timestamp-clear>清空</button>
            </div>
            <p class="tool-status" data-timestamp-status>支持秒、毫秒和 ISO8601。</p>
            <label>
              <span class="tool-label">结果</span>
              <textarea class="tool-textarea" data-timestamp-output readonly></textarea>
            </label>
          </div>
        </article>

        <article id="text-processor" class="tool-card">
          <h3>批量文本处理器</h3>
          <p>适合去重、去空行、加前后缀、批量替换、大小写转换和行号整理。</p>
          <span class="tool-badge">New</span>
          <div class="tool-form" data-text-processor data-locale="zh">
            <label>
              <span class="tool-label">输入文本</span>
              <textarea class="tool-textarea" data-text-processor-input placeholder="每行一项，或粘贴整段文本"></textarea>
            </label>
            <div class="tool-grid-2">
              <label><input type="checkbox" data-text-dedupe /> 去重行</label>
              <label><input type="checkbox" data-text-remove-blank /> 去空行</label>
              <label><input type="checkbox" data-text-trim /> trim 每行</label>
              <label><input type="checkbox" data-text-line-numbers /> 添加行号</label>
            </div>
            <div class="tool-grid-2">
              <label><span class="tool-label">前缀</span><input class="tool-input" data-text-prefix type="text" /></label>
              <label><span class="tool-label">后缀</span><input class="tool-input" data-text-suffix type="text" /></label>
              <label><span class="tool-label">查找</span><input class="tool-input" data-text-find type="text" /></label>
              <label><span class="tool-label">替换为</span><input class="tool-input" data-text-replace type="text" /></label>
            </div>
            <label>
              <span class="tool-label">大小写</span>
              <select class="tool-input" data-text-case>
                <option value="none">不转换</option>
                <option value="upper">UPPERCASE</option>
                <option value="lower">lowercase</option>
                <option value="title">Title Case</option>
              </select>
            </label>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-text-run>处理</button>
              <button type="button" class="tool-btn-secondary" data-text-copy disabled>复制结果</button>
              <button type="button" class="tool-btn-secondary" data-text-clear>清空</button>
            </div>
            <p class="tool-status" data-text-processor-status>适合清理列表、文案和批量行文本。</p>
            <label>
              <span class="tool-label">结果</span>
              <textarea class="tool-textarea" data-text-processor-output readonly></textarea>
            </label>
          </div>
        </article>

        <article id="json-toolbox" class="tool-card">
          <h3>JSON / YAML / TOML 工具箱</h3>
          <p>格式化、校验、JSON 压缩，并支持 JSON / YAML / TOML 之间的基础转换。</p>
          <span class="tool-badge">New</span>
          <div class="tool-form" data-json-toolbox data-locale="zh">
            <div class="tool-grid-2">
              <label>
                <span class="tool-label">输入格式</span>
                <select class="tool-input" data-json-format>
                  <option value="json">JSON</option>
                  <option value="yaml">YAML</option>
                  <option value="toml">TOML</option>
                </select>
              </label>
              <label>
                <span class="tool-label">转换目标</span>
                <select class="tool-input" data-json-convert-target>
                  <option value="json">JSON</option>
                  <option value="yaml">YAML</option>
                  <option value="toml">TOML</option>
                </select>
              </label>
            </div>
            <label>
              <span class="tool-label">输入</span>
              <textarea class="tool-textarea" data-json-input placeholder="粘贴 JSON / YAML / TOML"></textarea>
            </label>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-json-format-btn>格式化</button>
              <button type="button" class="tool-btn-secondary" data-json-minify-btn>压缩 JSON</button>
              <button type="button" class="tool-btn-secondary" data-json-validate-btn>校验</button>
              <button type="button" class="tool-btn-secondary" data-json-convert-btn>转换</button>
            </div>
            <div class="tool-actions">
              <button type="button" class="tool-btn-secondary" data-json-copy disabled>复制结果</button>
              <button type="button" class="tool-btn-secondary" data-json-clear>清空</button>
            </div>
            <p class="tool-status" data-json-status>适合结构化配置和接口返回调试。</p>
            <label>
              <span class="tool-label">结果</span>
              <textarea class="tool-textarea" data-json-output readonly></textarea>
            </label>
          </div>
        </article>

        <article id="url-toolbox" class="tool-card">
          <h3>URL 工具箱</h3>
          <p>支持 URL 编解码、Query 解析、Base64 解码、JWT 解码和 URL 结构拆解。</p>
          <span class="tool-badge">New</span>
          <div class="tool-form" data-url-toolbox data-locale="zh">
            <label>
              <span class="tool-label">操作</span>
              <select class="tool-input" data-url-action>
                <option value="encode">URL Encode</option>
                <option value="decode">URL Decode</option>
                <option value="query">解析 Query</option>
                <option value="breakdown">拆解 URL</option>
                <option value="base64">Base64 Decode</option>
                <option value="jwt">JWT Decode</option>
              </select>
            </label>
            <label>
              <span class="tool-label">输入</span>
              <textarea class="tool-textarea" data-url-input placeholder="输入 URL / Query / Base64 / JWT"></textarea>
            </label>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-url-run>处理</button>
              <button type="button" class="tool-btn-secondary" data-url-copy disabled>复制结果</button>
              <button type="button" class="tool-btn-secondary" data-url-clear>清空</button>
            </div>
            <p class="tool-status" data-url-status>适合调试链接、参数和 token。</p>
            <label>
              <span class="tool-label">结果</span>
              <textarea class="tool-textarea" data-url-output readonly></textarea>
            </label>
          </div>
        </article>

        <article id="regex-tester" class="tool-card">
          <h3>正则测试器</h3>
          <p>输入 pattern、flags 和测试文本，即时查看匹配结果、捕获组和高亮预览。</p>
          <span class="tool-badge">New</span>
          <div class="tool-form" data-regex-tester data-locale="zh">
            <div class="tool-grid-2">
              <label><span class="tool-label">Pattern</span><input class="tool-input" data-regex-pattern type="text" placeholder="例如 \\b\\w+@\\w+\\.\\w+\\b" /></label>
              <label><span class="tool-label">Flags</span><input class="tool-input" data-regex-flags type="text" value="g" /></label>
            </div>
            <label>
              <span class="tool-label">测试文本</span>
              <textarea class="tool-textarea" data-regex-input placeholder="输入要匹配的文本"></textarea>
            </label>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-regex-run>测试</button>
              <button type="button" class="tool-btn-secondary" data-regex-copy disabled>复制结果</button>
              <button type="button" class="tool-btn-secondary" data-regex-clear>清空</button>
            </div>
            <p class="tool-status" data-regex-status>适合快速验证表达式和提取逻辑。</p>
            <label>
              <span class="tool-label">匹配结果</span>
              <textarea class="tool-textarea" data-regex-output readonly></textarea>
            </label>
            <div class="tool-result tool-highlight" data-regex-highlight></div>
          </div>
        </article>

        <article id="text-redactor" class="tool-card">
          <h3>敏感信息脱敏器</h3>
          <p>自动脱敏邮箱、手机号、token、cookie 和长 ID 串，生成适合贴工单或发群聊的文本。</p>
          <span class="tool-badge">New</span>
          <div class="tool-form" data-text-redactor data-locale="zh">
            <label>
              <span class="tool-label">输入文本</span>
              <textarea class="tool-textarea" data-redactor-input placeholder="粘贴原始文本，工具会在本地脱敏"></textarea>
            </label>
            <div class="tool-grid-2">
              <label><input type="checkbox" data-redactor-email checked /> 邮箱</label>
              <label><input type="checkbox" data-redactor-phone checked /> 手机号</label>
              <label><input type="checkbox" data-redactor-token checked /> token / key</label>
              <label><input type="checkbox" data-redactor-cookie checked /> cookie</label>
              <label><input type="checkbox" data-redactor-ids checked /> 长 ID 串</label>
            </div>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-redactor-run>脱敏</button>
              <button type="button" class="tool-btn-secondary" data-redactor-copy disabled>复制结果</button>
              <button type="button" class="tool-btn-secondary" data-redactor-clear>清空</button>
            </div>
            <p class="tool-status" data-redactor-status>纯前端处理，不上传任何文本。</p>
            <label>
              <span class="tool-label">脱敏结果</span>
              <textarea class="tool-textarea" data-redactor-output readonly></textarea>
            </label>
          </div>
        </article>

        <article id="random-string" class="tool-card">
          <h3>随机字符串生成器</h3>
          <p>选择长度，一键生成随机字符串，用作随机密码。纯前端生成，不上传、不走后端。</p>
          <span class="tool-badge">New</span>

          <form class="tool-form" data-passgen-form>
            <label>
              <span class="tool-label">长度</span>
              <input class="tool-input" data-passgen-length type="number" min="4" max="128" step="1" value="16" />
            </label>

            <label>
              <span class="tool-label">生成结果</span>
              <input class="tool-input" data-passgen-output type="text" readonly placeholder="点击生成" />
            </label>

            <div class="tool-actions">
              <button type="submit" class="tool-btn-primary" data-passgen-generate>生成</button>
              <button type="button" class="tool-btn-secondary" data-passgen-copy disabled>复制</button>
            </div>

            <p class="tool-status" data-passgen-status aria-live="polite">建议长度 16+，并在重要场景配合密码管理器。</p>
          </form>
        </article>

        <article id="language-detector" class="tool-card">
          <h3>语言检测器</h3>
          <p>快速判断文本主要语言、脚本占比和推荐翻译方向，适合作为翻译前置判断。</p>
          <span class="tool-badge">New</span>
          <div class="tool-form" data-language-detector data-locale="zh">
            <label>
              <span class="tool-label">输入文本</span>
              <textarea class="tool-textarea" data-language-input placeholder="输入任意多语言文本..."></textarea>
            </label>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-language-run>检测</button>
              <button type="button" class="tool-btn-secondary" data-language-copy disabled>复制结果</button>
              <button type="button" class="tool-btn-secondary" data-language-clear>清空</button>
            </div>
            <p class="tool-status" data-language-status>本地分析字符分布，不上传文本。</p>
            <label>
              <span class="tool-label">检测结果</span>
              <textarea class="tool-textarea" data-language-output readonly></textarea>
            </label>
          </div>
        </article>

        <article id="text-translator" class="tool-card">
          <h3>多语言翻译</h3>
          <p>支持自动检测源语言、多目标语言翻译，并可输出对照文本方便复制和比对。</p>
          <span class="tool-badge">New</span>

          <form class="tool-form" data-translate-form data-locale="zh" data-tools-api-base={toolsApiBase}>
            <label>
              <span class="tool-label">原文</span>
              <textarea class="tool-textarea" data-translate-input placeholder="输入要翻译的内容..." data-translate-preserve></textarea>
            </label>

            <div class="tool-actions">
              <label style="flex:1;min-width:120px;display:grid;gap:0.25rem;">
                <span class="tool-label">源语言</span>
                <select class="tool-input" data-translate-source></select>
              </label>
              <label style="flex:1;min-width:120px;display:grid;gap:0.25rem;">
                <span class="tool-label">目标语言</span>
                <select class="tool-input" data-translate-target></select>
              </label>
            </div>

            <div class="tool-actions">
              <button type="submit" class="tool-btn-primary" data-translate-submit>翻译</button>
              <button type="button" class="tool-btn-secondary" data-translate-swap>交换</button>
              <button type="button" class="tool-btn-secondary" data-translate-copy disabled>复制译文</button>
              <button type="button" class="tool-btn-secondary" data-translate-copy-bilingual disabled>复制双语</button>
              <button type="button" class="tool-btn-secondary" data-translate-clear>清空</button>
            </div>

            <p class="tool-status" data-translate-status aria-live="polite">通过 tools-worker 安全代理调用翻译服务。</p>
            <div class="tool-status" data-translate-detected></div>

            <label>
              <span class="tool-label">译文</span>
              <textarea class="tool-textarea" data-translate-output readonly placeholder="翻译结果会显示在这里"></textarea>
            </label>
            <label>
              <span class="tool-label">双语对照</span>
              <textarea class="tool-textarea" data-translate-bilingual readonly placeholder="原文与译文对照会显示在这里"></textarea>
            </label>
          </form>
        </article>

        <!-- 图片转 SVG 归类为趣味小工具，见上方 Fun 区域。 -->
      </div>
    </section>

    <section id="experimental" class="tools-section">
      <h2>实验工具</h2>
      <div class="tools-grid">
        <article id="clash-yaml" class="tool-card">
          <h3>Clash YAML 订阅转换</h3>
          <p>将节点/订阅内容转换为 Clash YAML 订阅格式，支持 vless/vmess/trojan/ss 以及 Base64 通用订阅。</p>
          <span class="tool-badge">Beta</span>

          <form class="tool-form" data-clash-form data-tools-api-base={toolsApiBase}>
            <div class="tool-source-tabs" role="tablist" aria-label="输入模式">
              <button type="button" class="tool-tab is-active" data-source-tab="text">文本输入</button>
              <button type="button" class="tool-tab" data-source-tab="url">订阅链接</button>
            </div>

            <label class="tool-label" for="clash-input-zh">输入节点文本或订阅内容</label>
            <textarea
              id="clash-input-zh"
              class="tool-textarea"
              data-clash-input
              placeholder="每行一条 vless/vmess/trojan/ss://...\n或直接粘贴 Base64 通用订阅"
            ></textarea>

            <div class="tool-url-wrap" data-url-wrap hidden>
              <label class="tool-label" for="clash-source-url-zh">订阅链接 URL</label>
              <input
                id="clash-source-url-zh"
                class="tool-input"
                data-clash-source-url
                type="url"
                placeholder="https://example.com/subscription.txt"
              />
            </div>

            <div class="tool-actions">
              <label class="tool-file-btn" data-file-btn>
                导入 .txt
                <input type="file" accept=".txt,text/plain" data-clash-file />
              </label>
              <button type="submit" class="tool-btn-primary" data-clash-convert>转换</button>
              <button type="button" class="tool-btn-secondary" data-clash-clear-input>清除输入</button>
            </div>

            <p class="tool-status" data-clash-status>支持粘贴、txt 上传或订阅链接；可直接粘贴 Base64 通用订阅（自动识别解码）。</p>

            <div class="tool-result-wrap" data-clash-result-wrap hidden>
              <pre class="tool-result" data-clash-result></pre>
              <div class="tool-actions">
                <button type="button" class="tool-btn-secondary" data-clash-copy>复制 YAML</button>
                <button type="button" class="tool-btn-secondary" data-clash-download>下载 sub.yml</button>
                <button type="button" class="tool-btn-secondary" data-clash-clear-output>清除输出</button>
              </div>
            </div>
          </form>
        </article>

        <article id="address-generator" class="tool-card">
          <h3>地址生成器</h3>
          <p>独立静态页面，适合快速生成测试用地址资料。</p>
          <span class="tool-badge">Experimental</span>
          <div class="tool-form">
            <a class="tool-btn-primary" href={addressToolUrl || "https://address.410666.xyz"} target="_blank" rel="noreferrer">
              打开工具
            </a>
            <p class="tool-status">
              {addressToolUrl
                ? "当前直接跳转到独立地址生成器。"
                : "未配置环境变量时将使用默认独立域名。"}
            </p>
          </div>
        </article>

        <article id="temp-mail" class="tool-card">
          <h3>临时邮箱</h3>
          <p>快速生成临时邮箱用于注册验证与一次性收件场景。</p>
          <span class="tool-badge">Beta</span>

          <div class="tool-form" data-temp-mail data-tools-api-base={toolsApiBase}>
            <div class="tool-actions">
              <button type="button" class="tool-btn-primary" data-temp-mail-create>生成邮箱</button>
              <button type="button" class="tool-btn-secondary" data-temp-mail-refresh>刷新收件箱</button>
              <button type="button" class="tool-btn-secondary" data-temp-mail-auto>自动刷新：开</button>
            </div>

            <p class="tool-status" data-temp-mail-status>点击生成临时邮箱后即可开始收件。</p>
            <div class="tool-mailbox-row">
              <div class="tool-mailbox" data-temp-mail-address>尚未生成邮箱</div>
              <button type="button" class="tool-btn-secondary" data-temp-mail-copy>复制邮箱</button>
            </div>
            <div class="tool-result" data-temp-mail-list>暂无邮件</div>

            <div class="temp-mail-modal" data-temp-mail-modal hidden>
              <div class="temp-mail-modal-backdrop" data-temp-mail-close></div>
              <div class="temp-mail-modal-panel" role="dialog" aria-modal="true" aria-label="邮件详情">
                <div class="temp-mail-modal-head">
                  <strong data-temp-mail-detail-subject>邮件详情</strong>
                  <button type="button" class="tool-btn-secondary" data-temp-mail-close>关闭</button>
                </div>
                <p class="tool-status" data-temp-mail-detail-meta></p>
                <div class="temp-mail-otp" data-temp-mail-otp-wrap hidden>
                  <span data-temp-mail-otp-text></span>
                  <button type="button" class="tool-btn-secondary" data-temp-mail-copy-otp>复制验证码</button>
                </div>
                <div class="tool-result temp-mail-detail-content" data-temp-mail-detail-content>加载中...</div>
              </div>
            </div>
          </div>
        </article>

        <article id="vps-residual-value" class="tool-card">
          <h3>VPS 剩余周期价值</h3>
          <p>仅按已支付金额、总周期与到期时间计算剩余价值，不引入市场比价或人为系数。</p>
          <span class="tool-badge">New</span>

          <form class="tool-form" data-vps-value-form>
            <label>
              <span class="tool-label">支付金额</span>
              <input class="tool-input" data-vps-paid type="number" min="0" step="0.01" placeholder="例如 360" />
            </label>

            <label>
              <span class="tool-label">支付币种</span>
              <select class="tool-input" data-vps-currency>
                <option value="CNY">人民币 CNY</option>
                <option value="USD">美元 USD</option>
                <option value="GBP">英镑 GBP</option>
                <option value="EUR">欧元 EUR</option>
                <option value="HKD">港币 HKD</option>
              </select>
            </label>

            <label>
              <span class="tool-label">总周期（月）</span>
              <input class="tool-input" data-vps-total-months type="number" min="1" step="1" placeholder="例如 12" />
            </label>

            <label>
              <span class="tool-label">到期时间</span>
              <input class="tool-input" data-vps-expiry type="date" />
            </label>

            <div class="tool-actions">
              <button type="submit" class="tool-btn-primary">计算</button>
              <button type="button" class="tool-btn-secondary" data-vps-clear>清空</button>
            </div>

            <p class="tool-status" data-vps-status>按公式：支付金额 × (剩余周期 / 总周期)</p>

            <div class="vps-value-panel" data-vps-result hidden>
              <div class="vps-value-main" data-vps-value>--</div>
              <div class="vps-value-meta">
                <span data-vps-fx-date>汇率日期：--</span>
                <span data-vps-fx-rate>外币汇率：--</span>
                <span data-vps-remaining>剩余天数：--</span>
                <span data-vps-ratio>剩余占比：--</span>
                <span data-vps-original-value>原币剩余：--</span>
              </div>
            </div>
          </form>
        </article>

      </div>
    </section>
  </Main>
  <Footer />
</Layout>

<style>
  .tools-section {
    margin-top: 1.1rem;
  }

  .tools-section h2 {
    margin-bottom: 0.7rem;
    font-size: 1.05rem;
    font-weight: 700;
  }

  .tools-grid {
    display: grid;
    gap: 0.8rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .tools-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  /* Desktop: 4 cards per row */
  @media (min-width: 900px) {
    .tools-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .tool-card {
    border: 1px solid color-mix(in oklab, var(--foreground) 15%, transparent);
    border-radius: 0.9rem;
    padding: 0.9rem;
    background: color-mix(in oklab, var(--background) 95%, transparent);
  }

  .tool-card h3 {
    margin: 0 0 0.35rem;
    font-size: 0.95rem;
    font-weight: 700;
  }

  .tool-card p {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.45;
    color: color-mix(in oklab, var(--foreground) 80%, transparent);
  }

  .tool-form {
    margin-top: 0.65rem;
    display: grid;
    gap: 0.55rem;
  }

  .tool-link-stack {
    display: grid;
    gap: 0.7rem;
    align-content: start;
  }

  .tool-card-compact {
    padding: 0.8rem 0.85rem;
  }

  .tool-card-compact h3 {
    margin-bottom: 0.25rem;
  }

  .tool-card-compact .tool-status {
    margin-top: 0.45rem;
  }

  .tool-link-meta {
    margin-top: 0.55rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .tool-btn-compact {
    min-height: 2.35rem;
    padding: 0.6rem 0.9rem;
    width: auto;
  }

  .tool-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: color-mix(in oklab, var(--foreground) 78%, transparent);
  }

  .tool-source-tabs {
    display: inline-flex;
    gap: 0.35rem;
    padding: 0.2rem;
    border-radius: 0.6rem;
    border: 1px solid color-mix(in oklab, var(--foreground) 14%, transparent);
    width: fit-content;
  }

  .tool-tab {
    border: 0;
    background: transparent;
    color: color-mix(in oklab, var(--foreground) 76%, transparent);
    border-radius: 0.45rem;
    padding: 0.28rem 0.52rem;
    font-size: 0.72rem;
    cursor: pointer;
  }

  .tool-tab.is-active {
    background: color-mix(in oklab, var(--accent) 20%, transparent);
    color: var(--accent);
    font-weight: 700;
  }

  .tool-input {
    width: 100%;
    min-height: 2.75rem;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in oklab, var(--foreground) 18%, transparent);
    background: color-mix(in oklab, var(--background) 96%, transparent);
    color: var(--foreground);
    padding: 0.72rem 0.75rem;
    font-size: 0.92rem;
  }

  .tool-textarea {
    width: 100%;
    min-height: 8.5rem;
    resize: vertical;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in oklab, var(--foreground) 18%, transparent);
    background: color-mix(in oklab, var(--background) 96%, transparent);
    color: var(--foreground);
    padding: 0.78rem;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .tool-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
  }

  .tool-file-btn,
  .tool-btn-primary,
  .tool-btn-secondary {
    min-height: 2.75rem;
    border: 1px solid color-mix(in oklab, var(--foreground) 18%, transparent);
    background: color-mix(in oklab, var(--background) 95%, transparent);
    color: var(--foreground);
    border-radius: 0.72rem;
    padding: 0.65rem 0.95rem;
    font-size: 0.84rem;
    cursor: pointer;
    touch-action: manipulation;
  }

  .tool-btn-primary {
    border-color: transparent;
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
    color: #fff;
  }

  .tool-file-btn input {
    display: none;
  }

  .tool-btn-primary:disabled,
  .tool-btn-secondary:disabled,
  .tool-input:disabled,
  .tool-textarea:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .tool-status {
    margin: 0;
    font-size: 0.72rem;
    color: color-mix(in oklab, var(--foreground) 70%, transparent);
  }

  .vps-value-panel {
    border-radius: 0.75rem;
    border: 1px solid color-mix(in oklab, var(--accent) 24%, transparent);
    background: linear-gradient(135deg, color-mix(in oklab, var(--accent) 18%, var(--background) 82%), color-mix(in oklab, var(--background) 96%, transparent));
    padding: 0.72rem 0.8rem;
    display: grid;
    gap: 0.4rem;
  }

  .vps-value-main {
    font-size: 1.4rem;
    font-weight: 800;
    line-height: 1.1;
    color: var(--foreground);
  }

  .vps-value-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.9rem;
    font-size: 0.74rem;
    color: color-mix(in oklab, var(--foreground) 76%, transparent);
  }

  .tool-result-wrap {
    display: grid;
    gap: 0.45rem;
  }

  .tool-result {
    margin: 0;
    max-height: 14rem;
    overflow: auto;
    border-radius: 0.62rem;
    border: 1px solid color-mix(in oklab, var(--foreground) 14%, transparent);
    background: color-mix(in oklab, #0f172a 82%, var(--background) 18%);
    color: #e2e8f0;
    padding: 0.6rem;
    font-size: 0.71rem;
    line-height: 1.38;
  }

  .tool-mailbox {
    border-radius: 0.62rem;
    border: 1px dashed color-mix(in oklab, var(--foreground) 18%, transparent);
    padding: 0.55rem 0.6rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--foreground);
    background: color-mix(in oklab, var(--background) 97%, transparent);
  }

  .tool-mailbox-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.45rem;
    align-items: center;
  }

  .mbti-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .mbti-score-card {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: flex-start;
    flex-wrap: wrap;
    border-radius: 0.75rem;
    padding: 0.75rem 0.8rem;
    border: 1px solid color-mix(in oklab, var(--accent) 24%, transparent);
    background: linear-gradient(135deg, color-mix(in oklab, var(--accent) 18%, var(--background) 82%), color-mix(in oklab, var(--background) 96%, transparent));
  }

  .mbti-score-label {
    font-size: 0.72rem;
    color: color-mix(in oklab, var(--foreground) 70%, transparent);
  }

  .mbti-score-value {
    font-size: 1.5rem;
    font-weight: 800;
    line-height: 1;
  }

  .mbti-pair {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--accent);
  }

  .mbti-tier {
    margin-top: 0.35rem;
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    border-radius: 999px;
    padding: 0.18rem 0.52rem;
