<script>
  // @ts-nocheck
  const CLASH_API_PATH = "/api/tools/clash-yaml-convert";

  function initClashTool() {
    const form = document.querySelector("[data-clash-form]");
    if (!(form instanceof HTMLFormElement)) return;
    if (form.dataset.inited === "1") return;
    form.dataset.inited = "1";

    const input = form.querySelector("[data-clash-input]");
    const fileInput = form.querySelector("[data-clash-file]");
    const status = form.querySelector("[data-clash-status]");
    const resultWrap = form.querySelector("[data-clash-result-wrap]");
    const resultEl = form.querySelector("[data-clash-result]");
    const copyBtn = form.querySelector("[data-clash-copy]");
    const downloadBtn = form.querySelector("[data-clash-download]");
    const convertBtn = form.querySelector("[data-clash-convert]");
    const clearInputBtn = form.querySelector("[data-clash-clear-input]");
    const clearOutputBtn = form.querySelector("[data-clash-clear-output]");
    const sourceUrlInput = form.querySelector("[data-clash-source-url]");
    const tabs = form.querySelectorAll("[data-source-tab]");
    const urlWrap = form.querySelector("[data-url-wrap]");
    const fileBtn = form.querySelector("[data-file-btn]");

    if (!(input instanceof HTMLTextAreaElement)) return;
    if (!(fileInput instanceof HTMLInputElement)) return;
    if (!(status instanceof HTMLElement)) return;
    if (!(resultWrap instanceof HTMLElement)) return;
    if (!(resultEl instanceof HTMLElement)) return;
    if (!(copyBtn instanceof HTMLButtonElement)) return;
    if (!(downloadBtn instanceof HTMLButtonElement)) return;
    if (!(convertBtn instanceof HTMLButtonElement)) return;
    if (!(clearInputBtn instanceof HTMLButtonElement)) return;
    if (!(clearOutputBtn instanceof HTMLButtonElement)) return;
    if (!(sourceUrlInput instanceof HTMLInputElement)) return;
    if (!(urlWrap instanceof HTMLElement)) return;
    if (!(fileBtn instanceof HTMLElement)) return;

    const apiBase = (form.dataset.toolsApiBase || "").replace(/\/$/, "");
    const apiUrl = `${apiBase}${CLASH_API_PATH}`;
    let latestYaml = "";
    let busy = false;
    let sourceMode = "text";

    const syncSourceMode = () => {
      const isUrl = sourceMode === "url";
      urlWrap.hidden = !isUrl;
      input.hidden = isUrl;
      fileBtn.hidden = isUrl;
      tabs.forEach(btn => {
        if (!(btn instanceof HTMLButtonElement)) return;
        btn.classList.toggle("is-active", btn.dataset.sourceTab === sourceMode);
      });
    };

    syncSourceMode();

    const setBusy = (next: boolean) => {
      busy = next;
      convertBtn.disabled = busy;
      input.disabled = busy;
      fileInput.disabled = busy;
      sourceUrlInput.disabled = busy;
    };

    const autoDetectMode = (rawText: string) => {
      const text = String(rawText || "").trim();
      if (!text) return;
      const looksLikeUrl = /^https?:\/\//i.test(text) && !text.includes("\n");
      const hasVless = /vless:\/\//i.test(text);
      sourceMode = looksLikeUrl && !hasVless ? "url" : "text";
      if (sourceMode === "url") {
        sourceUrlInput.value = text;
      }
      syncSourceMode();
    };

    tabs.forEach(btn => {
      if (!(btn instanceof HTMLButtonElement)) return;
      btn.addEventListener("click", () => {
        sourceMode = btn.dataset.sourceTab === "url" ? "url" : "text";
        syncSourceMode();
      });
    });

    fileInput.addEventListener("change", async () => {
      const file = fileInput.files?.[0];
      if (!file) return;
      const text = await file.text();
      input.value = text;
      autoDetectMode(text);
      status.textContent = `已导入 ${file.name}`;
    });

    input.addEventListener("paste", e => {
      const t = e.clipboardData?.getData("text") || "";
      if (t) autoDetectMode(t);
    });

    form.addEventListener("submit", async e => {
      e.preventDefault();
      if (busy) return;
      const text = input.value.trim();
      const sourceUrl = sourceUrlInput.value.trim();
      if (sourceMode === "text" && !text) {
        status.textContent = "请先输入节点文本。";
        return;
      }
      if (sourceMode === "url" && !sourceUrl) {
        status.textContent = "请先输入订阅链接 URL。";
        return;
      }

      try {
        setBusy(true);
        status.textContent = "正在转换...";

        const res = await fetch(apiUrl, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(
            sourceMode === "url"
              ? { sourceType: "url", sourceUrl }
              : { sourceType: "text", inputText: text }
          ),
        });

        const data = await res.json().catch(() => ({}));

        if (!res.ok || !data?.ok) {
          const rid = data?.requestId ? `（请求ID: ${data.requestId}）` : "";
          status.textContent = data?.error ? `转换失败：${data.error}${rid}` : `转换失败：HTTP ${res.status}${rid}`;
          return;
        }

        latestYaml = String(data.yaml || "");
        resultEl.textContent = latestYaml;
        resultWrap.hidden = false;
        status.textContent = `转换成功：${data.nodes ?? 0} 条，失败 ${data.failed ?? 0} 条${data.requestId ? `（请求ID: ${data.requestId}）` : ""}`;
      } catch (err: any) {
        const msg = String((err && err.message) || "unknown");
        if (/Failed to fetch/i.test(msg)) {
          status.textContent = "转换失败：请求未到达接口（可能是 CORS 或接口地址不可达）。请检查 PUBLIC_TOOLS_API_BASE 与 tools-worker 的 CORS_ALLOWED_ORIGINS。";
        } else {
          status.textContent = `转换失败：${msg}`;
        }
      } finally {
        setBusy(false);
      }
    });

    copyBtn.addEventListener("click", async () => {
      if (!latestYaml) return;
      try {
        await navigator.clipboard.writeText(latestYaml);
        status.textContent = "YAML 已复制到剪贴板。";
      } catch {
        status.textContent = "复制失败，请手动复制。";
      }
    });

    downloadBtn.addEventListener("click", () => {
      if (!latestYaml) return;
      const blob = new Blob([latestYaml], { type: "application/x-yaml;charset=utf-8" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = "sub.yml";
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
    });

    clearInputBtn.addEventListener("click", () => {
      input.value = "";
      sourceUrlInput.value = "";
      status.textContent = "输入内容已清除。";
    });

    clearOutputBtn.addEventListener("click", () => {
      latestYaml = "";
      resultEl.textContent = "";
      resultWrap.hidden = true;
      status.textContent = "输出内容已清除。";
    });
  }

  const TEMP_MAIL_API_PATH = "/api/tools/temp-mail";
  const MBTI_API_PATH = "/api/tools/mbti-match";

  function initMbtiTool() {
    const form = document.querySelector("[data-mbti-form]");
    if (!(form instanceof HTMLFormElement)) return;
    if (form.dataset.inited === "1") return;
    form.dataset.inited = "1";

    const typeAEl = form.querySelector("[data-mbti-type-a]");
    const typeBEl = form.querySelector("[data-mbti-type-b]");
    const submitBtn = form.querySelector("[data-mbti-submit]");
    const deepBtn = form.querySelector("[data-mbti-deep]");
    const swapBtn = form.querySelector("[data-mbti-swap]");
    const copyBtn = form.querySelector("[data-mbti-copy]");
    const posterBtn = form.querySelector("[data-mbti-poster]");
    const status = form.querySelector("[data-mbti-status]");
    const resultWrap = form.querySelector("[data-mbti-result-wrap]");
    const pairEl = form.querySelector("[data-mbti-pair]");
    const tierEl = form.querySelector("[data-mbti-tier]");
    const overallEl = form.querySelector("[data-mbti-overall]");
    const dimensionsEl = form.querySelector("[data-mbti-dimensions]");
    const shareTitleEl = form.querySelector("[data-mbti-share-title]");
    const resultEl = form.querySelector("[data-mbti-result]");
    const deepResultEl = form.querySelector("[data-mbti-deep-result]");
    const posterModal = form.querySelector("[data-mbti-poster-modal]");
    const posterCloseBtns = form.querySelectorAll("[data-mbti-poster-close]");
    const posterPreview = form.querySelector("[data-mbti-poster-preview]");
    const posterDownloadBtn = form.querySelector("[data-mbti-poster-download]");
    const posterCopyBtn = form.querySelector("[data-mbti-poster-copy]");

    if (!(typeAEl instanceof HTMLSelectElement)) return;
    if (!(typeBEl instanceof HTMLSelectElement)) return;
    if (!(submitBtn instanceof HTMLButtonElement)) return;
    if (!(deepBtn instanceof HTMLButtonElement)) return;
    if (!(swapBtn instanceof HTMLButtonElement)) return;
    if (!(copyBtn instanceof HTMLButtonElement)) return;
    if (!(posterBtn instanceof HTMLButtonElement)) return;
    if (!(status instanceof HTMLElement)) return;
    if (!(resultWrap instanceof HTMLElement)) return;
    if (!(pairEl instanceof HTMLElement)) return;
    if (!(tierEl instanceof HTMLElement)) return;
    if (!(overallEl instanceof HTMLElement)) return;
    if (!(dimensionsEl instanceof HTMLElement)) return;
    if (!(shareTitleEl instanceof HTMLElement)) return;
    if (!(resultEl instanceof HTMLElement)) return;
    if (!(deepResultEl instanceof HTMLElement)) return;
    if (!(posterModal instanceof HTMLElement)) return;
    if (!(posterPreview instanceof HTMLElement)) return;
    if (!(posterDownloadBtn instanceof HTMLButtonElement)) return;
    if (!(posterCopyBtn instanceof HTMLButtonElement)) return;

    const apiBase = (form.dataset.toolsApiBase || "").replace(/\/$/, "");
    const apiUrl = `${apiBase}${MBTI_API_PATH}`;
    const types = ["INTJ","INTP","ENTJ","ENTP","INFJ","INFP","ENFJ","ENFP","ISTJ","ISFJ","ESTJ","ESFJ","ISTP","ISFP","ESTP","ESFP"];
    let latestPlainText = "";
    let busy = false;
    let latestPosterDataUrl = "";
    let lastDeepAt = 0;
    const DEEP_COOLDOWN_MS = 12000;

    const labels = {
      romance: "恋爱",
      friendship: "友情",
      communication: "沟通",
      conflict: "抗冲突",
      stability: "稳定度",
    };

    const esc = (v: unknown) =>
      String(v ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");

    const setBusy = (next: boolean) => {
      busy = next;
      submitBtn.disabled = next;
      deepBtn.disabled = next;
      swapBtn.disabled = next;
      typeAEl.disabled = next;
      typeBEl.disabled = next;
    };

    const wrapText = (ctx: CanvasRenderingContext2D, text: string, x: number, y: number, maxWidth: number, lineHeight: number, maxLines = 8) => {
      const words = String(text || "").split("");
      let line = "";
      let lines = 0;
      for (const ch of words) {
        const test = line + ch;
        if (ctx.measureText(test).width > maxWidth && line) {
          ctx.fillText(line, x, y);
          y += lineHeight;
          lines += 1;
          line = ch;
          if (lines >= maxLines) break;
        } else {
          line = test;
        }
      }
      if (line && lines < maxLines) {
        ctx.fillText(line, x, y);
        y += lineHeight;
      }
      return y;
    };

    const buildPoster = () => {
      if (!pairEl.textContent || pairEl.textContent === "-- × --") return null;
      const canvas = document.createElement("canvas");
      canvas.width = 1080;
      canvas.height = 1440;
      const ctx = canvas.getContext("2d");
      if (!ctx) return null;

      const gradient = ctx.createLinearGradient(0, 0, 1080, 1440);
      gradient.addColorStop(0, "#1d4ed8");
      gradient.addColorStop(0.45, "#7c3aed");
      gradient.addColorStop(1, "#0f172a");
      ctx.fillStyle = gradient;
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      ctx.fillStyle = "rgba(255,255,255,0.12)";
      ctx.beginPath();
      ctx.arc(920, 180, 180, 0, Math.PI * 2);
      ctx.fill();
      ctx.beginPath();
      ctx.arc(140, 1240, 220, 0, Math.PI * 2);
      ctx.fill();

      ctx.fillStyle = "#ffffff";
      ctx.font = "bold 64px Segoe UI, Microsoft YaHei, sans-serif";
      ctx.fillText("MBTI 匹配测试", 80, 120);
      ctx.font = "32px Segoe UI, Microsoft YaHei, sans-serif";
      ctx.fillStyle = "rgba(255,255,255,0.88)";
      ctx.fillText("这组到底是高甜、慢热，还是上头又拉扯？", 80, 176);

      ctx.fillStyle = "rgba(255,255,255,0.16)";
      ctx.fillRect(80, 240, 920, 180);
      ctx.fillStyle = "#ffffff";
      ctx.font = "bold 72px Segoe UI, Microsoft YaHei, sans-serif";
      ctx.fillText(pairEl.textContent || "", 120, 332);
      ctx.font = "bold 34px Segoe UI, Microsoft YaHei, sans-serif";
      ctx.fillStyle = "#bfdbfe";
      ctx.fillText(`综合匹配度 ${overallEl.textContent || "--"}${tierEl.textContent ? ` · ${tierEl.textContent}` : ""}`, 120, 388);

      const summaryText = shareTitleEl.textContent || resultEl.querySelector("p")?.textContent || latestPlainText.split("\n")[3] || "";
      ctx.fillStyle = "#ffffff";
      ctx.font = "bold 42px Segoe UI, Microsoft YaHei, sans-serif";
      ctx.fillText("一句话总结", 80, 500);
      ctx.font = "30px Segoe UI, Microsoft YaHei, sans-serif";
      ctx.fillStyle = "rgba(255,255,255,0.94)";
      let cursorY = wrapText(ctx, summaryText, 80, 555, 920, 42, 4);

      const cards = Array.from(dimensionsEl.children).slice(0, 5).map(node => ({
        title: node.querySelector("strong")?.textContent || "",
        value: node.querySelector("span")?.textContent || "",
      }));
      const startY = cursorY + 30;
      cards.forEach((card, index) => {
        const col = index % 2;
        const row = Math.floor(index / 2);
        const x = 80 + col * 455;
        const y = startY + row * 130;
        ctx.fillStyle = "rgba(255,255,255,0.14)";
        ctx.fillRect(x, y, 425, 100);
        ctx.fillStyle = "rgba(255,255,255,0.78)";
        ctx.font = "28px Segoe UI, Microsoft YaHei, sans-serif";
        ctx.fillText(card.title, x + 28, y + 38);
        ctx.fillStyle = "#ffffff";
        ctx.font = "bold 38px Segoe UI, Microsoft YaHei, sans-serif";
        ctx.fillText(String(card.value), x + 28, y + 78);
      });

      const noteY = startY + 3 * 130 + 40;
      ctx.fillStyle = "#ffffff";
      ctx.font = "bold 38px Segoe UI, Microsoft YaHei, sans-serif";
      ctx.fillText("适合直接发的标题", 80, noteY);
      ctx.font = "30px Segoe UI, Microsoft YaHei, sans-serif";
      ctx.fillStyle = "rgba(255,255,255,0.92)";
      wrapText(ctx, `${summaryText}`, 80, noteY + 54, 920, 40, 6);

      ctx.fillStyle = "rgba(255,255,255,0.66)";
      ctx.font = "24px Segoe UI, Microsoft YaHei, sans-serif";
      ctx.fillText("仅供娱乐参考 · 410666.xyz/tools", 80, 1360);

      return canvas;
    };

    const buildPosterPreviewImage = (canvas: HTMLCanvasElement) => {
      const img = document.createElement("img");
      img.src = canvas.toDataURL("image/png");
      img.alt = "MBTI 分享卡片预览";
      img.style.width = "180px";
      img.style.maxWidth = "100%";
      img.style.height = "auto";
      img.style.display = "block";
      img.style.borderRadius = "0.9rem";
      img.style.border = "1px solid color-mix(in oklab, var(--foreground) 14%, transparent)";
      img.style.boxShadow = "0 12px 40px rgba(15, 23, 42, 0.22)";
      return img;
    };

    const renderList = (title: string, items: string[]) => {
      if (!items?.length) return "";
      return `<h4>${esc(title)}</h4><ul>${items.map(item => `<li>${esc(item)}</li>`).join("")}</ul>`;
    };

    const buildPlainText = (analysis: any, deepText = "") => {
      return [
        `${analysis.typeA} × ${analysis.typeB}`,
        `标签：${analysis?.tier?.label || "--"}`,
        `综合匹配度：${analysis.overallScore}`,
        `分享标题：${analysis.shareTitle || ""}`,
        `总结：${analysis.summary}`,
        `亮点：${analysis.highlights.join("；")}`,
        `风险点：${analysis.risks.join("；")}`,
        `建议：${analysis.advice.join("；")}`,
        `趣味观察：${analysis.playful.join("；")}`,
        deepText ? `AI 深度解读：\n${deepText}` : "",
        analysis.disclaimer || "",
      ].filter(Boolean).join("\n");
    };

    const renderAnalysis = (analysis: any) => {
      resultWrap.hidden = false;
      pairEl.textContent = `${analysis.typeA} × ${analysis.typeB}`;
      tierEl.hidden = !analysis?.tier?.label;
      tierEl.textContent = analysis?.tier?.label ? `${analysis.tier.emoji || ""} ${analysis.tier.label}` : "";
      overallEl.textContent = String(analysis.overallScore || "--");
      shareTitleEl.hidden = !analysis?.shareTitle;
      shareTitleEl.textContent = analysis?.shareTitle || "";
      dimensionsEl.innerHTML = Object.entries(analysis.dimensions || {})
        .map(([key, value]) => `<div class="mbti-dimension-card"><strong>${esc(labels[key as keyof typeof labels] || key)}</strong><span>${esc(value)}</span></div>`)
        .join("");
      resultEl.innerHTML = [
        `<h4>一句话结论</h4><p>${esc(analysis.summary || "")}</p>`,
        renderList("亮点", analysis.highlights || []),
        renderList("风险点", analysis.risks || []),
        renderList("相处建议", analysis.advice || []),
        renderList("趣味观察", analysis.playful || []),
        `<p style="margin-top:0.75rem;color:#cbd5e1;">${esc(analysis.disclaimer || "")}</p>`,
      ].join("");
      deepResultEl.hidden = true;
      deepResultEl.innerHTML = "";
      latestPlainText = buildPlainText(analysis);
      latestPosterDataUrl = "";
    };

    const ensureTypes = () => {
      const options = types.map(type => `<option value="${type}">${type}</option>`).join("");
      typeAEl.insertAdjacentHTML("beforeend", options);
      typeBEl.insertAdjacentHTML("beforeend", options);
      typeAEl.value = "INFP";
      typeBEl.value = "ENFJ";
    };

    const requestAnalysis = async (action: "analyze" | "deep") => {
      const typeA = typeAEl.value.trim();
      const typeB = typeBEl.value.trim();
      if (!typeA || !typeB) {
        status.textContent = "请先选好两个 MBTI。";
        return;
      }

      setBusy(true);
      status.textContent = action === "deep" ? "AI 正在深度解读..." : "正在分析匹配度...";
      try {
        const res = await fetch(apiUrl, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ action, locale: "zh", typeA, typeB }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || !data?.ok) {
          status.textContent = data?.fallbackMessage || (data?.error ? `分析失败：${data.error}` : `分析失败：HTTP ${res.status}`);
          return;
        }
        renderAnalysis(data.data || {});
        if (action === "deep" && data?.data?.deepAnalysis) {
          deepResultEl.hidden = false;
          deepResultEl.innerHTML = `<h4>AI 深度解读 · ${esc(data?.data?.aiModel || "grok-4.1-fast")}</h4><div>${esc(data.data.deepAnalysis).replaceAll("\n", "<br>")}</div>`;
          latestPlainText = buildPlainText(data.data, data.data.deepAnalysis);
          status.textContent = `AI 深度解读已完成${data.requestId ? `（请求ID: ${data.requestId}）` : ""}`;
        } else {
          status.textContent = `基础分析已生成${data.requestId ? `（请求ID: ${data.requestId}）` : ""}`;
        }
      } catch (err: any) {
        status.textContent = `分析失败：${(err && err.message) || "unknown"}`;
      } finally {
        setBusy(false);
      }
    };

    ensureTypes();

    form.addEventListener("submit", async e => {
      e.preventDefault();
      if (busy) return;
      await requestAnalysis("analyze");
    });

    deepBtn.addEventListener("click", async e => {
      e.preventDefault();
      e.stopPropagation();
      if (busy) return;
      const now = Date.now();
      const remainMs = DEEP_COOLDOWN_MS - (now - lastDeepAt);
      if (remainMs > 0) {
        status.textContent = `AI 正在冷却中，请 ${Math.ceil(remainMs / 1000)} 秒后再试。`;
        return;
      }
      lastDeepAt = now;
      await requestAnalysis("deep");
    });

    swapBtn.addEventListener("click", e => {
      e.preventDefault();
      e.stopPropagation();
      const nextA = typeBEl.value;
      const nextB = typeAEl.value;
      typeAEl.value = nextA;
      typeBEl.value = nextB;
      status.textContent = "已交换顺序。";
    });

    copyBtn.addEventListener("click", async e => {
      e.preventDefault();
      e.stopPropagation();
      if (!latestPlainText) {
        status.textContent = "请先生成分析结果。";
        return;
      }
      try {
        await navigator.clipboard.writeText(latestPlainText);
        status.textContent = "分析结果已复制。";
      } catch {
        status.textContent = "复制失败，请手动复制。";
      }
    });

    const openPoster = () => {
      const canvas = buildPoster();
      if (!canvas) {
        status.textContent = "请先生成分析结果。";
        return;
      }
      posterPreview.innerHTML = "";
      latestPosterDataUrl = canvas.toDataURL("image/png");
      posterPreview.appendChild(buildPosterPreviewImage(canvas));
      posterModal.hidden = false;
      status.textContent = "分享卡片已生成。";
    };

    posterBtn.addEventListener("click", e => {
      e.preventDefault();
      e.stopPropagation();
      openPoster();
    });
    posterCloseBtns.forEach(btn => {
      if (!(btn instanceof HTMLElement)) return;
      btn.addEventListener("click", e => {
        e.preventDefault();
        e.stopPropagation();
        posterModal.hidden = true;
      });
    });

    posterDownloadBtn.addEventListener("click", e => {
      e.preventDefault();
      e.stopPropagation();
      if (!latestPosterDataUrl) {
        openPoster();
      }
      if (!latestPosterDataUrl) return;
      const a = document.createElement("a");
      a.href = latestPosterDataUrl;
      a.download = `mbti-${typeAEl.value || "A"}-${typeBEl.value || "B"}.png`;
      document.body.appendChild(a);
      a.click();
      a.remove();
    });

    posterCopyBtn.addEventListener("click", async e => {
      e.preventDefault();
      e.stopPropagation();
      if (!latestPlainText) {
        status.textContent = "请先生成分析结果。";
        return;
      }
      try {
        await navigator.clipboard.writeText(latestPlainText);
        status.textContent = "分享文案已复制。";
      } catch {
        status.textContent = "复制失败，请手动复制。";
      }
    });
  }

  function initTempMailTool() {
    const root = document.querySelector("[data-temp-mail]");
    if (!(root instanceof HTMLElement)) return;
    if (root.dataset.inited === "1") return;
    root.dataset.inited = "1";

    const createBtn = root.querySelector("[data-temp-mail-create]");
    const refreshBtn = root.querySelector("[data-temp-mail-refresh]");
    const autoBtn = root.querySelector("[data-temp-mail-auto]");
    const copyMailboxBtn = root.querySelector("[data-temp-mail-copy]");
    const status = root.querySelector("[data-temp-mail-status]");
    const mailboxEl = root.querySelector("[data-temp-mail-address]");
    const listEl = root.querySelector("[data-temp-mail-list]");
    const modal = root.querySelector("[data-temp-mail-modal]");
    const closeBtns = root.querySelectorAll("[data-temp-mail-close]");
    const detailSubject = root.querySelector("[data-temp-mail-detail-subject]");
    const detailMeta = root.querySelector("[data-temp-mail-detail-meta]");
    const detailContent = root.querySelector("[data-temp-mail-detail-content]");
    const otpWrap = root.querySelector("[data-temp-mail-otp-wrap]");
    const otpText = root.querySelector("[data-temp-mail-otp-text]");
    const copyOtpBtn = root.querySelector("[data-temp-mail-copy-otp]");

    if (!(createBtn instanceof HTMLButtonElement)) return;
    if (!(refreshBtn instanceof HTMLButtonElement)) return;
    if (!(autoBtn instanceof HTMLButtonElement)) return;
    if (!(copyMailboxBtn instanceof HTMLButtonElement)) return;
    if (!(status instanceof HTMLElement)) return;
    if (!(mailboxEl instanceof HTMLElement)) return;
    if (!(listEl instanceof HTMLElement)) return;
    if (!(modal instanceof HTMLElement)) return;
    if (!(detailSubject instanceof HTMLElement)) return;
    if (!(detailMeta instanceof HTMLElement)) return;
    if (!(detailContent instanceof HTMLElement)) return;
    if (!(otpWrap instanceof HTMLElement)) return;
    if (!(otpText instanceof HTMLElement)) return;
    if (!(copyOtpBtn instanceof HTMLButtonElement)) return;

    const apiBase = (root.dataset.toolsApiBase || "").replace(/\/$/, "");
    const apiUrl = `${apiBase}${TEMP_MAIL_API_PATH}`;
    let currentMailbox = "";
    const MANUAL_REFRESH_COOLDOWN_MS = 5000;
    let autoRefreshOn = true;
    let autoTimer = 0;
    let latestOtp = "";
    let lastManualRefreshAt = 0;

    const esc = (v: unknown) =>
      String(v ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");

    const toArray = (data: any): any[] => {
      if (Array.isArray(data)) return data;
      if (Array.isArray(data?.data)) return data.data;
      if (Array.isArray(data?.items)) return data.items;
      if (Array.isArray(data?.list)) return data.list;
      if (Array.isArray(data?.emails)) return data.emails;
      return [];
    };

    const detectOtp = (text: string) => {
      const src = String(text || "");
      const found: string[] = [];
      const pushUnique = (v: string) => {
        const token = String(v || "").trim();
        if (!token || found.includes(token)) return;
        found.push(token);
      };

      const numReg = /\b\d{4,8}\b/g;
      let m1: RegExpExecArray | null;
      while ((m1 = numReg.exec(src)) !== null) {
        pushUnique(m1[0]);
      }

      const alphaDashReg = /\b[A-Z0-9]{2,8}(?:-[A-Z0-9]{2,8}){1,3}\b/gi;
      let m2: RegExpExecArray | null;
      while ((m2 = alphaDashReg.exec(src)) !== null) {
        pushUnique(String(m2[0] || "").toUpperCase());
      }

      const lower = src.toLowerCase();
      const hasKeyword = /(验证码|verification code|otp|passcode|code|auth code|security code)/i.test(lower);

      if (!hasKeyword) {
        const prioritized = found.filter(v => /-/.test(v) || /\d/.test(v)).slice(0, 1);
        return prioritized;
      }
      return found.slice(0, 3);
    };

    const closeModal = () => {
      modal.hidden = true;
    };

    const openModal = () => {
      modal.hidden = false;
    };

    closeBtns.forEach(btn => {
      if (!(btn instanceof HTMLElement)) return;
      btn.addEventListener("click", closeModal);
    });

    const renderEmails = (list: any[]) => {
      if (!Array.isArray(list) || list.length === 0) {
        listEl.textContent = "暂无邮件";
        return;
      }
      listEl.innerHTML = list
        .slice(0, 10)
        .map((item: any) => {
          const id = item?.id ?? item?.email_id ?? item?._id ?? "";
          const subject = item?.subject || "(无主题)";
          const sender = item?.sender || item?.from || "unknown";
          const time = item?.received_at || item?.date || "";
          return `<button type="button" class="temp-mail-item" data-email-id="${esc(id)}"><span class="temp-mail-item-subject">${esc(subject)}</span><span class="temp-mail-item-meta">${esc(sender)} · ${esc(time)}</span></button>`;
        })
        .join("");
    };

    const fetchInbox = async (silent = false) => {
      if (!document.body.contains(root)) {
        if (autoTimer) window.clearInterval(autoTimer);
        return;
      }
      if (!currentMailbox) {
        status.textContent = "请先生成邮箱。";
        return;
      }
      if (!silent) status.textContent = "正在刷新收件箱...";
      const res = await fetch(`${apiUrl}?action=emails&mailbox=${encodeURIComponent(currentMailbox)}`);
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data?.ok) {
        status.textContent = data?.error ? `收件失败：${data.error}` : `收件失败：HTTP ${res.status}`;
        return;
      }
      renderEmails(toArray(data.data));
      if (!silent) status.textContent = `收件箱已刷新${data.requestId ? `（请求ID: ${data.requestId}）` : ""}`;
    };

    const syncAutoState = () => {
      autoBtn.textContent = `自动刷新：${autoRefreshOn ? "开" : "关"}`;
      if (autoRefreshOn && !autoTimer) {
        autoTimer = window.setInterval(() => {
          fetchInbox(true).catch(() => undefined);
        }, 30000);
      }
      if (!autoRefreshOn && autoTimer) {
        window.clearInterval(autoTimer);
        autoTimer = 0;
      }
    };

    const sanitizeHtml = (raw: string) => {
      const parser = new DOMParser();
      const doc = parser.parseFromString(String(raw || ""), "text/html");
      doc.querySelectorAll("script,style,iframe,object,embed,link,meta").forEach(el => el.remove());
      doc.querySelectorAll("*").forEach(el => {
        for (const attr of Array.from(el.attributes)) {
          const name = attr.name.toLowerCase();
          const value = attr.value || "";
          if (name.startsWith("on") || (name === "href" || name === "src") && /^javascript:/i.test(value)) {
            el.removeAttribute(attr.name);
          }
        }
      });
      return doc.body.innerHTML || "";
    };

    const openEmailDetail = async (emailId: string) => {
      if (!emailId) return;
      detailSubject.textContent = "邮件详情";
      detailMeta.textContent = "加载中...";
      detailContent.textContent = "加载中...";
      otpWrap.hidden = true;
      latestOtp = "";
      openModal();

      const res = await fetch(`${apiUrl}?action=email-detail&id=${encodeURIComponent(emailId)}`);
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data?.ok) {
        detailMeta.textContent = "加载失败";
        detailContent.textContent = data?.error ? `读取失败：${data.error}` : `读取失败：HTTP ${res.status}`;
        return;
      }

      const detail = data?.data || {};
      const subject = detail?.subject || "(无主题)";
      const sender = detail?.sender || detail?.from || "unknown";
      const time = detail?.received_at || detail?.date || "";
      const textBody = String(detail?.text || detail?.body || detail?.plain || detail?.content || "");
      const htmlBodyRaw = String(detail?.html || detail?.html_body || detail?.content_html || detail?.html_content || "");
      const explicitCode = String(detail?.verification_code || detail?.verificationCode || "").trim();
      const htmlBody = sanitizeHtml(htmlBodyRaw);

      detailSubject.textContent = subject;
      detailMeta.textContent = `${sender}${time ? ` · ${time}` : ""}`;
      if (htmlBody) {
        detailContent.innerHTML = htmlBody;
      } else {
        detailContent.textContent = textBody || String(detail?.preview || "") || "（无内容）";
      }

      const otpCandidates = explicitCode ? [explicitCode] : detectOtp(`${subject}\n${textBody}\n${htmlBodyRaw}\n${detail?.preview || ""}`);
      if (otpCandidates.length > 0) {
        latestOtp = otpCandidates[0];
        otpText.textContent = `验证码：${latestOtp}`;
        otpWrap.hidden = false;
      }
    };

    listEl.addEventListener("click", e => {
      const target = e.target instanceof Element ? e.target.closest("[data-email-id]") : null;
      if (!(target instanceof HTMLElement)) return;
      const emailId = String(target.dataset.emailId || "").trim();
      openEmailDetail(emailId).catch(() => {
        detailMeta.textContent = "加载失败";
        detailContent.textContent = "读取邮件详情失败。";
      });
    });

    createBtn.addEventListener("click", async () => {
      status.textContent = "正在生成邮箱...";
      const res = await fetch(`${apiUrl}?action=create`, { method: "POST" });
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data?.ok) {
        status.textContent = data?.error ? `生成失败：${data.error}` : `生成失败：HTTP ${res.status}`;
        return;
      }
      currentMailbox = data?.data?.email || "";
      mailboxEl.textContent = currentMailbox || "生成失败";
      status.textContent = `邮箱已生成${data.requestId ? `（请求ID: ${data.requestId}）` : ""}`;
      renderEmails([]);
      await fetchInbox(true);
    });

    refreshBtn.addEventListener("click", () => {
      const now = Date.now();
      const remainMs = MANUAL_REFRESH_COOLDOWN_MS - (now - lastManualRefreshAt);
      if (remainMs > 0) {
        const sec = Math.ceil(remainMs / 1000);
        status.textContent = `点击太频繁，请 ${sec} 秒后再刷新。`;
        return;
      }
      lastManualRefreshAt = now;
      fetchInbox().catch(() => undefined);
    });

    autoBtn.addEventListener("click", () => {
      autoRefreshOn = !autoRefreshOn;
      syncAutoState();
      status.textContent = autoRefreshOn ? "已开启自动刷新（30秒）。" : "已关闭自动刷新。";
    });

    copyMailboxBtn.addEventListener("click", async () => {
      if (!currentMailbox) {
        status.textContent = "请先生成邮箱。";
        return;
      }
      try {
        await navigator.clipboard.writeText(currentMailbox);
        status.textContent = "邮箱已复制到剪贴板。";
      } catch {
        status.textContent = "复制失败，请手动复制。";
      }
    });

    copyOtpBtn.addEventListener("click", async () => {
      if (!latestOtp) return;
      try {
        await navigator.clipboard.writeText(latestOtp);
        detailMeta.textContent = `${detailMeta.textContent || ""}（验证码已复制）`;
      } catch {
        detailMeta.textContent = `${detailMeta.textContent || ""}（复制失败）`;
      }
    });

    syncAutoState();
  }

  function initVpsResidualTool() {
    const form = document.querySelector("[data-vps-value-form]");
    if (!(form instanceof HTMLFormElement) || form.dataset.bound === "1") return;
    form.dataset.bound = "1";

    const paidInput = form.querySelector("[data-vps-paid]");
    const currencyInput = form.querySelector("[data-vps-currency]");
    const totalMonthsInput = form.querySelector("[data-vps-total-months]");
    const expiryInput = form.querySelector("[data-vps-expiry]");
    const status = form.querySelector("[data-vps-status]");
    const resultPanel = form.querySelector("[data-vps-result]");
    const valueEl = form.querySelector("[data-vps-value]");
    const fxDateEl = form.querySelector("[data-vps-fx-date]");
    const fxRateEl = form.querySelector("[data-vps-fx-rate]");
    const remainingEl = form.querySelector("[data-vps-remaining]");
    const ratioEl = form.querySelector("[data-vps-ratio]");
    const originalValueEl = form.querySelector("[data-vps-original-value]");
    const clearBtn = form.querySelector("[data-vps-clear]");

    if (!(paidInput instanceof HTMLInputElement)) return;
    if (!(currencyInput instanceof HTMLSelectElement)) return;
    if (!(totalMonthsInput instanceof HTMLInputElement)) return;
    if (!(expiryInput instanceof HTMLInputElement)) return;
    if (!(status instanceof HTMLElement)) return;
    if (!(resultPanel instanceof HTMLElement)) return;
    if (!(valueEl instanceof HTMLElement)) return;
    if (!(fxDateEl instanceof HTMLElement)) return;
    if (!(fxRateEl instanceof HTMLElement)) return;
    if (!(remainingEl instanceof HTMLElement)) return;
    if (!(ratioEl instanceof HTMLElement)) return;
    if (!(originalValueEl instanceof HTMLElement)) return;
    if (!(clearBtn instanceof HTMLButtonElement)) return;

    const fallbackFx = {
      date: new Date().toISOString().slice(0, 10),
      cnyPerUnit: {
        CNY: 1,
        USD: 7.2,
        GBP: 9.2,
        EUR: 7.8,
        HKD: 0.92,
      },
    };
    let fxSnapshot = fallbackFx;
    let fxLoaded = false;

    /** @param {number} value */
    function fmt(value) {
      return new Intl.NumberFormat("zh-CN", {
        minimumFractionDigits: 3,
        maximumFractionDigits: 3,
      }).format(value);
    }

    const fetchFx = async () => {
      if (fxLoaded) return fxSnapshot;

      try {
        const res = await fetch("https://open.er-api.com/v6/latest/CNY", { cache: "no-store" });
        const data = await res.json();
        if (!res.ok || data?.result !== "success" || !data?.rates) {
          fxSnapshot = fallbackFx;
          fxLoaded = true;
          return fxSnapshot;
        }

        function toCny(code) {
          if (code === "CNY") return 1;
          const r = Number(data.rates?.[code]);
          if (Number.isFinite(r) && r > 0) return 1 / r;
          if (code === "USD") return fallbackFx.cnyPerUnit.USD;
          if (code === "GBP") return fallbackFx.cnyPerUnit.GBP;
          if (code === "EUR") return fallbackFx.cnyPerUnit.EUR;
          if (code === "HKD") return fallbackFx.cnyPerUnit.HKD;
          return 1;
        }

        fxSnapshot = {
          date: String((data.time_last_update_utc || "").slice(0, 16) || data.time_last_update_unix || fallbackFx.date),
          cnyPerUnit: {
            CNY: 1,
            USD: toCny("USD"),
            GBP: toCny("GBP"),
            EUR: toCny("EUR"),
            HKD: toCny("HKD"),
          },
        };
        fxLoaded = true;
        return fxSnapshot;
      } catch {
        fxSnapshot = fallbackFx;
        fxLoaded = true;
        return fxSnapshot;
      }
    };

    const reset = () => {
      paidInput.value = "";
      currencyInput.value = "CNY";
      totalMonthsInput.value = "";
      expiryInput.value = "";
      status.textContent = "按公式：支付金额 × (剩余周期 / 总周期)";
      resultPanel.hidden = true;
      valueEl.textContent = "--";
      fxDateEl.textContent = "汇率日期：--";
      fxRateEl.textContent = "外币汇率：--";
      remainingEl.textContent = "剩余天数：--";
      ratioEl.textContent = "剩余占比：--";
      originalValueEl.textContent = "原币剩余：--";
    };

    form.addEventListener("submit", async event => {
      event.preventDefault();

      const paid = Number(paidInput.value);
      const currency = String(currencyInput.value || "CNY");
      const totalMonths = Number(totalMonthsInput.value);
      const expiryRaw = expiryInput.value;

      if (!Number.isFinite(paid) || paid < 0) {
        status.textContent = "请输入有效的支付金额。";
        resultPanel.hidden = true;
        return;
      }
      if (!Number.isFinite(totalMonths) || totalMonths <= 0) {
        status.textContent = "总周期（月）必须大于 0。";
        resultPanel.hidden = true;
        return;
      }
      if (!expiryRaw) {
        status.textContent = "请选择到期时间。";
        resultPanel.hidden = true;
        return;
      }

      const today = new Date();
      today.setHours(0, 0, 0, 0);

      const expiry = new Date(`${expiryRaw}T00:00:00`);
      if (Number.isNaN(expiry.getTime())) {
        status.textContent = "到期时间格式无效。";
        resultPanel.hidden = true;
        return;
      }

      const msPerDay = 24 * 60 * 60 * 1000;
      const remainingDays = Math.max(0, Math.ceil((expiry.getTime() - today.getTime()) / msPerDay));
      const remainingMonthsApprox = remainingDays / 30;
      const ratio = Math.max(0, Math.min(1, remainingMonthsApprox / totalMonths));

      const fx = await fetchFx();
      const cnyPerUnit = Number(fx.cnyPerUnit?.[currency] || 1);
      const paidCny = paid * cnyPerUnit;
      const valueCny = Math.max(0, Math.min(paidCny, paidCny * ratio));
      const valueOriginal = currency === "CNY" ? valueCny : valueCny / cnyPerUnit;

      valueEl.textContent = `剩余价值：${fmt(valueCny)} 元`;
      fxDateEl.textContent = `汇率日期：${fx.date}`;
      fxRateEl.textContent = `外币汇率：1 ${currency} = ${fmt(cnyPerUnit)} CNY`;
      remainingEl.textContent = `剩余天数：${remainingDays} 天`;
      ratioEl.textContent = `剩余占比：${(ratio * 100).toFixed(2)}%`;
      originalValueEl.textContent = `原币剩余：${fmt(valueOriginal)} ${currency}`;
      resultPanel.hidden = false;

      if (remainingDays <= 0) {
        status.textContent = "已到期或今日到期，剩余价值为 0。";
      } else {
        status.textContent = "已完成计算（按 30 天 = 1 个月折算，汇率每日更新）。";
      }
    });

    clearBtn.addEventListener("click", reset);
  }

  function initRandomStringTool() {
    const form = document.querySelector("[data-passgen-form]");
    if (!(form instanceof HTMLFormElement) || form.dataset.inited === "1") return;
    form.dataset.inited = "1";

    const lengthInput = form.querySelector("[data-passgen-length]");
    const outputInput = form.querySelector("[data-passgen-output]");
    const status = form.querySelector("[data-passgen-status]");
    const copyBtn = form.querySelector("[data-passgen-copy]");

    if (!(lengthInput instanceof HTMLInputElement)) return;
    if (!(outputInput instanceof HTMLInputElement)) return;
    if (!(status instanceof HTMLElement)) return;
    if (!(copyBtn instanceof HTMLButtonElement)) return;

    const CHARSET = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*()-_=+[]{};:,.?/";

    const clampLen = (raw) => {
      const n = Number(raw);
      if (!Number.isFinite(n)) return 16;
      return Math.max(4, Math.min(128, Math.floor(n)));
    };

    const randomString = (len) => {
      const chars = CHARSET;
      const n = chars.length;
      if (len <= 0) return "";

      // Prefer Web Crypto for strong randomness.
      const cryptoObj = globalThis.crypto;
      if (cryptoObj && typeof cryptoObj.getRandomValues === "function") {
        let out = "";
        const buf = new Uint32Array(1);
        const max = Math.floor(0xffffffff / n) * n;
        while (out.length < len) {
          cryptoObj.getRandomValues(buf);
          const x = buf[0];
          if (x >= max) continue;
          out += chars[x % n];
        }
        return out;
      }

      // Fallback (weaker): Math.random.
      let out = "";
      for (let i = 0; i < len; i++) {
        out += chars[Math.floor(Math.random() * n)];
      }
      return out;
    };

    const syncCopyState = () => {
      copyBtn.disabled = !outputInput.value;
    };

    const generate = () => {
      const len = clampLen(lengthInput.value);
      lengthInput.value = String(len);
      outputInput.value = randomString(len);
      status.textContent = `已生成 ${len} 位随机字符串。`;
      syncCopyState();
    };

    form.addEventListener("submit", e => {
      e.preventDefault();
      generate();
    });

    copyBtn.addEventListener("click", async () => {
      const text = outputInput.value || "";
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        status.textContent = "已复制到剪贴板。";
      } catch {
        try {
          outputInput.focus();
          outputInput.select();
          const ok = document.execCommand("copy");
          status.textContent = ok ? "已复制到剪贴板。" : "复制失败，请手动复制。";
        } catch {
          status.textContent = "复制失败，请手动复制。";
        }
      }
    });

    syncCopyState();
  }

  document.addEventListener("astro:page-load", initClashTool);
  document.addEventListener("astro:page-load", initMbtiTool);
  document.addEventListener("astro:page-load", initTempMailTool);
  document.addEventListener("astro:page-load", initVpsResidualTool);
  document.addEventListener("astro:page-load", initRandomStringTool);
  // New fun tools are initialized by their own module scripts.
</script>
